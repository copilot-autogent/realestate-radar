<script>
  // Dynamically load Chart.js when first needed (CDN, no npm dep)
  // jsDelivr +esm transforms the auto entry to a valid ESM module
  let Chart: any = null;
  let trendChartInstance: any = null;
  async function ensureChart() {
    if (Chart) return;
    // @ts-ignore — CDN ESM import, no type declarations needed
    const mod = await import("https://cdn.jsdelivr.net/npm/chart.js@4.4.0/auto/+esm");
    Chart = mod.default;
  }

  document.addEventListener("district-trend", async (e: Event) => {
    const { district, quarters, medians, buildingType, source } = (e as CustomEvent).detail as {
      district: string;
      quarters: string[];
      medians: number[];
      buildingType?: string;
      source?: string;
    };

    await ensureChart();

    const panel = document.getElementById("trend-panel") as HTMLDivElement;
    const title = document.getElementById("trend-title") as HTMLHeadingElement;
    const note  = document.getElementById("trend-note")  as HTMLParagraphElement;

    panel.style.display = "block";
    const typeLabel = buildingType ? ` ${buildingType}` : '';
    const sourceNote = source === 'dot' ? '同類型物件歷史走勢' : '行政區季均價走勢';
    title.textContent = `${district}${typeLabel} — 季均價走勢`;
    note.textContent  = quarters.length ? `${sourceNote}（共 ${quarters.length} 季）` : '暫無資料';


    const canvas = document.getElementById("trend-chart") as HTMLCanvasElement;

    if (trendChartInstance) {
      trendChartInstance.destroy();
      trendChartInstance = null;
    }

    if (!quarters.length) return;

    const data = medians.map((p: number) => Math.round(p / 10000));

    trendChartInstance = new Chart(canvas, {
      type: "line",
      data: {
        labels: quarters,
        datasets: [{
          label: "中位數單價 (萬/坪)",
          data,
          borderColor: "#2563eb",
          backgroundColor: "rgba(37,99,235,0.1)",
          tension: 0.3,
          pointRadius: 4,
          fill: true,
        }],
      },
      options: {
        responsive: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx: any) => `${ctx.parsed.y} 萬/坪`,
            },
          },
        },
        scales: {
          y: {
            beginAtZero: false,
            ticks: {
              callback: (v: any) => `${v}萬`,
              font: { size: 10 },
            },
          },
          x: {
            ticks: { font: { size: 10 }, maxRotation: 45 },
          },
        },
      },
    });
  });

  // ---- Price Histogram (vanilla SVG — no external dep) ----
  let currentPricesWan: number[] = [];
  let currentThresholdWan: number | undefined;

  function renderPriceHistogram(): void {
    const panel = document.getElementById("histogram-panel") as HTMLDivElement;
    const container = document.getElementById("histogram-svg-container") as HTMLDivElement;
    if (!panel || !container) return;

    // Filter to finite positive values only; guard against NaN propagation
    const prices = currentPricesWan.filter(p => Number.isFinite(p) && p > 0);
    if (!prices.length) {
      panel.style.display = "none";
      return;
    }
    panel.style.display = "block";

    const BIN = 5; // fixed 5万/坪 bin width
    // Clip to 2nd–98th percentile to prevent outliers from generating huge SVGs
    const s98 = [...prices].sort((a, b) => a - b);
    const p2  = s98[Math.max(0, Math.floor(s98.length * 0.02))];
    const p98 = s98[Math.min(s98.length - 1, Math.floor(s98.length * 0.98))];
    const lo0 = Math.floor(p2 / BIN) * BIN;
    // Ensure at least one bin even when all prices are the same exact BIN-multiple
    const hiEff = Math.max(Math.ceil(p98 / BIN) * BIN, lo0 + BIN);
    // Cap at 50 bins; recompute effective hi so threshold guard stays in-bounds
    const nBins = Math.min(50, Math.max(1, (hiEff - lo0) / BIN));
    const hi0 = lo0 + nBins * BIN;

    const bins = Array.from({ length: nBins }, (_, i) => ({
      lo: lo0 + i * BIN,
      hi: lo0 + (i + 1) * BIN,
      count: 0,
    }));
    for (const p of prices) {
      // Drop values outside the effective range (outliers excluded by percentile clip)
      if (p < lo0 || p > hi0) continue;
      const idx = Math.min(nBins - 1, Math.max(0, Math.floor((p - lo0) / BIN)));
      bins[idx].count++;
    }

    const maxCount = bins.reduce((a, b) => a > b.count ? a : b.count, 1);
    const W = 260, LPAD = 52, RPAD = 28, BAR_W = W - LPAD - RPAD;
    const ROW_H = 16, GAP = 2, TOP = 4;
    const H = TOP + nBins * (ROW_H + GAP);
    const thr = currentThresholdWan;

    const rows = bins.map(({ lo, hi, count }, i) => {
      const y = TOP + i * (ROW_H + GAP);
      const bw = Math.round((count / maxCount) * BAR_W);
      const fill = thr === undefined
        ? "#3b82f6"
        : hi <= thr ? "#22c55e"
        : lo < thr ? "#f59e0b"
        : "#94a3b8";
      const countLabel = count > 0
        ? `<text x="${LPAD + Math.max(bw, 2) + 3}" y="${ROW_H - 4}" font-size="9" fill="#475569">${count}</text>`
        : "";
      return `<g transform="translate(0,${y})"><text x="${LPAD - 4}" y="${ROW_H - 4}" text-anchor="end" font-size="9" fill="#64748b">${lo}–${hi}</text><rect x="${LPAD}" y="1" width="${Math.max(bw, count > 0 ? 2 : 0)}" height="${ROW_H - 2}" rx="2" fill="${fill}" opacity="0.85"><title>${count} 筆 (${lo}–${hi}萬/坪)</title></rect>${countLabel}</g>`;
    }).join("");

    let thrEl = "";
    // Show threshold line whenever it's within the displayed price range (inclusive)
    if (thr !== undefined && thr >= lo0 && thr <= hi0) {
      const ly = TOP + ((thr - lo0) / BIN) * (ROW_H + GAP);
      thrEl = `<line x1="${LPAD}" y1="${ly}" x2="${LPAD + BAR_W}" y2="${ly}" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="4 3"/><text x="${LPAD + BAR_W - 2}" y="${ly - 2}" font-size="8" fill="#ef4444" text-anchor="end">預算 ${thr.toFixed(0)}萬</text>`;
    }

    container.innerHTML = `<svg width="100%" viewBox="0 0 ${W} ${H}" style="display:block;overflow:visible">${rows}${thrEl}</svg>`;
  }

  document.addEventListener("stats-histogram", (e: Event) => {
    const { pricesWan } = (e as CustomEvent).detail as { pricesWan?: number[] };
    currentPricesWan = pricesWan ?? [];
    renderPriceHistogram();
  });

  document.addEventListener("budget-threshold-changed", (e: Event) => {
    const { thresholdWan } = (e as CustomEvent).detail as { thresholdWan?: number };
    currentThresholdWan = thresholdWan;
    renderPriceHistogram();
  });

  // ---- 議價時機 YoY Signal (dispatched by Map.astro on district click or search) ----
  document.addEventListener("yoy-signal", (e: Event) => {
    const { html } = (e as CustomEvent).detail as { district?: string; html: string };
    const panel = document.getElementById("yoy-panel") as HTMLDivElement | null;
    if (!panel) return;
    if (html) {
      panel.innerHTML = html;
      panel.style.display = "block";
    } else {
      panel.style.display = "none";
    }
  });

  // ---- 青安貸款換約提醒 banner ----
  (function initQinganBanner(): void {
    // Use local-timezone construction (avoids UTC-parse skew with ISO string)
    const DEADLINE = new Date(2026, 6, 1); // July 1, 2026 local time
    const DISMISS_KEY = "qingan_banner_dismissed";
    const WINDOW_DAYS = 60;

    const banner = document.getElementById("qingan-banner");
    if (!banner) return;

    const now = new Date();
    const msLeft = DEADLINE.getTime() - now.getTime();
    const daysLeft = msLeft / (1000 * 60 * 60 * 24);

    // Show when within the 60-day window (inclusive of day 60); hide on/after July 1 2026
    if (daysLeft <= 0 || daysLeft > WINDOW_DAYS) return;

    let dismissed = false;
    try { dismissed = localStorage.getItem(DISMISS_KEY) === "true"; } catch { /* storage blocked */ }
    if (dismissed) return;

    banner.style.display = "block";

    document.getElementById("qingan-dismiss")?.addEventListener("click", () => {
      banner.style.display = "none";
      try { localStorage.setItem(DISMISS_KEY, "true"); } catch { /* storage blocked */ }
    });

    // Smooth-scroll the mortgage calculator into view when the CTA link is clicked;
    // fall back to default anchor navigation if the target element is missing.
    banner.querySelector<HTMLAnchorElement>(".qingan-cta")?.addEventListener("click", (e) => {
      const target = document.getElementById("mortgage-calculator");
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  })();

  // ── Completion Wave Chart ──────────────────────────────────────────────────
  // Loads frontend/public/data/permits.json and renders a stacked bar chart
  // (quarterly 使照 completions) using Chart.js.  The "📦 完工供給強度" checkbox
  // also dispatches a completion-mode-change event to Map.astro.

  const BASE_URL_CWC = (import.meta as any).env?.BASE_URL ?? "/realestate-radar/";

  const CITY_COLORS: Record<string, string> = {
    "台北市": "#1d4ed8",
    "新北市": "#0891b2",
    "桃園市": "#16a34a",
    "台中市": "#ca8a04",
    "台南市": "#ea580c",
    "高雄市": "#dc2626",
  };

  let permitsData: {
    quarters: string[];
    first_projected_quarter: string;
    cities: Record<string, { building_permits: number[]; occupancy_permits: number[]; starts: number[] }>;
  } | null = null;

  let completionChartInstance: any = null;

  /** In-flight fetch promise to avoid duplicate concurrent requests. */
  let _permitsLoadPromise: Promise<typeof permitsData> | null = null;

  async function loadPermitsData(): Promise<typeof permitsData> {
    if (permitsData) return permitsData;
    if (_permitsLoadPromise) return _permitsLoadPromise;
    _permitsLoadPromise = (async () => {
      try {
        const url = BASE_URL_CWC.replace(/\/$/, "") + "/data/permits.json";
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        permitsData = await res.json();
      } catch (err) {
        console.warn("[completion-wave] failed to load permits.json:", err);
        permitsData = null;
      } finally {
        _permitsLoadPromise = null;
      }
      return permitsData;
    })();
    return _permitsLoadPromise;
  }

  async function renderCompletionWaveChart(selectedCity: string): Promise<void> {
    const data = await loadPermitsData();
    if (!data) return;

    await ensureChart(); // reuse the existing Chart.js loader

    const canvas = document.getElementById("completion-wave-chart") as HTMLCanvasElement | null;
    if (!canvas) return;

    if (completionChartInstance) {
      completionChartInstance.destroy();
      completionChartInstance = null;
    }

    const { quarters, first_projected_quarter, cities } = data;
    // Guard against first_projected_quarter not found in quarters array
    const projIdx = quarters.indexOf(first_projected_quarter);
    const safeProjIdx = projIdx >= 0 ? projIdx : quarters.length; // fallback: no projection

    let datasets: any[];
    const labels = quarters;

    if (selectedCity !== "all") {
      // Single city — single stack, two datasets for color split at projection boundary
      const cityData = cities[selectedCity];
      if (!cityData) return;
      const color = CITY_COLORS[selectedCity] ?? "#6366f1";

      datasets = [
        {
          label: `${selectedCity} 使照（實績）`,
          data: cityData.occupancy_permits.map((v, i) => (i < safeProjIdx ? v : null)),
          backgroundColor: color,
          borderColor: "transparent",
          stack: "op",
        },
        {
          label: `${selectedCity} 使照（預測）`,
          data: cityData.occupancy_permits.map((v, i) => (i >= safeProjIdx ? v : null)),
          backgroundColor: color + "66",
          borderColor: "transparent",
          stack: "op",
        },
      ];
    } else {
      // All cities — single stack per city, two datasets per city for color split
      const cityList = Object.keys(cities);
      datasets = cityList.flatMap((city) => {
        const color = CITY_COLORS[city] ?? "#6366f1";
        const op = cities[city].occupancy_permits;
        return [
          {
            label: `${city}（實績）`,
            data: op.map((v, i) => (i < safeProjIdx ? v : null)),
            backgroundColor: color,
            borderColor: "transparent",
            // All cities share the same stack key so they stack on top of each other
            stack: "all",
          },
          {
            label: `${city}（預測）`,
            data: op.map((v, i) => (i >= safeProjIdx ? v : null)),
            backgroundColor: color + "55",
            borderColor: "transparent",
            stack: "all",
          },
        ];
      });
    }

    // Show one label per year (every 4th quarter)
    const displayLabels = labels.map((q, i) => (i % 4 === 0 ? q : ""));

    completionChartInstance = new Chart(canvas, {
      type: "bar",
      data: { labels, datasets },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: { duration: 300 },
        plugins: {
          legend: {
            display: selectedCity === "all",
            position: "bottom" as const,
            labels: {
              font: { size: 9 },
              boxWidth: 10,
              padding: 6,
              // Show only the city name (first dataset per city), not "（預測）" duplicates
              filter: (item: any) => !item.text.includes("（預測）"),
            },
          },
          tooltip: {
            callbacks: {
              label: (ctx: any) => `${ctx.dataset.label}: ${ctx.parsed.y?.toLocaleString() ?? "–"} 宅`,
            },
          },
        },
        scales: {
          x: {
            stacked: true,
            ticks: {
              font: { size: 8 },
              maxRotation: 45,
              callback: (_val: any, i: number) => displayLabels[i],
            },
            grid: { display: false },
          },
          y: {
            stacked: true,
            ticks: {
              font: { size: 8 },
              callback: (v: any) => (v >= 1000 ? `${(v / 1000).toFixed(0)}K` : v),
            },
            title: {
              display: true,
              text: "使照核發數（宅）",
              font: { size: 8 },
              color: "#64748b",
            },
          },
        },
      },
      plugins: [
        {
          id: "projection-shading",
          beforeDraw(chart: any) {
            if (safeProjIdx <= 0 || safeProjIdx >= labels.length) return;
            const { ctx, chartArea, scales } = chart;
            if (!chartArea || !scales.x) return;
            // Use integer tick index to get pixel for left edge of the projection bar
            const x = scales.x.getPixelForValue(safeProjIdx - 0.5);
            ctx.save();
            ctx.fillStyle = "rgba(250,204,21,0.08)";
            ctx.fillRect(x, chartArea.top, chartArea.right - x, chartArea.bottom - chartArea.top);
            ctx.strokeStyle = "#eab308";
            ctx.lineWidth = 1;
            ctx.setLineDash([4, 3]);
            ctx.beginPath();
            ctx.moveTo(x, chartArea.top);
            ctx.lineTo(x, chartArea.bottom);
            ctx.stroke();
            ctx.setLineDash([]);
            ctx.font = "bold 8px sans-serif";
            ctx.fillStyle = "#92400e";
            ctx.fillText("預測 →", x + 3, chartArea.top + 10);
            ctx.restore();
          },
        },
      ],
    });
  }

  // Initial render (all cities)
  (async () => {
    await renderCompletionWaveChart("all");
  })();

  document.getElementById("completion-city-select")?.addEventListener("change", async (e) => {
    const city = (e.target as HTMLSelectElement).value;
    await renderCompletionWaveChart(city);
  });

  // ── Completion overlay toggle → dispatch to Map.astro ──────────────────────
  const completionOverlayToggle = document.getElementById("completion-overlay-toggle") as HTMLInputElement | null;

  async function updateCompletionOverlay(): Promise<void> {
    const enabled = completionOverlayToggle?.checked ?? false;

    if (enabled) {
      // Ensure choropleth districts are visible BEFORE dispatching, so Map.astro's
      // guard on districts-fill layer doesn't bail out on the first click
      const choroplethToggle = document.getElementById("choropleth-toggle") as HTMLInputElement | null;
      if (choroplethToggle && !choroplethToggle.checked) {
        choroplethToggle.checked = true;
        choroplethToggle.dispatchEvent(new Event("change"));
      }

      const data = await loadPermitsData();
      if (!data) {
        // Revert toggle on load failure
        if (completionOverlayToggle) completionOverlayToggle.checked = false;
        return;
      }
      document.dispatchEvent(new CustomEvent("completion-mode-change", {
        detail: { enabled: true, permitsData: data },
      }));
    } else {
      document.dispatchEvent(new CustomEvent("completion-mode-change", {
        detail: { enabled: false, permitsData: null },
      }));
    }
  }

  completionOverlayToggle?.addEventListener("change", updateCompletionOverlay);

  // Re-fire completion overlay when city changes (so district allocation stays fresh)
  document.getElementById("city-select")?.addEventListener("change", async () => {
    if (completionOverlayToggle?.checked) {
      await updateCompletionOverlay();
    }
  });

</script>
