---
import Layout from "../layouts/Layout.astro";
import Map from "../components/Map.astro";
---

<Layout title="實價登錄雷達 — Real Price Radar">
  <header class="header">
    <h1>🏠 實價登錄雷達</h1>
    <p class="subtitle">Real Price Radar — Taiwan Real Estate Analytics</p>
  </header>

  <main class="main">
    <aside class="sidebar">
      <div class="filter-group">
        <label for="city-select">縣市</label>
        <select id="city-select">
          <option value="">全部</option>
          <option value="台北市">台北市</option>
          <option value="新北市">新北市</option>
          <option value="桃園市">桃園市</option>
          <option value="台中市">台中市</option>
          <option value="台南市">台南市</option>
          <option value="高雄市">高雄市</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="district-select">鄉鎮市區</label>
        <select id="district-select">
          <option value="">全部</option>
          <option value="大安區">大安區</option>
          <option value="信義區">信義區</option>
          <option value="中山區">中山區</option>
          <option value="松山區">松山區</option>
          <option value="內湖區">內湖區</option>
          <option value="士林區">士林區</option>
          <option value="北投區">北投區</option>
          <option value="萬華區">萬華區</option>
          <option value="中正區">中正區</option>
          <option value="文山區">文山區</option>
          <option value="南港區">南港區</option>
          <option value="大同區">大同區</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="price-min">單價 (萬/坪)</label>
        <div class="range-inputs">
          <input type="number" id="price-min" placeholder="最低" />
          <span>~</span>
          <input type="number" id="price-max" placeholder="最高" />
        </div>
      </div>

      <div class="filter-group">
        <label for="building-type">建物型態</label>
        <select id="building-type">
          <option value="">全部</option>
          <option value="住宅大樓">住宅大樓</option>
          <option value="華廈">華廈</option>
          <option value="公寓">公寓</option>
          <option value="透天厝">透天厝</option>
          <option value="套房">套房</option>
        </select>
      </div>

      <!-- Choropleth toggle -->
      <div class="toggle-row">
        <input type="checkbox" id="choropleth-toggle" checked />
        <label for="choropleth-toggle">顯示行政區熱力圖</label>
      </div>

      <button id="search-btn" class="search-btn">搜尋</button>

      <div id="stats-panel" class="stats-panel">
        <h3>統計資訊</h3>
        <div id="stats-content">
          <p class="placeholder">選擇條件後按搜尋</p>
        </div>
      </div>

      <div id="trend-panel" class="trend-panel" style="display:none">
        <h3 id="trend-title">價格走勢</h3>
        <canvas id="trend-chart" width="260" height="160"></canvas>
        <p id="trend-note" class="trend-note"></p>
      </div>
    </aside>

    <div class="map-container">
      <Map />
    </div>
  </main>
</Layout>

<script>
  // Dynamically load Chart.js when first needed (CDN, no npm dep)
  let Chart: any = null;
  let trendChartInstance: any = null;

  async function ensureChart() {
    if (Chart) return;
    // @ts-ignore — CDN ESM import, no type declarations needed
    const mod = await import("https://cdn.jsdelivr.net/npm/chart.js@4.4.0/auto/auto.esm.js");
    Chart = mod.default;
  }

  document.addEventListener("district-trend", async (e: Event) => {
    const { district, quarters, medians } = (e as CustomEvent).detail as {
      district: string;
      quarters: string[];
      medians: number[];
    };

    await ensureChart();

    const panel = document.getElementById("trend-panel") as HTMLDivElement;
    const title = document.getElementById("trend-title") as HTMLHeadingElement;
    const note  = document.getElementById("trend-note")  as HTMLParagraphElement;

    panel.style.display = "block";
    title.textContent = `${district} — 季均價走勢`;
    note.textContent  = quarters.length ? `共 ${quarters.length} 季資料` : "暫無資料";

    const canvas = document.getElementById("trend-chart") as HTMLCanvasElement;

    if (trendChartInstance) {
      trendChartInstance.destroy();
      trendChartInstance = null;
    }

    if (!quarters.length) return;

    const data = medians.map((p: number) => Math.round(p / 10000));

    trendChartInstance = new Chart(canvas, {
      type: "line",
      data: {
        labels: quarters,
        datasets: [{
          label: "中位數單價 (萬/坪)",
          data,
          borderColor: "#2563eb",
          backgroundColor: "rgba(37,99,235,0.1)",
          tension: 0.3,
          pointRadius: 4,
          fill: true,
        }],
      },
      options: {
        responsive: false,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx: any) => `${ctx.parsed.y} 萬/坪`,
            },
          },
        },
        scales: {
          y: {
            beginAtZero: false,
            ticks: {
              callback: (v: any) => `${v}萬`,
              font: { size: 10 },
            },
          },
          x: {
            ticks: { font: { size: 10 }, maxRotation: 45 },
          },
        },
      },
    });
  });
</script>
