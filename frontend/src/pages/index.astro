---
import Layout from "../layouts/Layout.astro";
import Map from "../components/Map.astro";
import { DATA_AS_OF } from "../generated/metadata.ts";

/** Sentinel value written by generate-metadata when no real data is available (dev/lint mode). */
const PLACEHOLDER_DATE = "1970-01-01";
const isPlaceholder = DATA_AS_OF === PLACEHOLDER_DATE;

/** Convert "YYYY-MM-DD" to "YYYY 年 QN（YYYY-MM-DD）". Returns input as-is on malformed dates. */
function formatDataAsOf(isoDate: string): string {
  const parts = isoDate.split("-").map(Number);
  const [year, month] = parts;
  if (!year || !month || isNaN(month) || month < 1 || month > 12) return isoDate;
  const quarter = Math.ceil(month / 3);
  return `${year} 年 Q${quarter}（${isoDate}）`;
}

const dataAsOfLabel = formatDataAsOf(DATA_AS_OF);

/**
 * True if DATA_AS_OF is more than 180 days before today (date-string comparison, UTC-safe).
 * Suppressed when DATA_AS_OF is the dev-mode placeholder (1970-01-01).
 * Note: isStale is computed at build time (SSG). The banner reflects the state when the
 * site was last deployed, not when each user loads the page.
 */
const isStale = !isPlaceholder && (() => {
  const cutoff = new Date();
  cutoff.setUTCDate(cutoff.getUTCDate() - 180);
  const cutoffStr = cutoff.toISOString().slice(0, 10);
  return DATA_AS_OF < cutoffStr;
})();

/** Year derived from DATA_AS_OF for buyer's-market copy. Null in dev/placeholder or on malformed date. */
const dataYear = (() => {
  if (isPlaceholder) return null;
  if (!/^\d{4}-\d{2}-\d{2}/.test(DATA_AS_OF)) return null;
  const y = Number(DATA_AS_OF.slice(0, 4));
  return isNaN(y) || y === 0 ? null : y;
})();

/** Show buyer's-market trend copy only when data is fresh and a valid year is known. */
const showBuyersMarket = !isStale && dataYear !== null;
---

<Layout title="實價登錄雷達 — Real Price Radar">
  {isStale && (
    <div class="stale-banner" role="alert">
      ⚠️ 資料已超過 6 個月。最新交易資訊請至<a href="https://lvr.land.moi.gov.tw/" target="_blank" rel="noopener">內政部實價登錄</a>查詢。
    </div>
  )}
  <header class="header">
    <h1>🏠 實價登錄雷達</h1>
    <p class="subtitle">台灣不動產實價資訊平台</p>
    {showBuyersMarket && <p class="buyers-market-tagline">📉 行情下行，掌握議價優勢</p>}
    <span class="data-freshness-badge" title={`資料來源最新交易日期：${DATA_AS_OF}`}>
      資料更新至 {dataAsOfLabel}
    </span>
  </header>

  <main class="main">
    <div id="sidebar-backdrop" class="sidebar-backdrop"></div>
    <aside class="sidebar">
      <button id="sidebar-close-btn" class="sidebar-close-btn" aria-label="關閉篩選">✕</button>

      <!-- 青安貸款換約提醒 banner (shown client-side when within 60 days of 2026-07-01) -->
      <div id="qingan-banner" class="qingan-banner" role="alert" style="display:none">
        <button id="qingan-dismiss" class="qingan-dismiss" aria-label="關閉提醒">✕</button>
        <p class="qingan-text">
          ⚠️ <strong>青安貸款換約提醒</strong>：2026年7月起，利率從1.775%調升至2.3%（1,000萬40年期每月約多2,706元）。
        </p>
        <a href="#mortgage-calculator" class="qingan-cta">把握現行優惠期限，點此試算 →</a>
      </div>

      <div class="filter-group">
        <label for="address-search">地址搜尋</label>
        <div class="search-input-wrapper">
          <input type="text" id="address-search" placeholder="輸入路名、地址關鍵字…" autocomplete="off" />
          <button id="address-clear-btn" class="input-clear-btn" aria-label="清除" style="display:none">✕</button>
        </div>
      </div>

      <div class="filter-group">
        <label for="city-select">縣市</label>
        <select id="city-select">
          <option value="">全部</option>
          <option value="台北市">台北市</option>
          <option value="新北市">新北市</option>
          <option value="桃園市">桃園市</option>
          <option value="台中市">台中市</option>
          <option value="台南市">台南市</option>
          <option value="高雄市">高雄市</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="district-select">鄉鎮市區</label>
        <select id="district-select">
          <option value="">全部</option>
        </select>
      </div>

      <div class="filter-group">
        <label for="price-min">單價 (萬/坪)</label>
        <div class="range-inputs">
          <input type="number" id="price-min" placeholder="最低" />
          <span>~</span>
          <input type="number" id="price-max" placeholder="最高" />
        </div>
      </div>

      <div class="filter-group">
        <label for="total-price-min">總價 (萬)</label>
        <div class="range-inputs">
          <input type="number" id="total-price-min" placeholder="最低" min="0" />
          <span>~</span>
          <input type="number" id="total-price-max" placeholder="最高" min="0" />
        </div>
      </div>

      <div class="filter-group">
        <label for="area-min">坪數 (坪)</label>
        <div class="range-inputs">
          <input type="number" id="area-min" placeholder="最低" min="0" step="0.1" />
          <span>~</span>
          <input type="number" id="area-max" placeholder="最高" min="0" step="0.1" />
        </div>
      </div>

      <div class="filter-group">
        <label for="building-type">建物型態</label>
        <select id="building-type">
          <option value="">全部</option>
          <option value="住宅大樓">住宅大樓</option>
          <option value="華廈">華廈</option>
          <option value="公寓">公寓</option>
          <option value="透天厝">透天厝</option>
          <option value="套房">套房</option>
        </select>
      </div>

      <div class="filter-group">
        <label>交易期間</label>
        <div class="date-presets">
          <button class="preset-btn active" data-months="0">全部</button>
          <button class="preset-btn" data-months="6">近半年</button>
          <button class="preset-btn" data-months="12">近1年</button>
          <button class="preset-btn" data-months="24">近2年</button>
        </div>
        <div class="range-inputs" style="margin-top:8px">
          <input type="date" id="date-from" aria-label="開始日期" />
          <span>~</span>
          <input type="date" id="date-to" aria-label="結束日期" />
        </div>
      </div>

      <div class="filter-group">
        <label for="mrt-walk-min">距捷運站步行</label>
        <select id="mrt-walk-min">
          <option value="">任意距離</option>
          <option value="5">5分鐘內 (~400m)</option>
          <option value="10">10分鐘內 (~800m)</option>
          <option value="15">15分鐘內 (~1200m)</option>
        </select>
      </div>

      <!-- Choropleth toggle -->
      <div class="toggle-row">
        <input type="checkbox" id="choropleth-toggle" checked />
        <label for="choropleth-toggle">顯示行政區熱力圖</label>
      </div>

      <!-- Completion supply overlay toggle -->
      <div class="toggle-row">
        <input type="checkbox" id="completion-overlay-toggle" />
        <label for="completion-overlay-toggle">📦 完工供給強度</label>
      </div>

      <!-- MRT stations layer toggle (shown when MRT filter active) -->
      <div class="toggle-row" id="mrt-layer-toggle-row" style="display:none">
        <input type="checkbox" id="mrt-layer-toggle" checked />
        <label for="mrt-layer-toggle">🚇 顯示捷運站圖示</label>
      </div>

      <button id="search-btn" class="search-btn">搜尋</button>
      <button id="reset-btn" class="reset-btn">清除篩選</button>
      <button id="save-search-btn" class="save-search-btn">⭐ 儲存此搜尋</button>
      <button id="share-search-btn" type="button" class="share-search-btn">🔗 分享此搜尋</button>

      <div id="my-searches-panel" class="my-searches-panel" style="display:none">
        <div class="my-searches-header">⭐ 我的搜尋 (<span id="ss-count">0</span>)</div>
        <div id="my-searches-list" class="my-searches-list"></div>
      </div>

      <!-- Budget Calculator -->
      <div id="budget-calculator" class="budget-calculator">
        <h3>💰 預算計算器</h3>
        <div class="calc-inputs">
          <div class="calc-input-row">
            <label for="budget-total">總預算 (萬)</label>
            <input type="number" id="budget-total" placeholder="例如: 1000" min="0" step="50" />
          </div>
          <div class="calc-input-row">
            <label for="budget-ping">坪數需求 (坪)</label>
            <input type="number" id="budget-ping" placeholder="例如: 30" min="0" step="1" />
          </div>
        </div>
        <div id="budget-result" class="budget-result" style="display:none">
          <p>您的單價上限：<strong id="max-unit-price">0</strong> 萬/坪</p>
          <p id="affordable-districts" class="affordable-districts"></p>
        </div>
          <div class="toggle-row" id="affordability-toggle-row" style="margin-top:10px">
            <input type="checkbox" id="affordability-toggle" />
            <label for="affordability-toggle">🗺️ 顯示可負擔性地圖</label>
          </div>
      </div>

      <!-- Mortgage Calculator -->
      <div id="mortgage-calculator" class="mortgage-calculator">
        <h3>🏦 房貸試算器</h3>
        <div class="calc-inputs">
          <div class="calc-input-row">
            <label for="mortgage-total">總價 (萬)</label>
            <input type="number" id="mortgage-total" placeholder="例如: 1000" min="0" step="10" />
          </div>
          <div class="calc-input-row">
            <label for="mortgage-down">頭期款 (%)</label>
            <input type="number" id="mortgage-down" value="20" min="0" max="100" step="5" />
          </div>
          <div class="calc-input-row">
            <label for="mortgage-years">貸款年限</label>
            <select id="mortgage-years">
              <option value="20">20年</option>
              <option value="30" selected>30年</option>
            </select>
          </div>
          <div class="calc-input-row">
            <label for="mortgage-rate">利率 (%)</label>
            <input type="number" id="mortgage-rate" value="2.5" min="0" max="10" step="0.1" />
          </div>
        </div>
        <div id="mortgage-result" class="mortgage-result" style="display:none">
          <p>貸款金額：<strong id="loan-amount">0</strong> 萬</p>
          <p>每月還款：<strong id="monthly-payment">0</strong> 元</p>
          <p class="mortgage-detail">貸款總額：<span id="total-payment">0</span> 萬</p>
        </div>
      </div>

      <div id="stats-panel" class="stats-panel">
        <h3>統計資訊</h3>
        {showBuyersMarket && <p class="buyers-market-context">📉 {dataYear}年行情下行中 — 首購族議價空間擴大</p>}
        <div id="stats-content">
          <p class="placeholder">選擇條件後按搜尋</p>
        </div>
        <div id="yoy-panel" class="yoy-panel" style="display:none"></div>
      </div>

      <div id="trend-panel" class="trend-panel" style="display:none">
        <h3 id="trend-title">價格走勢</h3>
        <canvas id="trend-chart" width="260" height="160"></canvas>
        <p id="trend-note" class="trend-note"></p>
      </div>

      <div id="histogram-panel" class="histogram-panel" style="display:none">
        <h3>單價分佈 (萬/坪)</h3>
        <div id="histogram-svg-container"></div>
      </div>

      <div id="transaction-list-panel" class="transaction-list-panel" style="display:none">
        <div class="transaction-list-header">
          <h3>交易紀錄</h3>
          <div class="transaction-list-sort">
            <label>排序：</label>
            <select id="sort-by">
              <option value="date-desc">日期 (新→舊)</option>
              <option value="date-asc">日期 (舊→新)</option>
              <option value="unitPrice-desc">單價 (高→低)</option>
              <option value="unitPrice-asc">單價 (低→高)</option>
              <option value="totalPrice-desc">總價 (高→低)</option>
              <option value="totalPrice-asc">總價 (低→高)</option>
            </select>
          </div>
        </div>
        <div id="transaction-list-content" class="transaction-list-content"></div>
      </div>

      <!-- ── Completion Wave Panel ── -->
      <div id="completion-wave-panel" class="completion-wave-panel">
        <div class="completion-wave-header">
          <h3>📦 建造完工供給波浪</h3>
          <span class="completion-wave-badge projected-badge">2026–2028 預測</span>
        </div>
        <p class="completion-wave-desc">
          各縣市季度使用執照核發數（建築完工）。2026–2028 為依建照推估之預測值。
        </p>
        <div class="completion-city-select-row">
          <label for="completion-city-select">縣市</label>
          <select id="completion-city-select">
            <option value="all">全部六都</option>
            <option value="台北市">台北市</option>
            <option value="新北市">新北市</option>
            <option value="桃園市">桃園市</option>
            <option value="台中市">台中市</option>
            <option value="台南市">台南市</option>
            <option value="高雄市">高雄市</option>
          </select>
        </div>
        <div class="completion-chart-wrap">
          <canvas id="completion-wave-chart" width="260" height="200" aria-label="完工供給波浪圖"></canvas>
        </div>
        <p class="completion-wave-note" id="completion-wave-note">
          資料來源：內政部不動產資訊平台 E3030（示範資料）
        </p>
      </div>
    </aside>

    <div class="map-container">
      <div id="ss-alert-banner" class="ss-alert-banner" style="display:none"></div>
      <Map />
    </div>
  </main>
  <button id="filter-toggle-btn" class="filter-toggle-btn" aria-label="開啟篩選">☰ 篩選</button>
  <footer class="site-footer">
    <p>本工具無仲介費用衝突，提供市場真實成交資訊。資料來源：<a href="https://lvr.land.moi.gov.tw/" target="_blank" rel="noopener noreferrer">內政部實價登錄</a>。</p>
  </footer>
</Layout>

<script>
  // ---- District data per city ----
  const DISTRICTS_BY_CITY: Record<string, string[]> = {
    "台北市": ["中正區","大同區","中山區","松山區","大安區","萬華區","信義區","士林區","北投區","內湖區","南港區","文山區"],
    "新北市": ["板橋區","三重區","中和區","永和區","新莊區","新店區","土城區","蘆洲區","樹林區","汐止區","鶯歌區","三峽區","淡水區","林口區","五股區","泰山區","瑞芳區","八里區","深坑區","三芝區","萬里區","金山區","貢寮區","石門區","平溪區","雙溪區","石碇區","坪林區","烏來區"],
    "桃園市": ["桃園區","中壢區","大溪區","楊梅區","蘆竹區","大園區","龜山區","八德區","龍潭區","平鎮區","新屋區","觀音區","復興區"],
    "台中市": ["中區","東區","南區","西區","北區","北屯區","西屯區","南屯區","太平區","大里區","霧峰區","烏日區","豐原區","后里區","石岡區","東勢區","和平區","新社區","潭子區","大雅區","神岡區","大肚區","沙鹿區","龍井區","梧棲區","清水區","大甲區","外埔區","大安區"],
    "台南市": ["中西區","東區","南區","北區","安平區","安南區","永康區","歸仁區","新化區","左鎮區","玉井區","楠西區","南化區","仁德區","關廟區","龍崎區","官田區","麻豆區","佳里區","西港區","七股區","將軍區","學甲區","北門區","新營區","後壁區","白河區","東山區","六甲區","下營區","柳營區","鹽水區","善化區","大內區","山上區","新市區","安定區"],
    "高雄市": ["楠梓區","左營區","鼓山區","三民區","鹽埕區","前金區","新興區","苓雅區","前鎮區","旗津區","小港區","鳳山區","林園區","大寮區","大樹區","大社區","仁武區","鳥松區","岡山區","橋頭區","燕巢區","田寮區","阿蓮區","路竹區","湖內區","茄萣區","永安區","彌陀區","梓官區","旗山區","美濃區","六龜區","甲仙區","杉林區","內門區","茂林區","桃源區","那瑪夏區"],
  };

  // ---- Dynamic district dropdown ----
  function updateDistrictOptions(city: string): void {
    const districtSelect = document.getElementById("district-select") as HTMLSelectElement;
    const currentValue = districtSelect.value;
    districtSelect.innerHTML = '<option value="">全部</option>';
    const districts = city ? DISTRICTS_BY_CITY[city] : [];
    for (const d of districts) {
      const opt = document.createElement("option");
      opt.value = d;
      opt.textContent = d;
      districtSelect.appendChild(opt);
    }
    // Restore selection if still valid
    if (districts.includes(currentValue)) {
      districtSelect.value = currentValue;
    }
  }

  document.getElementById("city-select")?.addEventListener("change", (e) => {
    updateDistrictOptions((e.target as HTMLSelectElement).value);
  });

  // ---- Address search ----
  const addressInput = document.getElementById("address-search") as HTMLInputElement;
  const addressClearBtn = document.getElementById("address-clear-btn") as HTMLButtonElement;

  addressInput?.addEventListener("input", () => {
    addressClearBtn.style.display = addressInput.value ? "block" : "none";
  });

  addressClearBtn?.addEventListener("click", () => {
    addressInput.value = "";
    addressClearBtn.style.display = "none";
    document.getElementById("search-btn")?.click();
  });

  // Enter key triggers search
  addressInput?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      document.getElementById("search-btn")?.click();
    }
  });

  // ---- URL state ----
  function getFilterParams(): Record<string, string> {
    const params: Record<string, string> = {};
    const city         = (document.getElementById("city-select")     as HTMLSelectElement)?.value;
    const district     = (document.getElementById("district-select")  as HTMLSelectElement)?.value;
    const minPrice     = (document.getElementById("price-min")        as HTMLInputElement)?.value;
    const maxPrice     = (document.getElementById("price-max")        as HTMLInputElement)?.value;
    const buildingType = (document.getElementById("building-type")    as HTMLSelectElement)?.value;
    const address      = (document.getElementById("address-search")   as HTMLInputElement)?.value;
    if (city)         params.city = city;
    if (district)     params.district = district;
    if (minPrice)     params.minPrice = minPrice;
    if (maxPrice)     params.maxPrice = maxPrice;
    const totalPriceMin = (document.getElementById("total-price-min") as HTMLInputElement)?.value;
    const totalPriceMax = (document.getElementById("total-price-max") as HTMLInputElement)?.value;
    if (totalPriceMin) params.totalPriceMin = totalPriceMin;
    const areaMin = (document.getElementById("area-min") as HTMLInputElement)?.value;
    const areaMax = (document.getElementById("area-max") as HTMLInputElement)?.value;
    if (totalPriceMax) params.totalPriceMax = totalPriceMax;
    if (areaMin) params.areaMin = areaMin;
    if (areaMax) params.areaMax = areaMax;
    if (buildingType) params.buildingType = buildingType;
    if (address)      params.address = address;
    const dateFrom = (document.getElementById("date-from") as HTMLInputElement)?.value;
    const dateTo   = (document.getElementById("date-to")   as HTMLInputElement)?.value;
    if (dateFrom) params.dateFrom = dateFrom;
    if (dateTo)   params.dateTo   = dateTo;
    const mrtWalkMin = (document.getElementById("mrt-walk-min") as HTMLSelectElement)?.value;
    if (mrtWalkMin) params.mrtWalkMin = mrtWalkMin;
    return params;
  }

  function pushUrlState(params: Record<string, string>): void {
    const qs = new URLSearchParams(params).toString();
    const newUrl = qs ? `${location.pathname}?${qs}` : location.pathname;
    history.pushState(null, "", newUrl);
  }

  function loadFromUrl(): void {
    const sp = new URLSearchParams(location.search);
    const set = (id: string, key: string) => {
      const el = document.getElementById(id) as HTMLSelectElement | HTMLInputElement | null;
      const v = sp.get(key);
      if (el && v) el.value = v;
    };
    set("city-select",     "city");
    // Populate district options before setting value
    const city = sp.get("city");
    if (city) updateDistrictOptions(city);
    set("district-select", "district");
    set("price-min",       "minPrice");
    set("price-max",       "maxPrice");
    set("total-price-min", "totalPriceMin");
    set("total-price-max", "totalPriceMax");
    set("area-min", "areaMin");
    set("area-max", "areaMax");
    set("building-type",   "buildingType");
    set("date-from",       "dateFrom");
    set("date-to",         "dateTo");
    set("address-search",  "address");
    set("mrt-walk-min",    "mrtWalkMin");
    // Show clear button if address has value
    if (sp.get("address")) {
      addressClearBtn.style.display = "block";
    }
  }

  // Hook search button to also push URL state
  document.getElementById("search-btn")?.addEventListener("click", () => {
    pushUrlState(getFilterParams());
  });

  // Reset button
  document.getElementById("reset-btn")?.addEventListener("click", () => {
    (document.getElementById("city-select")     as HTMLSelectElement).value = "";
    (document.getElementById("district-select")  as HTMLSelectElement).value = "";
    (document.getElementById("price-min")        as HTMLInputElement).value  = "";
    (document.getElementById("price-max")        as HTMLInputElement).value  = "";
    (document.getElementById("total-price-min") as HTMLInputElement).value  = "";
    (document.getElementById("total-price-max") as HTMLInputElement).value  = "";
    (document.getElementById("area-min") as HTMLInputElement).value = "";
    (document.getElementById("area-max") as HTMLInputElement).value = "";
    (document.getElementById("building-type")    as HTMLSelectElement).value = "";
    (document.getElementById("date-from") as HTMLInputElement).value = "";
    (document.getElementById("date-to")   as HTMLInputElement).value = "";
    (document.getElementById("address-search") as HTMLInputElement).value = "";
    addressClearBtn.style.display = "none";
    (document.getElementById("mrt-walk-min") as HTMLSelectElement).value = "";
    // Hide MRT layer toggle row on reset and restore checkbox default state
    const mrtToggleRow = document.getElementById("mrt-layer-toggle-row");
    if (mrtToggleRow) mrtToggleRow.style.display = "none";
    const mrtLayerToggle = document.getElementById("mrt-layer-toggle") as HTMLInputElement | null;
    if (mrtLayerToggle) mrtLayerToggle.checked = true;
    document.dispatchEvent(new CustomEvent("mrt-filter-reset"));
    // Reset district options
    updateDistrictOptions("");
    // Reset preset active state
    document.querySelectorAll(".preset-btn").forEach(b => b.classList.remove("active"));
    document.querySelector('.preset-btn[data-months="0"]')?.classList.add("active");
    history.pushState(null, "", location.pathname);
    document.getElementById("search-btn")?.click();
  });

  // Date preset buttons
  document.querySelectorAll(".preset-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      // Mark active
      document.querySelectorAll(".preset-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");

      const months = Number((btn as HTMLButtonElement).dataset.months ?? "0");
      const dateFromEl = document.getElementById("date-from") as HTMLInputElement;
      const dateToEl   = document.getElementById("date-to")   as HTMLInputElement;

      if (months === 0) {
        // "全部" — clear both date inputs
        dateFromEl.value = "";
        dateToEl.value   = "";
      } else {
        // Compute dateFrom = today minus N months
        const to   = new Date();
        const from = new Date();
        from.setMonth(from.getMonth() - months);
        const fmt = (d: Date) => d.toISOString().slice(0, 10);
        dateFromEl.value = fmt(from);
        dateToEl.value   = fmt(to);
      }
      // Trigger search
      document.getElementById("search-btn")?.click();
    });
  });

  // Clear preset active state when date inputs are manually changed
  ["date-from", "date-to"].forEach((id) => {
    document.getElementById(id)?.addEventListener("change", () => {
      document.querySelectorAll(".preset-btn").forEach(b => b.classList.remove("active"));
      // Mark "全部" active if both are empty
      const df = (document.getElementById("date-from") as HTMLInputElement)?.value;
      const dt = (document.getElementById("date-to")   as HTMLInputElement)?.value;
      if (!df && !dt) {
        document.querySelector('.preset-btn[data-months="0"]')?.classList.add("active");
      }
    });
  });

  // ---- Mobile sidebar toggle ----
  const sidebar  = document.querySelector(".sidebar")         as HTMLElement | null;
  const backdrop = document.getElementById("sidebar-backdrop") as HTMLElement | null;

  function openSidebar()  {
    sidebar?.classList.add("open");
    backdrop?.classList.add("open");
    document.body.style.overflow = "hidden";
  }
  function closeSidebar() {
    sidebar?.classList.remove("open");
    backdrop?.classList.remove("open");
    document.body.style.overflow = "";
  }

  document.getElementById("filter-toggle-btn")?.addEventListener("click", openSidebar);
  document.getElementById("sidebar-close-btn")?.addEventListener("click", closeSidebar);
  backdrop?.addEventListener("click", closeSidebar);

  // ---- On load: restore from URL ----
  loadFromUrl();
  if (location.search) {
    setTimeout(() => document.getElementById("search-btn")?.click(), 800);
  }

  // ============================================================
  // ---- Budget Calculator -------------------------------------
  // ============================================================

  const budgetTotalInput = document.getElementById("budget-total") as HTMLInputElement;
  const budgetPingInput = document.getElementById("budget-ping") as HTMLInputElement;
  const budgetResultDiv = document.getElementById("budget-result") as HTMLDivElement;
  const maxUnitPriceSpan = document.getElementById("max-unit-price") as HTMLSpanElement;
  const affordableDistrictsP = document.getElementById("affordable-districts") as HTMLParagraphElement;

  function calculateBudget(): void {
    const total = parseFloat(budgetTotalInput.value);
    const ping = parseFloat(budgetPingInput.value);
    
    if (!total || !ping || ping <= 0) {
      budgetResultDiv.style.display = "none";
      document.dispatchEvent(new CustomEvent("budget-threshold-changed", { detail: { thresholdWan: undefined } }));
      return;
    }

    const maxUnitPrice = total / ping;
    maxUnitPriceSpan.textContent = maxUnitPrice.toFixed(1);
    budgetResultDiv.style.display = "block";

    // Show affordable districts hint (no actual filtering yet, just a note)
    const citySelect = document.getElementById("city-select") as HTMLSelectElement;
    if (citySelect.value) {
      affordableDistrictsP.textContent = `提示：在篩選中選擇 ${citySelect.value}，使用「單價上限 ${maxUnitPrice.toFixed(1)} 萬/坪」來搜尋符合預算的房源。`;
    } else {
      affordableDistrictsP.textContent = "提示：先選擇縣市，再使用「單價」篩選來查看符合預算的區域。";
    }

    // Notify histogram renderer to show affordability threshold line
    document.dispatchEvent(new CustomEvent("budget-threshold-changed", { detail: { thresholdWan: maxUnitPrice } }));
  }

  budgetTotalInput?.addEventListener("input", calculateBudget);
  budgetPingInput?.addEventListener("input", calculateBudget);

  // ---- Affordability Map Toggle ----
  const affordabilityToggle = document.getElementById("affordability-toggle") as HTMLInputElement;
  
  function updateAffordabilityMode(): void {
    const total = parseFloat(budgetTotalInput.value);
    const ping = parseFloat(budgetPingInput.value);
    const enabled = affordabilityToggle?.checked ?? false;
    
    if (enabled && total > 0 && ping > 0) {
      // Convert total budget from 萬 to TWD (×10000), then calc max unit price
      const maxUnitPricePerPing = (total * 10000) / ping;
      document.dispatchEvent(new CustomEvent("affordability-mode-change", {
        detail: { enabled: true, maxUnitPricePerPing, totalBudget: total, desiredPing: ping },
      }));
    } else {
      document.dispatchEvent(new CustomEvent("affordability-mode-change", {
        detail: { enabled: false },
      }));
    }
  }
  
  affordabilityToggle?.addEventListener("change", updateAffordabilityMode);
  budgetTotalInput?.addEventListener("input", () => {
    if (affordabilityToggle?.checked) updateAffordabilityMode();
  });
  budgetPingInput?.addEventListener("input", () => {
    if (affordabilityToggle?.checked) updateAffordabilityMode();
  });

  // ============================================================
  // ---- Mortgage Calculator -----------------------------------
  // ============================================================

  const mortgageTotalInput = document.getElementById("mortgage-total") as HTMLInputElement;
  const mortgageDownInput = document.getElementById("mortgage-down") as HTMLInputElement;
  const mortgageYearsSelect = document.getElementById("mortgage-years") as HTMLSelectElement;
  const mortgageRateInput = document.getElementById("mortgage-rate") as HTMLInputElement;
  const mortgageResultDiv = document.getElementById("mortgage-result") as HTMLDivElement;
  const loanAmountSpan = document.getElementById("loan-amount") as HTMLSpanElement;
  const monthlyPaymentSpan = document.getElementById("monthly-payment") as HTMLSpanElement;
  const totalPaymentSpan = document.getElementById("total-payment") as HTMLSpanElement;

  function calculateMortgage(): void {
    const totalPrice = parseFloat(mortgageTotalInput.value); // 萬
    const downPercent = parseFloat(mortgageDownInput.value);
    const years = parseInt(mortgageYearsSelect.value);
    const ratePercent = parseFloat(mortgageRateInput.value);

    if (!totalPrice || !downPercent || !years || !ratePercent) {
      mortgageResultDiv.style.display = "none";
      return;
    }

    // Calculate loan amount (萬)
    const loanAmount = totalPrice * (1 - downPercent / 100);
    loanAmountSpan.textContent = loanAmount.toFixed(0);

    // Monthly interest rate (decimal)
    const monthlyRate = ratePercent / 100 / 12;
    const numPayments = years * 12;

    // Monthly payment formula: P * [r(1+r)^n] / [(1+r)^n - 1]
    const monthlyPayment = (loanAmount * 10000) * 
      (monthlyRate * Math.pow(1 + monthlyRate, numPayments)) / 
      (Math.pow(1 + monthlyRate, numPayments) - 1);

    monthlyPaymentSpan.textContent = monthlyPayment.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ",");

    // Total payment over loan period
    const totalPayment = (monthlyPayment * numPayments) / 10000;
    totalPaymentSpan.textContent = totalPayment.toFixed(0);

    mortgageResultDiv.style.display = "block";
  }

  mortgageTotalInput?.addEventListener("input", calculateMortgage);
  mortgageDownInput?.addEventListener("input", calculateMortgage);
  mortgageYearsSelect?.addEventListener("change", calculateMortgage);
  mortgageRateInput?.addEventListener("input", calculateMortgage);

  // ============================================================
  // ---- Saved Search Feature ----------------------------------
  // ============================================================

  const SS_KEY = "realestate-radar-saved-searches";
  const LISTINGS_URL = `${import.meta.env.BASE_URL}data/sample-transactions.json`;

  interface SavedSearch {
    id: string;
    name: string;
    city?: string;
    district?: string;
    maxUnitPrice?: number;   // 萬/坪 (unit price)
    maxTotalPrice?: number;  // 萬 TWD (total price)
    buildingType?: string;
    created_at: string;
  }

  function ssGetAll(): SavedSearch[] {
    try { return JSON.parse(localStorage.getItem(SS_KEY) ?? "[]"); } catch { return []; }
  }

  function ssSaveAll(list: SavedSearch[]): void {
    localStorage.setItem(SS_KEY, JSON.stringify(list));
  }

  function ssDelete(id: string): void {
    ssSaveAll(ssGetAll().filter(s => s.id !== id));
    ssRender();
  }

  function ssApply(search: SavedSearch): void {
    // Reset all filters first
    (document.getElementById("city-select") as HTMLSelectElement).value = "";
    (document.getElementById("district-select") as HTMLSelectElement).value = "";
    (document.getElementById("price-min") as HTMLInputElement).value = "";
    (document.getElementById("price-max") as HTMLInputElement).value = "";
    (document.getElementById("total-price-min") as HTMLInputElement).value = "";
    (document.getElementById("total-price-max") as HTMLInputElement).value = "";
    (document.getElementById("area-min") as HTMLInputElement).value = "";
    (document.getElementById("area-max") as HTMLInputElement).value = "";
    (document.getElementById("building-type") as HTMLSelectElement).value = "";
    updateDistrictOptions("");

    if (search.city) {
      (document.getElementById("city-select") as HTMLSelectElement).value = search.city;
      updateDistrictOptions(search.city);
    }
    if (search.district) {
      (document.getElementById("district-select") as HTMLSelectElement).value = search.district;
    }
    if (search.maxUnitPrice) {
      (document.getElementById("price-max") as HTMLInputElement).value = String(search.maxUnitPrice);
    }
    if (search.maxTotalPrice) {
      (document.getElementById("total-price-max") as HTMLInputElement).value = String(search.maxTotalPrice);
    }
    if (search.buildingType) {
      (document.getElementById("building-type") as HTMLSelectElement).value = search.buildingType;
    }
    document.getElementById("search-btn")?.click();
    closeSidebar();
  }

  function ssRender(): void {
    const list = ssGetAll();
    const panel = document.getElementById("my-searches-panel") as HTMLDivElement | null;
    const listEl = document.getElementById("my-searches-list") as HTMLDivElement | null;
    const countEl = document.getElementById("ss-count") as HTMLSpanElement | null;
    if (!panel || !listEl) return;

    if (countEl) countEl.textContent = String(list.length);
    panel.style.display = list.length > 0 ? "block" : "none";

    listEl.innerHTML = "";
    for (const s of list) {
      const tags: string[] = [];
      if (s.city) tags.push(s.city);
      if (s.district) tags.push(s.district);
      if (s.maxTotalPrice) tags.push(`總價≤${s.maxTotalPrice}萬`);
      if (s.maxUnitPrice) tags.push(`單價≤${s.maxUnitPrice}萬/坪`);
      if (s.buildingType) tags.push(s.buildingType);

      const item = document.createElement("div");
      item.className = "ss-item";
      item.innerHTML = `
        <div class="ss-item-info">
          <div class="ss-item-name">${s.name}</div>
          <div class="ss-item-tags">${tags.map(t => `<span class="ss-tag">${t}</span>`).join("")}</div>
        </div>
        <div class="ss-item-actions">
          <button class="ss-apply-btn" title="套用此搜尋">套用</button>
          <button class="ss-del-btn" title="刪除">✕</button>
        </div>
      `;
      item.querySelector(".ss-apply-btn")?.addEventListener("click", () => ssApply(s));
      item.querySelector(".ss-del-btn")?.addEventListener("click", () => ssDelete(s.id));
      listEl.appendChild(item);
    }
  }

  // Save current filter state as a new saved search
  document.getElementById("save-search-btn")?.addEventListener("click", () => {
    const city         = (document.getElementById("city-select")      as HTMLSelectElement).value;
    const district     = (document.getElementById("district-select")   as HTMLSelectElement).value;
    const maxUnitPriceStr  = (document.getElementById("price-max")        as HTMLInputElement).value;
    const maxTotalPriceStr = (document.getElementById("total-price-max")  as HTMLInputElement).value;
    const buildingType = (document.getElementById("building-type")    as HTMLSelectElement).value;

    const parts: string[] = [];
    if (city) parts.push(city);
    if (district) parts.push(district);
    if (maxTotalPriceStr) parts.push(`≤${maxTotalPriceStr}萬`);
    if (buildingType) parts.push(buildingType);
    const suggestedName = parts.join(" ") || "我的搜尋";

    const name = prompt("為此搜尋條件命名：", suggestedName);
    if (name === null) return;

    const search: SavedSearch = {
      id: `ss-${Date.now()}-${Math.random().toString(36).slice(2, 7)}`,
      name: name.trim() || suggestedName,
      ...(city && { city }),
      ...(district && { district }),
      ...(maxUnitPriceStr  && { maxUnitPrice:  Number(maxUnitPriceStr) }),
      ...(maxTotalPriceStr && { maxTotalPrice: Number(maxTotalPriceStr) }),
      ...(buildingType && { buildingType }),
      created_at: new Date().toISOString(),
    };

    ssSaveAll([...ssGetAll(), search]);
    ssRender();
  });

  // Share search button: copy current URL to clipboard
  const SHARE_BTN_LABEL = "🔗 分享此搜尋";
  document.getElementById("share-search-btn")?.addEventListener("click", async (e) => {
    const btn = e.currentTarget as HTMLButtonElement;
    // Guard against re-entry during success (2s) or error (3s) feedback windows
    if (btn.disabled) return;

    btn.disabled = true;
    const url = window.location.href;

    let copied = false;
    if (navigator.clipboard?.writeText) {
      try {
        await navigator.clipboard.writeText(url);
        copied = true;
      } catch {
        // fall through to execCommand
      }
    }
    if (!copied) {
      // execCommand fallback for older browsers
      const ta = document.createElement("textarea");
      ta.value = url;
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      try { copied = document.execCommand("copy"); } catch { /* ignore */ }
      document.body.removeChild(ta);
    }

    btn.disabled = true;
    if (copied) {
      btn.textContent = "✓ 連結已複製";
      btn.classList.add("copied");
      setTimeout(() => {
        btn.textContent = SHARE_BTN_LABEL;
        btn.classList.remove("copied");
        btn.disabled = false;
      }, 2000);
    } else {
      // Both methods failed (e.g. non-HTTPS context) — surface URL for manual copy
      btn.disabled = false;
      prompt("請複製以下網址分享此搜尋：", url);
    }
  });

  // On page load: check how many listings match each saved search and show banner
  async function checkSavedSearchMatches(): Promise<void> {
    const searches = ssGetAll();
    if (searches.length === 0) return;

    let geojson: any;
    try {
      const res = await fetch(LISTINGS_URL);
      geojson = await res.json();
    } catch {
      return;
    }

    const features: any[] = geojson.features ?? [];
    const alerts: string[] = [];

    for (const s of searches) {
      const matches = features.filter((f: any) => {
        const p = f.properties;
        if (s.city         && p.city         !== s.city)                    return false;
        if (s.district     && p.district     !== s.district)                 return false;
        if (s.maxTotalPrice && p.totalPrice  > s.maxTotalPrice * 10000)     return false;
        if (s.maxUnitPrice  && p.unitPrice   > s.maxUnitPrice  * 10000)     return false;
        if (s.buildingType  && p.buildingType !== s.buildingType)            return false;
        return true;
      });
      if (matches.length > 0) {
        alerts.push(`<strong>${matches.length}</strong> 筆符合「${s.name}」`);
      }
    }

    const banner = document.getElementById("ss-alert-banner");
    if (!banner || alerts.length === 0) return;

    banner.innerHTML = `
      <div class="ss-alert-content">
        <span class="ss-alert-icon">🏠</span>
        <span>${alerts.join("；")}</span>
        <button class="ss-alert-close" aria-label="關閉">✕</button>
      </div>
    `;
    banner.style.display = "block";
    banner.querySelector(".ss-alert-close")?.addEventListener("click", () => {
      banner.style.display = "none";
    });
  }

  ssRender();
  checkSavedSearchMatches();
</script>

