---
---
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{Astro.props.title}</title>
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🏠</text></svg>" />
    <link href="https://unpkg.com/maplibre-gl@5.4.0/dist/maplibre-gl.css" rel="stylesheet" />
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }

      :root {
        --primary: #2563eb;
        --primary-hover: #1d4ed8;
        --bg: #f8fafc;
        --surface: #ffffff;
        --text: #1e293b;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --sidebar-width: 320px;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--bg);
        color: var(--text);
        height: 100vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }

      .header {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 12px 24px;
        display: flex;
        align-items: baseline;
        gap: 16px;
      }

      .header h1 { font-size: 1.25rem; }
      .subtitle { color: var(--text-muted); font-size: 0.875rem; }

      .data-freshness-badge {
        margin-left: auto;
        font-size: 0.75rem;
        color: var(--text-muted);
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 3px 10px;
        white-space: nowrap;
        flex-shrink: 0;
      }

      .stale-banner {
        background: #fef3c7;
        border-bottom: 1px solid #f59e0b;
        color: #92400e;
        font-size: 0.85rem;
        padding: 8px 24px;
        text-align: center;
      }
      .stale-banner a {
        color: #b45309;
        text-decoration: underline;
      }

      .main {
        display: flex;
        flex: 1;
        min-height: 0;
      }

      .sidebar {
        width: var(--sidebar-width);
        background: var(--surface);
        border-right: 1px solid var(--border);
        padding: 16px;
        overflow-y: auto;
        flex-shrink: 0;
      }

      .filter-group {
        margin-bottom: 16px;
      }

      .filter-group label {
        display: block;
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
      }

      .filter-group select,
      .filter-group input {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 0.9rem;
        background: var(--bg);
      }

      .range-inputs {
        display: flex;
        gap: 8px;
        align-items: center;
      }

      .range-inputs input { flex: 1; }
      .range-inputs span { color: var(--text-muted); }

      .search-btn {
        width: 100%;
        padding: 10px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        margin-bottom: 16px;
        transition: background 0.15s;
      }

      .search-btn:hover { background: var(--primary-hover); }

      .stats-panel {
        border-top: 1px solid var(--border);
        padding-top: 16px;
      }

      .stats-panel h3 {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-bottom: 8px;
      }

      .placeholder { color: var(--text-muted); font-size: 0.85rem; }

      .map-container {
        flex: 1;
        position: relative;
      }

      #map { width: 100%; height: 100%; }

      .maplibregl-popup-content {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        padding: 12px;
        border-radius: 8px;
        max-width: 280px;
      }

      .popup-title {
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 8px;
      }

      .popup-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        padding: 2px 0;
      }

      .popup-label { color: var(--text-muted); }
      .popup-value { font-weight: 500; }
      .popup-price { color: var(--primary); font-weight: 700; }

      .trend-panel {
        border-top: 1px solid var(--border);
        padding-top: 16px;
        margin-top: 8px;
      }
      .trend-panel h3 {
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-bottom: 8px;
      }
      .trend-note {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 4px;
        text-align: center;
      }

      /* Mobile-only elements hidden by default on desktop */
      .filter-toggle-btn {
        display: none;
        position: fixed;
        bottom: 28px;
        left: 16px;
        z-index: 500;
        align-items: center;
        gap: 6px;
        background: #2563eb;
        color: #fff;
        border: none;
        border-radius: 24px;
        padding: 10px 18px;
        font-size: 0.92rem;
        font-weight: 600;
        cursor: pointer;
        box-shadow: 0 4px 14px rgba(37,99,235,0.35);
      }
      .sidebar-close-btn {
        display: none;
        position: absolute;
        top: 10px;
        right: 12px;
        background: none;
        border: none;
        font-size: 1.3rem;
        cursor: pointer;
        color: #64748b;
        z-index: 1001;
      }

      @media (max-width: 768px) {
        .header {
          flex-wrap: wrap;
          gap: 4px 12px;
        }
        .data-freshness-badge {
          flex-basis: 100%;
          margin-left: 0;
          font-size: 0.7rem;
        }
        .main {
          flex-direction: column;
        }
        .sidebar {
          position: fixed;
          top: 0;
          left: 0;
          width: 80vw;
          max-width: 320px;
          height: 100vh;
          z-index: 1000;
          background: #fff;
          box-shadow: 4px 0 20px rgba(0,0,0,0.18);
          overflow-y: auto;
          transform: translateX(-100%);
          transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
          padding-top: 48px;
        }
        .sidebar.open {
          transform: translateX(0);
        }
        .sidebar-backdrop {
          display: none;
          position: fixed;
          inset: 0;
          background: rgba(0,0,0,0.35);
          z-index: 999;
        }
        .sidebar-backdrop.open {
          display: block;
        }
        .map-container {
          width: 100vw;
          height: calc(100vh - 60px);
          flex: none;
        }
        .filter-toggle-btn {
          display: flex !important;
        }
        .sidebar-close-btn {
          display: flex !important;
          min-width: 44px;
          min-height: 44px;
          align-items: center;
          justify-content: center;
          padding: 10px;
        }
        .sidebar input[type="text"],
        .sidebar input[type="number"],
        .sidebar input[type="date"],
        .sidebar input[type="datetime-local"],
        .sidebar input[type="time"],
        .sidebar input[type="email"],
        .sidebar input[type="tel"],
        .sidebar input[type="url"],
        .sidebar input[type="search"],
        .sidebar input[type="password"],
        .sidebar input:not([type]),
        .sidebar textarea,
        .sidebar select {
          min-height: 44px;
          /* 16px prevents iOS Safari auto-zoom on focus;
             note: min-height on <select> is ignored by iOS native picker,
             but is honoured on Android/desktop browsers */
          font-size: 16px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
