  /** Build a MapLibre fill-color expression from completionByDistrict counts. */
  function getCompletionFillColor(): any {
    if (!Object.keys(completionByDistrict).length) return "#d1d5db";
    const counts = Object.values(completionByDistrict);
    const max = Math.max(...counts, 1);
    const p25 = max * 0.25;
    const p50 = max * 0.5;
    const p75 = max * 0.75;
    return [
      "case",
      ["has", "completionCount"],
      [
        "interpolate", ["linear"],
        ["get", "completionCount"],
        0,    "#f0fdf4",
        p25,  "#86efac",
        p50,  "#f97316",
        p75,  "#ef4444",
        max,  "#7f1d1d",
      ],
      "#d1d5db",
    ];
  }

  function updateCompletionLegend(active: boolean, maxUnits?: number): void {
    const legend = document.getElementById("choropleth-legend");
    if (!legend) return;
    if (active && maxUnits) {
      const k = (v: number) => v >= 1000 ? `${(v / 1000).toFixed(1)}K` : String(Math.round(v));
      legend.innerHTML = `
        <div class="legend-title">📦 完工供給（近4季合計）</div>
        <div class="legend-items">
          <div class="legend-item"><span class="legend-swatch" style="background:#f0fdf4"></span>0（無完工）</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#86efac"></span>低（≤${k(maxUnits * 0.25)} 宅）</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#f97316"></span>中（≤${k(maxUnits * 0.5)} 宅）</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>高（≤${k(maxUnits * 0.75)} 宅）</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#7f1d1d"></span>極高（>${k(maxUnits * 0.75)} 宅）</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#d1d5db"></span>資料不足</div>
        </div>
        <div style="font-size:0.62rem;color:#94a3b8;margin-top:5px">各區均分（城市層級資料）</div>`;
    } else {
      // Restore to whichever legend is currently active (affordability or default price)
      updateAffordabilityLegend(affordabilityActive, affordabilityActive ? affordabilityThreshold / 10000 : undefined);
    }
  }

  /**
   * Distributes city-level rolling-annual 使照 units uniformly across all districts.
   * NOTE: E3030 only provides city-level data; all districts within a city receive an
   * equal share (cityTotal ÷ numDistricts). District-level variation requires the weighted
   * allocation model from E5010, which is future work once the ingest backend ships (#57).
   */
  function buildCompletionByDistrict(
    city: string,
    permitsData: { quarters: string[]; first_projected_quarter: string; cities: Record<string, { occupancy_permits: number[] }> }
  ): Record<string, number> {
    const cityData = permitsData.cities[city];
    if (!cityData) return {};
    const qi = permitsData.quarters.indexOf(permitsData.first_projected_quarter);
    // Use the most recent 4 historical quarters (rolling annual)
    const histEnd = qi >= 0 ? qi : permitsData.quarters.length;
    const histStart = Math.max(0, histEnd - 4);
    const cityTotal = cityData.occupancy_permits
      .slice(histStart, histEnd)
      .reduce((a, b) => a + b, 0);
    // Distribute proportionally among known districts for this city
    if (!districtGeoJSON?.features?.length) return {};
    const districtNames: string[] = districtGeoJSON.features.map(
      (f: any) => f.properties?.district as string
    ).filter(Boolean);
    const numDistricts = districtNames.length || 1;
    const perDistrict = Math.round(cityTotal / numDistricts);
    const result: Record<string, number> = {};
    for (const d of districtNames) result[d] = perDistrict;
    return result;
  }

  /** Compute median unit price per district from transaction features. */
  function computeDistrictMedians(features: any[]): Record<string, number> {
    const byDistrict: Record<string, number[]> = {};
    for (const f of features) {
      const d = f.properties?.district as string | undefined;
      const p = f.properties?.unitPrice as number | undefined;
      if (d && p && p > 0) {
        if (!byDistrict[d]) byDistrict[d] = [];
        byDistrict[d].push(p);
      }
    }
    const medians: Record<string, number> = {};
    for (const [d, prices] of Object.entries(byDistrict)) {
      const sorted = [...prices].sort((a, b) => a - b);
      medians[d] = sorted[Math.floor(sorted.length / 2)];
    }
    return medians;
  }

  /**
   * Compute building age statistics per district from rawAllFeatures, keyed by "city:district"
   * to handle same-name districts across cities (e.g., 中山區 in 台北市 / 基隆市).
   * Returns medianAge (-1 = no data), pctUnder20, hasPartialMissing.
   * Uses rawAllFeatures so stats reflect overall district character regardless of active filters.
   */
  function computeDistrictAgeStatsMap(): Record<string, { medianAge: number; pctUnder20: number; hasPartialMissing: boolean }> {
    const currentYear = new Date().getFullYear();
    const byKey: Record<string, { ages: number[]; totalFeatures: number }> = {};
    for (const f of rawAllFeatures) {
      const d = f.properties?.district as string | undefined;
      const c = f.properties?.city as string | undefined;
      if (!d) continue;
      const key = `${c ?? ""}:${d}`;
      if (!byKey[key]) byKey[key] = { ages: [], totalFeatures: 0 };
      byKey[key].totalFeatures++;
      const rawBY = f.properties?.buildYear ? Number(f.properties.buildYear) : null;
      if (!rawBY || rawBY <= 0) continue;
      const by = rawBY < 200 ? rawBY + 1911 : rawBY;
      const age = currentYear - by;
      if (age >= 0 && age < 200) byKey[key].ages.push(age);
    }
    const result: Record<string, { medianAge: number; pctUnder20: number; hasPartialMissing: boolean }> = {};
    for (const [key, { ages, totalFeatures }] of Object.entries(byKey)) {
      if (ages.length === 0) {
        result[key] = { medianAge: -1, pctUnder20: -1, hasPartialMissing: totalFeatures > 0 };
        continue;
      }
      // True median: average the two middle values for even-length arrays
      const sorted = [...ages].sort((a, b) => a - b);
      const mid = Math.floor(sorted.length / 2);
      const medianAge = sorted.length % 2 === 0
        ? Math.round((sorted[mid - 1] + sorted[mid]) / 2)
        : sorted[mid];
      const pctUnder20 = Math.round((ages.filter((a) => a < 20).length / ages.length) * 100);
      const hasPartialMissing = ages.length < totalFeatures;
      result[key] = { medianAge, pctUnder20, hasPartialMissing };
    }
    return result;
  }

  // Module-level cache of district age stats (refreshed by updateChoropleth after rawAllFeatures loads)
  let cachedDistrictAgeStatsMap: Record<string, { medianAge: number; pctUnder20: number; hasPartialMissing: boolean }> = {};

  /** Re-join district median prices into the district GeoJSON and update source. */
  function updateChoropleth(): void {
    const src = map.getSource("districts") as maplibregl.GeoJSONSource | undefined;
    if (!src || !districtGeoJSON || !currentTxGeojson) return;
    const medians = computeDistrictMedians(currentTxGeojson.features ?? []);

    // Pre-compute buyer scores for all districts (uses rawAllFeatures — unfiltered)
    const buyerScores: Record<string, number> = {};
    if (buyerScoreActive) {
      for (const f of districtGeoJSON.features) {
        const district = f.properties.district as string;
        const city = f.properties.city as string | undefined;
        const score = computeBuyerTimingScore(district, city);
        buyerScores[district] = score !== null ? score : -1;
      }
    }

    // Pre-compute volatility CV for all districts (uses rawAllFeatures — unfiltered)
    const volatilityCVs: Record<string, number> = {};
    // Always pre-compute CV when data is available — badge appears in all click popups
    if (rawAllFeatures.length > 0) {
      for (const f of districtGeoJSON.features) {
        const district = f.properties.district as string;
        const city = f.properties.city as string | undefined;
        const cv = computeVolatilityCV(district, city);
        // -1 = insufficient data sentinel; use city:district key to avoid collisions
        const key = `${city ?? ""}:${district}`;
        volatilityCVs[key] = cv !== null ? cv : -1;
      }
    }

    // Pre-compute MRT proximity premium for all districts
    // Always pre-computed so badge appears in all click popups; keyed by "city:district"
    const mrtPremiums: Record<string, number> = {};
    if (rawAllFeatures.length > 0 && mrtStations.length > 0) {
      for (const f of districtGeoJSON.features) {
        const district = f.properties.district as string;
        const city = f.properties.city as string | undefined;
        const key = `${city ?? ""}:${district}`;
        mrtPremiums[key] = computeMrtPremium(district, city);
      }
    }

    // Pre-compute pre-sale spread for all districts (always, so badge appears in all click popups)
    const presaleSpreads: Record<string, number> = {};
    if (rawAllFeatures.length > 0) {
      for (const f of districtGeoJSON.features) {
        const district = f.properties.district as string;
        const city = f.properties.city as string | undefined;
        const key = `${city ?? ""}:${district}`;
        const { spread } = computePresaleSpread(district, city);
        presaleSpreads[key] = spread !== null ? spread : -9999;
      }
    }

    // Pre-compute buyers market signal flags for hover tooltip (always, not gated on overlay mode)
    const buyersMarketFlags: Record<string, { qualifies: number; stale: number }> = {};
    const buyersMarketQualifyingKeys = new Set<string>();
    if (rawAllFeatures.length > 0) {
      for (const f of districtGeoJSON.features) {
        const district = f.properties?.district as string | undefined;
        const city = f.properties?.city as string | undefined;
        if (!district) continue;
        const sig = computeBuyersMarketSignal(district, city);
        // Key by "city:district" to match how ageStat and buyersMarketMarkers avoid collision
        const key = `${city ?? ""}:${district}`;
        buyersMarketFlags[key] = { qualifies: sig.qualifies ? 1 : 0, stale: sig.isStale ? 1 : 0 };
        if (sig.qualifies) buyersMarketQualifyingKeys.add(key);
      }
    }

    // Pre-compute district age stats (uses rawAllFeatures — unfiltered for consistent district overview)
    // Key by "city:district" to avoid cross-city collision for same-name districts.
    // Always refresh (even if rawAllFeatures is empty) so cleared data doesn't leave stale stats.
    cachedDistrictAgeStatsMap = rawAllFeatures.length > 0 ? computeDistrictAgeStatsMap() : {};

    const updated = {
      ...districtGeoJSON,
      features: districtGeoJSON.features.map((f: any) => {
        const district = f.properties.district as string;
        const city = f.properties.city as string | undefined;
        const completionCount = completionByDistrict[district];
        const ageStat = cachedDistrictAgeStatsMap[`${city ?? ""}:${district}`];
        const props: Record<string, any> = {
          ...f.properties,
          medianPrice: medians[district] ?? -1,
          // Only add completionCount when present so ["has","completionCount"] is a
          // reliable test — omitting it means the gray "資料不足" swatch is reachable
          ...(completionCount !== undefined ? { completionCount } : {}),
          // Age stats: -1 = no data; keyed by city to avoid cross-city name collisions
          medianAge: ageStat?.medianAge ?? -1,
          pctUnder20: ageStat?.pctUnder20 ?? -1,
          hasPartialMissingAge: ageStat?.hasPartialMissing ? 1 : 0,
          // Buyers market signal flags for hover tooltip
          buyersMarket: buyersMarketFlags[`${city ?? ""}:${district}`]?.qualifies ?? 0,
          buyersMarketStale: buyersMarketFlags[`${city ?? ""}:${district}`]?.stale ?? 0,
        };
        if (buyerScoreActive) {
          props.buyerScore = buyerScores[district] ?? -1;
        }
        props.volatilityCV  = volatilityCVs[`${city ?? ""}:${district}`] ?? -1;
        props.mrtPremium    = mrtPremiums[`${city ?? ""}:${district}`] ?? -9998;
        props.presaleSpread = presaleSpreads[`${city ?? ""}:${district}`] ?? -9999;
        return { ...f, properties: props };
      }),
    };
    src.setData(updated);
    // Re-apply overlay fill in priority order: completion > volatility > buyer-score > mrt-premium > presale-spread > affordability > default
    if (completionActive && map.getLayer("districts-fill")) {
      map.setPaintProperty("districts-fill", "fill-color", getCompletionFillColor());
    } else if (volatilityActive && map.getLayer("districts-fill")) {
      map.setPaintProperty("districts-fill", "fill-color", getVolatilityFillColor());
    } else if (buyerScoreActive && map.getLayer("districts-fill")) {
      map.setPaintProperty("districts-fill", "fill-color", getBuyerScoreFillColor());
    } else if (mrtPremiumActive && map.getLayer("districts-fill")) {
      map.setPaintProperty("districts-fill", "fill-color", getMrtPremiumFillColor());
    } else if (presaleSpreadActive && map.getLayer("districts-fill")) {
      map.setPaintProperty("districts-fill", "fill-color", getPresaleSpreadFillColor());
    }

    // Update pulsing ring markers for qualifying buyer's market districts
    updateBuyersMarketMarkers(buyersMarketQualifyingKeys);
  }

  /** Load district boundary GeoJSON for the given city. */
  async function loadDistrictBoundaries(city: string): Promise<void> {
    const url = CITY_DISTRICTS[city] ?? CITY_DISTRICTS["台北市"];
    try {
      const res = await fetch(url);
      districtGeoJSON = await res.json();
    } catch (e) {
      console.warn("[choropleth] district boundaries unavailable:", e);
      districtGeoJSON = null;
    }
    updateChoropleth();
  }

  // ---- Transaction loading ----
  async function loadTransactions(params: Record<string, string> = {}): Promise<any> {
    let geojson: any;

    try {
      if (API_BASE) {
        const qs = new URLSearchParams(params).toString();
        const url = `${API_BASE}/transactions/geojson${qs ? `?${qs}` : ""}`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        geojson = await res.json();
      } else {
        throw new Error("No API configured");
      }
    } catch {
      // Fall back to static sample data
      const res = await fetch(STATIC_DATA_URL);
      geojson = await res.json();

      // Cache full unfiltered features once for YoY computation (defensive slice — copy refs, not the array object)
      if (rawAllFeatures.length === 0 && geojson.features) {
        rawAllFeatures = geojson.features.slice();
      }

      // Client-side filtering
      if (params.city)         geojson.features = geojson.features.filter((f: any) => f.properties.city === params.city);
      if (params.district)    geojson.features = geojson.features.filter((f: any) => f.properties.district === params.district);
      if (params.minPrice)    geojson.features = geojson.features.filter((f: any) => f.properties.unitPrice >= Number(params.minPrice));
      if (params.maxPrice)    geojson.features = geojson.features.filter((f: any) => f.properties.unitPrice <= Number(params.maxPrice));
      if (params.buildingType) geojson.features = geojson.features.filter((f: any) => f.properties.buildingType === params.buildingType);
      if (params.dateFrom)  geojson.features = geojson.features.filter((f: any) => f.properties.date >= params.dateFrom);
      if (params.dateTo)    geojson.features = geojson.features.filter((f: any) => f.properties.date <= params.dateTo);
      if (params.totalPriceMin) geojson.features = geojson.features.filter((f: any) => f.properties.totalPrice >= Number(params.totalPriceMin) * 10000);
      if (params.totalPriceMax) geojson.features = geojson.features.filter((f: any) => f.properties.totalPrice <= Number(params.totalPriceMax) * 10000);
      if (params.areaMin) geojson.features = geojson.features.filter((f: any) => f.properties.areaPing >= Number(params.areaMin));
      if (params.areaMax) geojson.features = geojson.features.filter((f: any) => f.properties.areaPing <= Number(params.areaMax));
      if (params.address) {
        const keyword = params.address.toLowerCase();
        geojson.features = geojson.features.filter((f: any) => {
          const addr = (f.properties.address || "").toLowerCase();
          return addr.includes(keyword);
        });
      }
      // Building age filter (屋齡篩選)
      if (params.buildAgeRange || params.post921 === "1") {
        const currentYear = new Date().getFullYear(); // computed once for both age filters
        if (params.buildAgeRange) {
          geojson.features = geojson.features.filter((f: any) => {
            const rawBY = f.properties?.buildYear ? Number(f.properties.buildYear) : null;
            if (!rawBY || rawBY <= 0) return false; // exclude records without buildYear when filter active
            const by = rawBY < 200 ? rawBY + 1911 : rawBY; // ROC → Western year
            const age = currentYear - by;
            if (age < 0 || age >= 200) return false;
            switch (params.buildAgeRange) {
              case "0-5":   return age <= 5;
              case "5-20":  return age > 5  && age <= 20;
              case "20-40": return age > 20 && age < 40;  // excludes 40; "40+" is ≥40
              case "40+":   return age >= 40;              // 40年以上 includes exactly 40
              default:      return true;
            }
          });
        }
        // 921後興建 toggle: only show buildings completed in 2000+
        if (params.post921 === "1") {
          geojson.features = geojson.features.filter((f: any) => {
            const rawBY = f.properties?.buildYear ? Number(f.properties.buildYear) : null;
            if (!rawBY || rawBY <= 0) return false;
            const by = rawBY < 200 ? rawBY + 1911 : rawBY;
            return by >= 2000 && by <= currentYear;
          });
        }
      }
      // MRT proximity filter (straight-line Haversine distance to nearest station)
      if (params.mrtWalkMin) {
        const walkMinutes = Number(params.mrtWalkMin);
        // Guard against NaN from malformed URL params
        if (!isNaN(walkMinutes) && walkMinutes > 0) {
          // Walking speed ~80m/min => 5min=400m, 10min=800m, 15min=1200m
          const maxMetres = walkMinutes * 80;
          await loadMrtStations();
          if (mrtStations.length === 0) {
            console.warn("[mrt] Station data unavailable — MRT filter skipped");
          } else {
            geojson.features = geojson.features.filter((f: any) => {
              const coords = f.geometry?.coordinates;
              if (!Array.isArray(coords) || coords.length < 2) return true;
              const [lng, lat] = coords as [number, number];
              return distToNearestMrt(lng, lat) <= maxMetres;
            });
          }
        }
      }
    }

    currentTxGeojson = geojson;

    try {
      const source = map.getSource("transactions") as maplibregl.GeoJSONSource | undefined;
      if (source) {
        source.setData(geojson);
      } else {
        map.addSource("transactions", { type: "geojson", data: geojson });
        map.addLayer({
          id: "transactions-circles",
          type: "circle",
          source: "transactions",
          paint: {
            "circle-radius": [
              "interpolate", ["linear"], ["zoom"],
              10, 2, 14, 6, 18, 12,
            ],
            "circle-color": [
              "interpolate", ["linear"],
              ["get", "unitPrice"],
              200000, "#22c55e",
              400000, "#84cc16",
              600000, "#eab308",
              800000, "#f97316",
              1000000, "#ef4444",
              1500000, "#dc2626",
            ],
            "circle-opacity": 0.85,
            "circle-stroke-width": 1,
            "circle-stroke-color": "#ffffff",
            "circle-stroke-opacity": 0.5,
          },
        });
      }

      // Update stats panel
      const statsEl = document.getElementById("stats-content");
      if (statsEl && geojson.features) {
        const prices = geojson.features
          .map((f: any) => f.properties.unitPrice)
          .filter((p: any) => p != null && p > 0);
        if (prices.length > 0) {
          prices.sort((a: number, b: number) => a - b);
          const median = prices[Math.floor(prices.length / 2)];
          const avg = Math.round(prices.reduce((s: number, p: number) => s + p, 0) / prices.length);
          statsEl.innerHTML = `
            <div class="match-count">符合筆數：<strong>${geojson.features.length.toLocaleString()}</strong></div>
            <div class="popup-row">
              <span class="popup-label">中位數單價 (萬/坪)</span>
              <span class="popup-price">${formatPrice(median)}</span>
            </div>
            <div class="popup-row">
              <span class="popup-label">平均單價 (萬/坪)</span>
              <span class="popup-price">${formatPrice(avg)}</span>
            </div>
          `;
        } else {
          statsEl.innerHTML = `
          <div class="stats-empty-state">
            <div class="empty-state-icon">📊</div>
            <p class="empty-state-msg">目前篩選條件下無符合交易記錄。</p>
            <p class="empty-state-hint">試試調整篩選條件以查看統計資訊。</p>
          </div>`;
        }
      }

      // Update #yoy-panel: populate when district filter active, clear otherwise.
      // Single render path avoids duplicate YoY display (popup vs inline stats).
      // Stats panel gets both price YoY and volume badge; popups stay price-only via renderYoYHtml.
      document.dispatchEvent(new CustomEvent("yoy-signal", {
        detail: {
          html: params.district
            ? renderYoYHtml(params.district, params.city || undefined) +
              renderVolumeHtml(params.district, params.city || undefined)
            : "",
        },
      }));

      // Dispatch histogram event — pass raw prices in 万/坪; SVG renderer bins them at 5万 intervals
      const allPrices: number[] = (geojson.features ?? [])
        .map((f: any) => f.properties.unitPrice as number)
        .filter((p: any) => p != null && p > 0);
      document.dispatchEvent(new CustomEvent("stats-histogram", {
        detail: { pricesWan: allPrices.map((p: number) => p / 10000) },
      }));
    } catch (err) {
      console.error("Failed to update map layer:", err);
    }

    // Recompute choropleth colors with current data

    // Render transaction list
    const sortBy = (document.getElementById('sort-by') as HTMLSelectElement)?.value || 'date-desc';
    renderTransactionList(geojson.features || [], sortBy);
    updateChoropleth();
    return geojson;
  }

  // ---- Map load ----
  map.on("load", async () => {
    // 1. District fill + border layers FIRST (render below transaction dots)
    map.addSource("districts", {
      type: "geojson",
      data: { type: "FeatureCollection", features: [] },
    });

    map.addLayer({
      id: "districts-fill",
      type: "fill",
      source: "districts",
      paint: {
        "fill-color": [
          "case",
          ["<", ["coalesce", ["get", "medianPrice"], -1], 0],
          "#d1d5db",
          [
            "interpolate", ["linear"],
            ["get", "medianPrice"],
            300000,  "#22c55e",
            500000,  "#84cc16",
            700000,  "#eab308",
            900000,  "#f97316",
            1100000, "#ef4444",
            1400000, "#7c1010",
          ],
        ],
        "fill-opacity": 0.44,
      },
    });

    map.addLayer({
      id: "districts-line",
      type: "line",
      source: "districts",
      paint: {
        "line-color": "#475569",
        "line-width": 1.5,
        "line-opacity": 0.65,
      },
    });

    // 2. Load transactions — circles layer added ON TOP of district fill
    await loadTransactions();

    // 3. Fetch Taipei district boundaries initially
    await loadDistrictBoundaries("台北市");

    // 4. Load MRT stations layer (hidden initially, shown when filter active)
    await loadMrtStations();
    // Refresh choropleth now that MRT station data is available — the initial
    // updateChoropleth() call (step 3) ran before stations were loaded, so
    // mrtPremium properties were all -9998. Re-run to get real premium values.
    updateChoropleth();
    const mrtGeojson = {
      type: "FeatureCollection",
      features: mrtStations.map((st) => ({
        type: "Feature",
        geometry: { type: "Point", coordinates: [st.lng, st.lat] },
        properties: { name: st.name, line: st.line, lineZh: st.lineZh },
      })),
    };
    map.addSource("mrt-stations", { type: "geojson", data: mrtGeojson as any });
    map.addLayer({
      id: "mrt-stations-circles",
      type: "circle",
      source: "mrt-stations",
      layout: { visibility: "none" },
      paint: {
        "circle-radius": ["interpolate", ["linear"], ["zoom"], 10, 4, 14, 7, 18, 10],
        "circle-color": "#1d4ed8",
        "circle-opacity": 0.85,
        "circle-stroke-width": 1.5,
        "circle-stroke-color": "#ffffff",
      },
    });
    map.addLayer({
      id: "mrt-stations-labels",
      type: "symbol",
      source: "mrt-stations",
      layout: {
        visibility: "none",
        "text-field": ["get", "name"],
        "text-font": ["Open Sans Regular"],
        "text-size": 10,
        "text-offset": [0, 1.4],
        "text-anchor": "top",
        "text-optional": true,
      },
      paint: {
        "text-color": "#1e40af",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5,
      },
      minzoom: 13,
    });

    // 5. Inject legend into map container
    const legend = document.createElement("div");
    legend.id = "choropleth-legend";
    legend.className = "choropleth-legend";
    legend.innerHTML = `
      <div class="legend-title">行政區 中位數單價</div>
      <div class="legend-items">
        <div class="legend-item"><span class="legend-swatch" style="background:#22c55e"></span>&lt; 50萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#84cc16"></span>50–70萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#eab308"></span>70–90萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#f97316"></span>90–110萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>110–140萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#7c1010"></span>&gt; 140萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#d1d5db"></span>資料不足</div>
      </div>`;
    document.getElementById("map")!.appendChild(legend);
    // Signal that all Mapbox layers are registered so overlay restore can proceed
    document.dispatchEvent(new CustomEvent("map-layers-ready"));
  });

  // ---- Popup on transaction click ----
  map.on("click", "transactions-circles", (e) => {
    if (!e.features || e.features.length === 0) return;
    const props = e.features[0].properties;

    showTxModal(props);

    // Dispatch price-history trend for same district × building type
    const txDistrict = props.district as string | undefined;
    const txType     = props.buildingType as string | undefined;
    if (txDistrict) {
      const txFeatures = currentTxGeojson?.features ?? [];
      const quarterly: Record<string, number[]> = {};
      for (const f of txFeatures) {
        if (f.properties.district !== txDistrict) continue;
        if (txType && f.properties.buildingType !== txType) continue;
        const p = f.properties.unitPrice as number | undefined;
        const d = f.properties.date as string | undefined;
        if (!p || p <= 0 || !d) continue;
        const dt = new Date(d);
        if (isNaN(dt.getTime())) continue;
        const q = Math.floor(dt.getMonth() / 3) + 1;
        const key = `${dt.getFullYear()}-Q${q}`;
        (quarterly[key] ??= []).push(p);
      }
      const quarters = Object.keys(quarterly).sort();
      const medians = quarters.map((q) => {
        const arr = [...quarterly[q]].sort((a, b) => a - b);
        return arr[Math.floor(arr.length / 2)];
      });
      document.dispatchEvent(
        new CustomEvent('district-trend', {
          detail: { district: txDistrict, quarters, medians, buildingType: txType ?? '', source: 'dot' },
        })
      );
    }
  });

  // Cursor on transaction dots
  map.on("mouseenter", "transactions-circles", () => {
    map.getCanvas().style.cursor = "pointer";
  });
  map.on("mouseleave", "transactions-circles", () => {
    map.getCanvas().style.cursor = "";
  });

  // ---- HTML-escape helper (prevents XSS when interpolating GeoJSON properties into setHTML) ----
  function escHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"})[c]!);
  }

  // ---- Transaction detail modal ----
  function showTxModal(props: Record<string, any>): void {
    const backdrop = document.getElementById("tx-modal-backdrop");
    const titleEl  = document.getElementById("tx-modal-title");
    const bodyEl   = document.getElementById("tx-modal-body");
    if (!backdrop || !titleEl || !bodyEl) return;

    titleEl.textContent = props.address || "地址未登錄";

    // Parse transaction year safely (avoid timezone-skew by replacing - with /).
    // If date is absent or malformed, fall back to null so buildingAge shows "—" rather
    // than computing an age relative to the current calendar year.
    const parsedDate = props.date ? new Date(String(props.date).replace(/-/g, "/")) : null;
    const txYear     = parsedDate && !isNaN(parsedDate.getTime()) ? parsedDate.getFullYear() : null;
    // Treat sub-1911 buildYear values as ROC years and convert; still requires a valid txYear.
    const buildYearRaw = props.buildYear ? Number(props.buildYear) : null;
    const buildYear    = buildYearRaw && buildYearRaw > 0
      ? (buildYearRaw < 200 ? buildYearRaw + 1911 : buildYearRaw)  // ROC → Western
      : null;
    const rawAge       = txYear && buildYear ? txYear - buildYear : null;
    const buildingAge  = rawAge != null && rawAge >= 0 && rawAge < 200
      ? `${rawAge} 年 (${buildYear} 年建)`
      : "—";

    const floorText = props.floor && props.floorsTotal
      ? `${props.floor} 層 / 共 ${props.floorsTotal} 層`
      : props.floor
        ? `${props.floor} 層`
        : "—";

    const districtText = props.district
      ? `${props.city ? escHtml(String(props.city)) + "\u00a0" : ""}${escHtml(String(props.district))}`
      : "—";

    // Safe number formatter — returns "—" for NaN/null/0
    const safePrice = (v: any): string | null => {
      const n = parseFloat(String(v));
      return !isNaN(n) && n > 0 ? formatPrice(n) : null;
    };
    const safePing = (v: any): string | null => {
      const n = parseFloat(String(v));
      return !isNaN(n) && n > 0 ? `${n.toFixed(1)} 坪` : null;
    };

    type Row = { label: string; value: string; price?: boolean; rawHtml?: boolean };
    const rows: Row[] = [
      { label: "成交日期", value: props.date ? String(props.date) : "—" },
      { label: "總價",     value: safePrice(props.totalPrice) ?? "—", price: true },
      { label: "單價／坪", value: safePrice(props.unitPrice) ? `${safePrice(props.unitPrice)} ／坪` : "—", price: true },
      { label: "坪數",     value: safePing(props.areaPing) ?? "—" },
      { label: "樓層",     value: floorText },
      { label: "格局",     value: props.rooms ? `${props.rooms} 房` : "—" },
      { label: "屋齡",     value: buildingAge },
      { label: "建物型態", value: props.buildingType ? String(props.buildingType) : "—" },
      { label: "行政區",   value: districtText, rawHtml: true },
    ];

    bodyEl.innerHTML = rows.map((row) => {
      const displayVal = row.rawHtml ? row.value : escHtml(row.value);
      return `<div class="tx-detail-row">
        <span class="tx-detail-label">${escHtml(row.label)}</span>
        <span class="${row.price ? "tx-detail-price" : "tx-detail-value"}">${displayVal}</span>
      </div>`;
    }).join("");

    backdrop.removeAttribute("hidden");
    document.getElementById("tx-modal-close")?.focus();
  }

  function closeTxModal(): void {
    document.getElementById("tx-modal-backdrop")?.setAttribute("hidden", "");
  }

  // ---- Modal close handlers (all guarded via single registration flag) ----
  if (!(window as any).__txModalHandlersRegistered) {
    (window as any).__txModalHandlersRegistered = true;

    // Close on backdrop click (outside modal card)
    document.getElementById("tx-modal-backdrop")?.addEventListener("click", (e) => {
      if (e.target === e.currentTarget) closeTxModal();
    });
    // Close on ✕ button
    document.getElementById("tx-modal-close")?.addEventListener("click", closeTxModal);
    // Close on Escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        const backdrop = document.getElementById("tx-modal-backdrop");
        if (backdrop && !backdrop.hasAttribute("hidden")) closeTxModal();
      }
    });
    // Close when user pans/zooms so modal doesn't permanently occlude the map
    map.on("dragstart", closeTxModal);
    map.on("zoomstart", closeTxModal);
  }

  // ---- SVG sparkline helper ----
  /**
   * Renders an inline SVG sparkline for up to N quarterly price points.
   * Null entries create a visual gap — no line is drawn through those quarters.
   */
  function buildSparkline(values: (number | null)[], width = 204, height = 44): string {
    const W = width, H = height;
    const PX = 3, PY = 5; // padding
    const plotW = W - PX * 2;
    const plotH = H - PY * 2;
    const n = values.length;

    const nonNull = values.filter((v): v is number => v !== null && v > 0);
    if (nonNull.length === 0) {
      return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}"><text x="${W / 2}" y="${H / 2 + 3}" text-anchor="middle" font-size="9" fill="#94a3b8">暫無走勢資料</text></svg>`;
    }

    const yMin = Math.min(...nonNull);
    const yMax = Math.max(...nonNull);
    const yRange = yMax - yMin || 1;

    // Map each value to SVG coordinates; null → null
    const pts: ([number, number] | null)[] = values.map((v, i) => {
      if (v === null) return null;
      const x = PX + (n <= 1 ? plotW / 2 : (i / (n - 1)) * plotW);
      const y = PY + plotH - ((v - yMin) / yRange) * plotH;
      return [+x.toFixed(1), +y.toFixed(1)];
    });

    // Build contiguous polyline segments, breaking at null gaps
    const lines: string[] = [];
    let seg: [number, number][] = [];
    const flushSeg = () => {
      if (seg.length >= 2) {
        lines.push(`<polyline points="${seg.map((p) => p.join(",")).join(" ")}" fill="none" stroke="#3b82f6" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"/>`);
      } else if (seg.length === 1) {
        lines.push(`<circle cx="${seg[0][0]}" cy="${seg[0][1]}" r="2" fill="#3b82f6"/>`);
      }
      seg = [];
    };
    for (const pt of pts) {
      if (pt === null) { flushSeg(); } else { seg.push(pt); }
    }
    flushSeg();

    // Data-point dots overlaid on the lines
    const dots = pts
      .filter((p): p is [number, number] => p !== null)
      .map(([x, y]) => `<circle cx="${x}" cy="${y}" r="2.2" fill="#2563eb" stroke="white" stroke-width="1.2"/>`)
      .join("");

    return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" style="display:block;overflow:visible">${lines.join("")}${dots}</svg>`;
  }

  // ---- District click → sparkline popup + dispatch trend event ----
  let districtClickPopup: maplibregl.Popup | null = null;

  map.on("click", "districts-fill", (e) => {
    if (!e.features || e.features.length === 0) return;
    // Don't open district popup when clicking a transaction dot on top of the fill
    if (map.queryRenderedFeatures(e.point, { layers: ["transactions-circles"] }).length > 0) return;

    const district = e.features[0].properties.district as string;
    const txFeatures = currentTxGeojson?.features ?? [];

    // Group unit prices by quarter for this district
    const quarterly: Record<string, number[]> = {};
    for (const f of txFeatures) {
      if (f.properties.district !== district) continue;
      const p = f.properties.unitPrice as number | undefined;
      const d = f.properties.date as string | undefined;
      if (!p || p <= 0 || !d) continue;
      const dt = new Date(d);
      if (isNaN(dt.getTime())) continue;
      const q = Math.floor(dt.getMonth() / 3) + 1;
      const key = `${dt.getFullYear()}-Q${q}`;
      (quarterly[key] ??= []).push(p);
    }

    // Overall median for the filtered district (all quarters combined)
    const allPrices = Object.values(quarterly).flat().sort((a, b) => a - b);
    const medianPrice = allPrices.length ? allPrices[Math.floor(allPrices.length / 2)] : null;

    // Transactions in the last 6 months (近半年)
    const cutoff = new Date();
    cutoff.setMonth(cutoff.getMonth() - 6);
    const sixMonthCount = txFeatures.filter((f: any) => {
      if (f.properties.district !== district) return false;
      const d = f.properties.date as string | undefined;
      return d && new Date(d) >= cutoff;
    }).length;

    // Determine the 8-quarter window anchored at the latest quarter present in data
    const allSortedKeys = Object.keys(quarterly).sort();
    let anchorDate: Date;
    if (allSortedKeys.length > 0) {
      const [yr, qStr] = allSortedKeys[allSortedKeys.length - 1].split("-Q");
      anchorDate = new Date(Number(yr), (Number(qStr) - 1) * 3, 1);
    } else {
      anchorDate = new Date();
    }

    const last8: string[] = [];
    for (let i = 7; i >= 0; i--) {
      const d = new Date(anchorDate);
      d.setMonth(d.getMonth() - i * 3);
      const q = Math.floor(d.getMonth() / 3) + 1;
      last8.push(`${d.getFullYear()}-Q${q}`);
    }

    // Sparkline values: median per quarter, null if no transactions that quarter
    const sparkValues: (number | null)[] = last8.map((qk) => {
      const arr = quarterly[qk];
      if (!arr || arr.length === 0) return null;
      const sorted = [...arr].sort((a, b) => a - b);
      return sorted[Math.floor(sorted.length / 2)];
    });

    // Dispatch sidebar trend event (all quarters with data, sorted)
    const trendMedians = allSortedKeys.map((qk) => {
      const arr = [...quarterly[qk]].sort((a, b) => a - b);
      return arr[Math.floor(arr.length / 2)];
    });
    document.dispatchEvent(
      new CustomEvent("district-trend", { detail: { district, quarters: allSortedKeys, medians: trendMedians } })
    );

    // Get the clicked district's city from the feature properties (most reliable source)
    const clickedCity = (e.features[0].properties.city as string | undefined)
      || (document.getElementById("city-select") as HTMLSelectElement | null)?.value
      || "";

    // Dispatch price histogram for the selected district — last 12 months only.
    // Compute cutoff as local-time YYYY-MM-DD to avoid toISOString() UTC shift.
    // Subtract exactly 1 year and clamp day to avoid leap-year / month-length overflow.
    {
      const _n = new Date();
      const _y = _n.getFullYear() - 1, _m = _n.getMonth();
      const _maxDay = new Date(_y, _m + 1, 0).getDate(); // last day of target month
      const _d = Math.min(_n.getDate(), _maxDay);
      const _p = (n: number) => String(n).padStart(2, "0");
      const cutoff12mStr = `${_y}-${_p(_m + 1)}-${_p(_d)}`;
      const last12mPricesWan = txFeatures
        .filter((f: any) => {
          if (f.properties.district !== district) return false;
          if (clickedCity && f.properties.city && f.properties.city !== clickedCity) return false;
          const p = f.properties.unitPrice as number | undefined;
          if (!p || p <= 0) return false;
          const d = f.properties.date as string | undefined;
          return typeof d === "string" && /^\d{4}-\d{2}-\d{2}/.test(d) && d >= cutoff12mStr;
        })
        .map((f: any) => (f.properties.unitPrice as number) / 10000);
      document.dispatchEvent(new CustomEvent("stats-histogram", {
        detail: { pricesWan: last12mPricesWan, district, city: clickedCity },
      }));
    }

    // Compute activeCity once; reused for both yoy-signal dispatch and popup rendering.
    // Prefer city derived from transaction data for the clicked district (more reliable
    // than the dropdown when no city filter is active or the map spans multiple cities).
    const cityFromData = rawAllFeatures.find(
      (f) => f.properties?.district === district
    )?.properties?.city as string | undefined;
    const activeCity = clickedCity || cityFromData || undefined;
    const yoyHtml = renderYoYHtml(district, activeCity);

    // Buyers market banner (always computed — shown unconditionally when conditions met)
    const buyersMarketBannerHtml = renderBuyersMarketBannerHtml(district, activeCity);

    // Dispatch YoY+volume signal so #yoy-panel in the stats card updates on district click.
    // The popup itself (below) uses yoyHtml (price-only) to keep popup size compact.
    // Include buyers market banner in the sidebar panel when present.
    document.dispatchEvent(new CustomEvent("yoy-signal", {
      detail: { district, html: yoyHtml + renderVolumeHtml(district, activeCity) + buyersMarketBannerHtml },
    }));

    // Build popup HTML
    const medianWan = medianPrice ? (medianPrice / 10_000).toFixed(1) : "—";
    const hasSparkData = sparkValues.some((v) => v !== null);
    const sparkSection = hasSparkData
      ? `<div class="spark-wrap">
           <div class="spark-label">📈 季均價走勢 (萬/坪)</div>
           ${buildSparkline(sparkValues)}
           <div class="spark-axis-labels">
             <span>${last8[0]}</span><span>${last8[7]}</span>
           </div>
         </div>`
      : `<div class="popup-row" style="color:#94a3b8;font-size:0.76rem;margin-top:4px">走勢資料不足</div>`;

    // Build volume sparkline section
    const velData = computeMonthlyVelocity(district, activeCity);
    const volumeSparkSection = velData.hasData
      ? `<div class="velocity-spark-wrap">
           <div class="velocity-spark-label">📊 月成交量 (近12個月) <span class="velocity-trend-badge ${velData.trendClass}">${escHtml(velData.trendLabel)}</span></div>
           ${buildVolumeSparkline(velData.counts)}
           <div class="velocity-spark-axis">
             <span>${velData.months[0] ?? ""}</span><span>${velData.months[velData.months.length - 1] ?? ""}</span>
           </div>
         </div>`
      : `<div class="popup-row" style="color:#94a3b8;font-size:0.76rem;margin-top:4px">成交量資料不足</div>`;

    const pinCity = activeCity || "";
    const isPinned = pinnedDistricts.some((p) => p.district === district && p.city === pinCity);
    const atCap    = !isPinned && pinnedDistricts.length >= MAX_PINS;
    const pinBtnLabel = isPinned ? "✕ 移除比較" : atCap ? `📌 已達上限 (最多${MAX_PINS}個)` : "📌 加入比較";
    const pinBtnClass = `popup-pin-btn${isPinned ? " pinned" : ""}`;
    const pinBtnDisabled = atCap ? "disabled" : "";

    // Buyer score badge — always shown in click popup (badge row only shown when mode active)
    const buyerScoreClickHtml = buyerScoreActive
      ? renderBuyerScoreBadgeHtml(district, activeCity)
      : "";

    // Volatility badge — always shown in click popup
    // Use the clicked feature's city for volatility/combined-signal to avoid
    // cross-city collisions when activeCity is blank or a different city name.
    const featureCityForVolatility = (e.features[0].properties.city as string | undefined) ?? activeCity ?? undefined;
    const volatilityClickHtml = renderVolatilityBadgeHtml(district, featureCityForVolatility);
    // Combined signal callouts (最佳進場訊號 / caveat card)
    const combinedSignalHtml = renderVolatilityCombinedSignalHtml(district, featureCityForVolatility);

    // MRT premium badge — always shown in click popup
    const featureCityForMrt = (e.features[0].properties.city as string | undefined) ?? activeCity ?? undefined;
    const mrtPremiumClickHtml = renderMrtPremiumBadgeHtml(district, featureCityForMrt);

    // Pre-sale spread badge — always shown in click popup
    const featureCityForPresale = (e.features[0].properties.city as string | undefined) ?? activeCity ?? undefined;
    const presaleSpreadClickHtml = renderPresaleSpreadBadgeHtml(district, featureCityForPresale);

    // Building age stats for click popup — use the district feature's own city for cache lookup
    // (more reliable than activeCity which may be missing if city dropdown is blank).
    // No cross-city fallback: if the exact city:district key misses, skip the age block rather
    // than silently showing another city's stats for a same-name district.
    let ageClickHtml = "";
    {
      const featureCity = (e.features[0].properties.city as string | undefined) ?? activeCity ?? "";
      const ageStat = cachedDistrictAgeStatsMap[`${featureCity}:${district}`];
      if (ageStat && ageStat.medianAge >= 0) {
        const missingNote = ageStat.hasPartialMissing ? ` <span class="age-missing-note">部分資料缺失</span>` : "";
        ageClickHtml = `
          <div class="popup-row age-row" style="margin-top:6px">
            <span class="popup-label">屋齡中位數</span>
            <span class="popup-value"><strong>${ageStat.medianAge} 年</strong>${missingNote}</span>
          </div>
          <div class="popup-row" style="margin-bottom:2px">
            <span class="popup-label">屋齡分佈</span>
            <span class="popup-value"><span class="age-dist-badge">${ageStat.pctUnder20 >= 0 ? ageStat.pctUnder20 : "—"}% 屋齡&lt;20年</span></span>
          </div>`;
      }
    }

    districtClickPopup?.remove();
    districtClickPopup = new maplibregl.Popup({
      closeButton: true,
      closeOnClick: false,
      offset: [0, -6],
      className: "district-sparkline-popup",
      maxWidth: "280px",
    })
      .setLngLat(e.lngLat)
      .setHTML(
        `<div class="popup-title">${escHtml(district)}</div>
         ${buyersMarketBannerHtml}
         ${combinedSignalHtml}
         <div class="popup-row">
           <span class="popup-label">中位單價</span>
           <span class="popup-price">${medianWan} 萬/坪</span>
         </div>
         ${yoyHtml}
         ${buyerScoreClickHtml}
         ${volatilityClickHtml}
         ${mrtPremiumClickHtml}
         ${presaleSpreadClickHtml}
         ${ageClickHtml}
         ${sparkSection}
         ${volumeSparkSection}
         <div class="popup-row" style="margin-top:6px">
           <span class="popup-label">近半年成交</span>
           <span class="popup-value">${sixMonthCount} 筆</span>
         </div>
         <button class="${pinBtnClass}" data-district="${escHtml(district)}" data-city="${escHtml(pinCity)}" ${pinBtnDisabled}>${pinBtnLabel}</button>`
      )
      .addTo(map);

    // Wire pin button inside popup (after addTo — DOM is now live)
    const pinBtn = districtClickPopup.getElement()?.querySelector<HTMLButtonElement>(".popup-pin-btn");
    if (pinBtn) {
      pinBtn.addEventListener("click", (e) => {
        e.stopPropagation(); // prevent click bubbling to map (would close/replace the popup)
        const d = pinBtn.dataset.district ?? district;
        const c = pinBtn.dataset.city     ?? pinCity;
        togglePin(d, c);
        syncOpenPopupPinButton();
      });
    }

    // Wire "?" help button inside popup to open methodology tooltip
    districtClickPopup.getElement()?.querySelectorAll<HTMLButtonElement>(".buyer-score-help-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        openBuyerScoreTooltip();
      });
    });

    // Wire buyers market ⓘ button inside popup to open methodology tooltip
    districtClickPopup.getElement()?.querySelectorAll<HTMLButtonElement>(".buyers-market-info-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        openBuyersMarketTooltip();
      });
    });

    // Null the reference when the popup is dismissed via its own ✕ button
    districtClickPopup.on("close", () => { districtClickPopup = null; });
  });

  // Cursor on district polygons
  map.on("mouseenter", "districts-fill", () => {
    map.getCanvas().style.cursor = "pointer";
  });
  map.on("mouseleave", "districts-fill", () => {
    map.getCanvas().style.cursor = "";
  });

  // ---- District hover popup ----
  let districtHover: maplibregl.Popup | null = null;

  map.on("mousemove", "districts-fill", (e) => {
    if (!e.features || e.features.length === 0) return;
    const props = e.features[0].properties as Record<string, any>;
    if (!districtHover) {
      districtHover = new maplibregl.Popup({
        closeButton: false,
        closeOnClick: false,
        offset: 4,
      });
    }
    const priceHtml =
      props.medianPrice > 0
        ? (() => {
            const baseHtml = `<div class="popup-row"><span class="popup-label">中位數單價</span><span class="popup-price">${formatPrice(props.medianPrice)}/坪</span></div>`;
            if (affordabilityActive && affordabilityThreshold > 0) {
              let status: string;
              if (props.medianPrice <= affordabilityThreshold) {
                status = `<div class="popup-row" style="color:#16a34a;font-weight:600">✅ 可負擔</div>`;
              } else if (props.medianPrice <= affordabilityThreshold * 1.2) {
                status = `<div class="popup-row" style="color:#ca8a04;font-weight:600">⚠️ 邊緣</div>`;
              } else {
                status = `<div class="popup-row" style="color:#dc2626;font-weight:600">❌ 負擔重</div>`;
              }
              return baseHtml + status;
            }
            return baseHtml;
          })()
        : `<div class="popup-row"><span class="popup-label">資料不足</span></div>`;
    const completionHtml = completionActive && props.completionCount > 0
      ? `<div class="popup-row" style="margin-top:4px"><span class="popup-label">📦 完工供給（近4季）</span><span class="popup-price">${(props.completionCount as number).toLocaleString()} 宅</span></div>`
      : "";
    // Buyer score badge on hover: use pre-computed props.buyerScore (joined by updateChoropleth)
    // rather than calling computeBuyerTimingScore on every mousemove (O(n) per tick).
    let buyerScoreHtml = "";
    if (buyerScoreActive) {
      const score = props.buyerScore as number | undefined;
      if (score === undefined || score < 0) {
        buyerScoreHtml = `<div class="popup-row" style="margin-top:4px"><span class="popup-label">買方時機分</span><span class="buyer-score-insufficient">資料不足</span></div>`;
      } else {
        const { label, cls, emoji } = buyerScoreBucket(score);
        buyerScoreHtml = `<div class="popup-row" style="margin-top:4px"><span class="popup-label">買方時機分</span><span class="buyer-score-badge ${cls}">${emoji} ${label} ${score}/100</span></div>`;
      }
    }
    // Building age stats (pre-computed in updateChoropleth, uses rawAllFeatures)
    let ageHtml = "";
    {
      const medianAge = props.medianAge as number | undefined;
      const pctUnder20 = props.pctUnder20 as number | undefined;
      const hasPartialMissing = props.hasPartialMissingAge === 1;
      if (medianAge !== undefined && medianAge >= 0) {
        const distBadge = pctUnder20 !== undefined && pctUnder20 >= 0
          ? `<span class="age-dist-badge">${pctUnder20}% 屋齡&lt;20年</span>`
          : "";
        const missingNote = hasPartialMissing ? `<span class="age-missing-note">部分資料缺失</span>` : "";
        ageHtml = `<div class="popup-row age-row" style="margin-top:4px"><span class="popup-label">屋齡中位數</span><span class="popup-value">${medianAge} 年 ${distBadge}${missingNote}</span></div>`;
      }
    }
    // Volatility badge on hover: use pre-computed props.volatilityCV
    let volatilityHoverHtml = "";
    if (volatilityActive) {
      const cv = props.volatilityCV as number | undefined;
      if (cv === undefined || cv < 0) {
        volatilityHoverHtml = `<div class="popup-row" style="margin-top:4px"><span class="popup-label">價格波動度</span><span class="volatility-insufficient">資料不足</span></div>`;
      } else {
        const { label, cls, emoji } = volatilityTier(cv);
        volatilityHoverHtml = `<div class="popup-row" style="margin-top:4px"><span class="popup-label">波動度</span><span class="volatility-badge ${cls}">${emoji} ${label}</span></div>`;
      }
    }
    // Buyers market opportunity indicator on hover (first line)
    // Uses pre-computed props.buyersMarket flag (joined in updateChoropleth)
    // Shows stale variant when data is > 90 days old
    const bmOpportunityHtml = props.buyersMarket === 1
