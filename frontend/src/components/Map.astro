---
/**
 * MapLibre GL JS map component
 * Renders transaction dots + district choropleth layer
 */
---

<div id="map"></div>

<!-- Transaction detail modal / bottom sheet -->
<div id="tx-modal-backdrop" class="tx-modal-backdrop" hidden>
  <div id="tx-modal" class="tx-modal" role="dialog" aria-modal="true" aria-labelledby="tx-modal-title">
    <div class="tx-modal-header">
      <div id="tx-modal-title" class="tx-modal-title"></div>
      <button id="tx-modal-close" class="tx-modal-close" aria-label="關閉">✕</button>
    </div>
    <div id="tx-modal-body" class="tx-modal-body"></div>
  </div>
</div>

<!-- Cross-district comparison panel (fixed bottom bar) -->
<div id="comparison-panel" class="comparison-panel" aria-label="行政區比較面板" style="display:none">
  <div class="comparison-panel-header">
    <span class="comparison-panel-title">📊 行政區比較</span>
    <div class="comparison-panel-actions">
      <button id="comparison-clear-btn" class="comparison-clear-btn" aria-label="清除所有比較">清除全部</button>
      <button id="comparison-toggle-btn" class="comparison-toggle-btn" aria-label="收合比較面板">▼</button>
    </div>
  </div>
  <div id="comparison-panel-body" class="comparison-panel-body">
    <div class="comparison-table-wrap">
      <table id="comparison-table" class="comparison-table" aria-label="行政區指標比較表">
        <thead>
          <tr>
            <th class="comparison-metric-col">指標</th>
            <!-- district columns injected by JS -->
          </tr>
        </thead>
        <tbody>
          <!-- rows injected by JS -->
        </tbody>
      </table>
    </div>
    <p id="comparison-hint" class="comparison-hint">點擊地圖上的行政區，再按「📌 加入比較」即可比較最多 3 個行政區。</p>
  </div>
</div>

<!-- Buyer timing score methodology tooltip backdrop + popup (hidden by default) -->
<div id="buyer-score-tooltip-backdrop" class="buyer-score-tooltip-backdrop" hidden></div>
<div id="buyer-score-tooltip" class="buyer-score-tooltip" hidden>
  <h4>🧮 買方時機分 — 計算方法</h4>
  <table>
    <thead><tr><th>指標</th><th>權重</th><th>買方優勢條件</th></tr></thead>
    <tbody>
      <tr><td>房價年增率 (YoY)</td><td>40%</td><td>房價下跌 → 高分</td></tr>
      <tr><td>交易量年增率 (YoY)</td><td>30%</td><td>成交量萎縮 → 高分 (競爭少)</td></tr>
      <tr><td>現價 vs 3年均價</td><td>20%</td><td>低於歷史均價 → 高分</td></tr>
      <tr><td>距高峰月數</td><td>10%</td><td>高峰後越久 → 高分</td></tr>
    </tbody>
  </table>
  <div style="font-size:0.74rem;color:#64748b;margin-bottom:8px">
    🟢 70–100：強烈買方優勢（議價空間大）<br>
    🟡 40–69：均衡市場（有限議價空間）<br>
    🔴 0–39：賣方市場（買方不利）<br>
    <em>資料不足：近12個月成交量不足10筆</em>
  </div>
  <button class="close-tooltip-btn" id="close-buyer-score-tooltip">關閉</button>
</div>

<!-- 買方市場訊號 methodology tooltip backdrop + popup (hidden by default) -->
<div id="buyers-market-tooltip-backdrop" class="buyer-score-tooltip-backdrop" hidden></div>
<div id="buyers-market-tooltip" class="buyer-score-tooltip" hidden>
  <h4>⚡ 買方市場訊號 — 判斷依據</h4>
  <p style="font-size:0.8rem;color:#374151;margin-bottom:10px">以下三項條件需同時成立：</p>
  <table>
    <thead><tr><th>條件</th><th>門檻</th></tr></thead>
    <tbody>
      <tr><td>買方時機分</td><td>≥ 70（強烈買方優勢）</td></tr>
      <tr><td>房價年增率 (YoY)</td><td>&lt; −3%（價格下跌中）</td></tr>
      <tr><td>交易量趨勢</td><td>萎縮（成交量年減 &gt; 5%）</td></tr>
    </tbody>
  </table>
  <div style="font-size:0.74rem;color:#64748b;margin-bottom:8px">
    ⚠️ 資料不足門檻：近12個月成交量少於10筆時不顯示訊號。<br>
    ⚠️ 若最新資料超過90天，訊號僅供歷史參考。
  </div>
  <button class="close-tooltip-btn" id="close-buyers-market-tooltip">關閉</button>
</div>

<style is:global>
  /* Choropleth legend overlay */
  .choropleth-legend {
    position: absolute;
    bottom: 40px;
    right: 10px;
    background: rgba(255, 255, 255, 0.93);
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.78rem;
    z-index: 10;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }
  .legend-title {
    font-weight: 700;
    font-size: 0.72rem;
    color: #475569;
    margin-bottom: 7px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .legend-items { display: flex; flex-direction: column; gap: 4px; }
  .legend-item  { display: flex; align-items: center; gap: 6px; color: #334155; }
  .legend-swatch {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    flex-shrink: 0;
    opacity: 0.82;
    border: 1px solid rgba(0,0,0,0.08);
  }

  /* Match count badge */
  .match-count {
    font-size: 0.78rem;
    color: #64748b;
    margin-top: 4px;
    padding: 4px 0;
  }
  .match-count strong {
    color: #2563eb;
    font-weight: 700;
  }

  /* Toggle row in sidebar */
  .toggle-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding: 8px 10px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
  }
  .toggle-row input[type="checkbox"] {
    width: 15px;
    height: 15px;
    cursor: pointer;
    accent-color: #2563eb;
  }
  .toggle-row label {
    font-size: 0.85rem;
    color: #475569;
    cursor: pointer;
    margin-bottom: 0 !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    font-weight: 500;
  }

  /* ---- District sparkline popup ---- */
  .district-sparkline-popup {
    z-index: 1000;
  }
  .district-sparkline-popup .maplibregl-popup-content {
    padding: 10px 13px 10px;
    min-width: 210px;
    max-width: 275px;
    font-size: 0.82rem;
  }
  .spark-wrap {
    margin: 7px 0 4px;
    padding: 6px 0 4px;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
  }
  .spark-label {
    font-size: 0.7rem;
    color: #64748b;
    font-weight: 600;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .spark-axis-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.64rem;
    color: #94a3b8;
    margin-top: 3px;
  }
  @media (max-width: 400px) {
    .district-sparkline-popup .maplibregl-popup-content {
      min-width: 170px;
      max-width: 240px;
      font-size: 0.78rem;
    }
  }

  /* ---- 議價時機 YoY Trend Signal ---- */
  .yoy-signal {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .yoy-buyer   { color: #15803d; background: #f0fdf4; border: 1px solid #bbf7d0; }
  .yoy-neutral { color: #a16207; background: #fefce8; border: 1px solid #fde047; }
  .yoy-seller  { color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; }
  .yoy-insufficient { color: #94a3b8; font-size: 0.76rem; font-weight: 400; font-style: italic; }
  /* ---- 交易量 Volume YoY badge ---- */
  .volume-signal {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .volume-falling { color: #15803d; background: #f0fdf4; border: 1px solid #bbf7d0; }
  .volume-rising  { color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; }
  .volume-flat    { color: #a16207; background: #fefce8; border: 1px solid #fde047; }
  .volume-count-row {
    font-size: 0.76rem;
    color: #475569;
  }
  .volume-interp {
    font-size: 0.73rem;
    color: #64748b;
    font-style: italic;
    margin-top: 2px;
    padding-left: 2px;
  }

  /* ---- 成交量趨勢 Velocity sparkline ---- */
  .velocity-trend-badge {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .velocity-rising  { color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; }
  .velocity-falling { color: #15803d; background: #f0fdf4; border: 1px solid #bbf7d0; }
  .velocity-flat    { color: #a16207; background: #fefce8; border: 1px solid #fde047; }
  .velocity-na      { color: #94a3b8; font-size: 0.76rem; font-weight: 400; font-style: italic; }
  .velocity-spark-wrap {
    margin-top: 8px;
  }
  .velocity-spark-label {
    font-size: 0.73rem;
    color: #64748b;
    margin-bottom: 2px;
  }
  .velocity-spark-axis {
    display: flex;
    justify-content: space-between;
    font-size: 0.65rem;
    color: #94a3b8;
    margin-top: 1px;
  }

  /* ---- 買方時機分 Buyer Timing Score ---- */
  .buyer-score-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 5px;
    white-space: nowrap;
  }
  .buyer-score-green  { color: #15803d; background: #f0fdf4; border: 1px solid #86efac; }
  .buyer-score-yellow { color: #a16207; background: #fefce8; border: 1px solid #fde047; }
  .buyer-score-red    { color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; }
  .buyer-score-insufficient { color: #94a3b8; font-size: 0.76rem; font-weight: 400; font-style: italic; }

  /* ---- 價格波動度 Volatility Badge ---- */
  .volatility-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 5px;
    white-space: nowrap;
  }
  .volatility-stable   { color: #15803d; background: #f0fdf4; border: 1px solid #86efac; }
  .volatility-medium   { color: #a16207; background: #fefce8; border: 1px solid #fde047; }
  .volatility-high     { color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; }
  .volatility-insufficient { color: #94a3b8; font-size: 0.76rem; font-weight: 400; font-style: italic; }

  /* ---- MRT proximity premium badge ---- */
  .mrt-premium-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 5px;
    gap: 8px;
  }
  .mrt-premium-label {
    font-size: 0.76rem;
    color: #64748b;
    white-space: nowrap;
  }
  .mrt-premium-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 5px;
    white-space: nowrap;
  }
  .mrt-no-coverage  { color: #64748b; background: #f1f5f9; border: 1px solid #cbd5e1; font-weight: 400; }
  .mrt-insufficient { color: #94a3b8; font-size: 0.76rem; font-weight: 400; font-style: italic; }
  .mrt-neutral      { color: #78716c; background: #fefce8; border: 1px solid #fde047; }
  .mrt-low          { color: #92400e; background: #fffbeb; border: 1px solid #fde68a; }
  .mrt-medium       { color: #c2410c; background: #fff7ed; border: 1px solid #fed7aa; }
  .mrt-high         { color: #92400e; background: #fef3c7; border: 1px solid #fcd34d; }

  /* ---- Pre-sale spread badge ---- */
  .presale-spread-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 5px;
    gap: 8px;
  }
  .presale-spread-label {
    font-size: 0.76rem;
    color: #64748b;
    white-space: nowrap;
  }
  .presale-spread-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 5px;
    white-space: nowrap;
  }
  .presale-insufficient { color: #94a3b8; font-size: 0.76rem; font-weight: 400; font-style: italic; }
  .presale-premium-low     { color: #92400e; background: #fffbeb; border: 1px solid #fde68a; }
  .presale-premium-medium  { color: #c2410c; background: #fff7ed; border: 1px solid #fed7aa; }
  .presale-premium-high    { color: #7c2d12; background: #fef3c7; border: 1px solid #fcd34d; }
  .presale-discount        { color: #1d4ed8; background: #eff6ff; border: 1px solid #bfdbfe; }
  .presale-neutral         { color: #475569; background: #f8fafc; border: 1px solid #cbd5e1; font-weight: 400; }

  .volatility-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 5px;
    gap: 8px;
  }
  .volatility-row-label {
    font-size: 0.76rem;
    color: #64748b;
    white-space: nowrap;
  }
  /* Combined signal callout: 最佳進場訊號 */
  .best-entry-callout {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #f0fdf4;
    border: 1px solid #86efac;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 0.80rem;
    font-weight: 700;
    color: #15803d;
    margin-bottom: 6px;
  }
  /* Caveat card: high timing + high volatility warning */
  .volatility-caveat-card {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 0.76rem;
    color: #b91c1c;
    margin-bottom: 6px;
  }
  .buyer-score-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 5px;
    gap: 8px;
  }
  .buyer-score-row-label {
    font-size: 0.76rem;
    color: #64748b;
    white-space: nowrap;
  }
  /* Methodology tooltip popup */
  .buyer-score-tooltip {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 18px 20px;
    max-width: 340px;
    width: 92vw;
    z-index: 3000;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    font-size: 0.82rem;
    color: #334155;
  }
  .buyer-score-tooltip h4 {
    margin: 0 0 10px;
    font-size: 0.88rem;
    color: #1e293b;
  }
  .buyer-score-tooltip table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
    margin-bottom: 10px;
  }
  .buyer-score-tooltip th {
    background: #f8fafc;
    padding: 4px 6px;
    text-align: left;
    border-bottom: 1px solid #e2e8f0;
    font-weight: 600;
  }
  .buyer-score-tooltip td {
    padding: 4px 6px;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: top;
  }
  .buyer-score-tooltip .close-tooltip-btn {
    display: block;
    margin: 8px 0 0 auto;
    padding: 5px 14px;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 5px;
    font-size: 0.8rem;
    cursor: pointer;
  }
  .buyer-score-tooltip-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.22);
    z-index: 2999;
  }
  .yoy-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 5px 0;
    border-top: 1px solid #f1f5f9;
    margin-top: 6px;
    gap: 6px;
  }
  .yoy-row-label {
    font-size: 0.76rem;
    color: #64748b;
    font-weight: 500;
    flex-shrink: 0;
  }

  /* ---- 屋齡 age badge + missing note ---- */
  .age-dist-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.74rem;
    font-weight: 600;
    padding: 1px 6px;
    border-radius: 4px;
    background: #eff6ff;
    border: 1px solid #bfdbfe;
    color: #1d4ed8;
    white-space: nowrap;
    margin-left: 4px;
  }
  .age-missing-note {
    display: inline-flex;
    font-size: 0.68rem;
    color: #94a3b8;
    font-style: italic;
    margin-left: 4px;
  }
  .age-row .popup-value {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 2px;
  }

  /* ---- Transaction detail modal / bottom sheet ---- */
  .tx-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tx-modal-backdrop[hidden] { display: none !important; }

  .tx-modal {
    background: #fff;
    border-radius: 12px;
    max-width: 440px;
    width: 90%;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    animation: tx-slide-up 0.18s ease;
  }
  @keyframes tx-slide-up {
    from { transform: translateY(14px); opacity: 0.6; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  .tx-modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px 12px;
    border-bottom: 1px solid #e2e8f0;
  }
  .tx-modal-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.4;
    flex: 1;
  }
  .tx-modal-close {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: #94a3b8;
    cursor: pointer;
    padding: 0 4px;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .tx-modal-close:hover { color: #334155; }
  @media (max-width: 768px) {
    .tx-modal-close {
      min-width: 44px;
      min-height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 10px;
    }
  }

  .tx-modal-body { padding: 14px 20px 20px; }

  .tx-detail-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 0;
    border-bottom: 1px solid #f1f5f9;
    gap: 8px;
  }
  .tx-detail-row:last-child { border-bottom: none; }
  .tx-detail-label {
    font-size: 0.78rem;
    color: #64748b;
    font-weight: 500;
    flex-shrink: 0;
  }
  .tx-detail-value {
    font-size: 0.85rem;
    color: #1e293b;
    font-weight: 500;
    text-align: right;
  }
  .tx-detail-price {
    font-size: 0.93rem;
    color: #2563eb;
    font-weight: 700;
    text-align: right;
  }

  /* Mobile: full-width bottom sheet */
  @media (max-width: 640px) {
    .tx-modal-backdrop { align-items: flex-end; }
    .tx-modal {
      width: 100%;
      max-width: 100%;
      border-radius: 16px 16px 0 0;
      max-height: 75vh;
      animation: tx-slide-sheet 0.22s ease;
    }
    @keyframes tx-slide-sheet {
      from { transform: translateY(100%); }
      to   { transform: translateY(0); }
    }
  }

  /* ---- Cross-district comparison panel ---- */
  .comparison-panel {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 900;
    background: #fff;
    border-top: 2px solid #2563eb;
    box-shadow: 0 -4px 24px rgba(0,0,0,0.13);
    font-size: 0.85rem;
    transition: transform 0.22s ease;
  }
  .comparison-panel.collapsed .comparison-panel-body {
    display: none;
  }
  .comparison-panel.collapsed .comparison-toggle-btn {
    transform: rotate(180deg);
  }
  .comparison-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    background: #eff6ff;
    border-bottom: 1px solid #bfdbfe;
    cursor: pointer;
    user-select: none;
    min-height: 40px;
  }
  .comparison-panel-title {
    font-weight: 700;
    color: #1d4ed8;
    font-size: 0.9rem;
  }
  .comparison-panel-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .comparison-clear-btn {
    background: none;
