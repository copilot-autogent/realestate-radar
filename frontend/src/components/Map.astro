---
/**
 * MapLibre GL JS map component
 * Renders transaction dots + district choropleth layer
 */
---

<div id="map"></div>

<!-- Transaction detail modal / bottom sheet -->
<div id="tx-modal-backdrop" class="tx-modal-backdrop" hidden>
  <div id="tx-modal" class="tx-modal" role="dialog" aria-modal="true" aria-labelledby="tx-modal-title">
    <div class="tx-modal-header">
      <div id="tx-modal-title" class="tx-modal-title"></div>
      <button id="tx-modal-close" class="tx-modal-close" aria-label="關閉">✕</button>
    </div>
    <div id="tx-modal-body" class="tx-modal-body"></div>
  </div>
</div>

<style is:global>
  /* Choropleth legend overlay */
  .choropleth-legend {
    position: absolute;
    bottom: 40px;
    right: 10px;
    background: rgba(255, 255, 255, 0.93);
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.78rem;
    z-index: 10;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }
  .legend-title {
    font-weight: 700;
    font-size: 0.72rem;
    color: #475569;
    margin-bottom: 7px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .legend-items { display: flex; flex-direction: column; gap: 4px; }
  .legend-item  { display: flex; align-items: center; gap: 6px; color: #334155; }
  .legend-swatch {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    flex-shrink: 0;
    opacity: 0.82;
    border: 1px solid rgba(0,0,0,0.08);
  }

  /* Match count badge */
  .match-count {
    font-size: 0.78rem;
    color: #64748b;
    margin-top: 4px;
    padding: 4px 0;
  }
  .match-count strong {
    color: #2563eb;
    font-weight: 700;
  }

  /* Toggle row in sidebar */
  .toggle-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding: 8px 10px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
  }
  .toggle-row input[type="checkbox"] {
    width: 15px;
    height: 15px;
    cursor: pointer;
    accent-color: #2563eb;
  }
  .toggle-row label {
    font-size: 0.85rem;
    color: #475569;
    cursor: pointer;
    margin-bottom: 0 !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    font-weight: 500;
  }

  /* ---- District sparkline popup ---- */
  .district-sparkline-popup .maplibregl-popup-content {
    padding: 10px 13px 10px;
    min-width: 210px;
    max-width: 275px;
    font-size: 0.82rem;
  }
  .spark-wrap {
    margin: 7px 0 4px;
    padding: 6px 0 4px;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
  }
  .spark-label {
    font-size: 0.7rem;
    color: #64748b;
    font-weight: 600;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .spark-axis-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.64rem;
    color: #94a3b8;
    margin-top: 3px;
  }
  @media (max-width: 400px) {
    .district-sparkline-popup .maplibregl-popup-content {
      min-width: 170px;
      max-width: 240px;
      font-size: 0.78rem;
    }
  }

  /* ---- 議價時機 YoY Trend Signal ---- */
  .yoy-signal {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .yoy-buyer   { color: #15803d; background: #f0fdf4; border: 1px solid #bbf7d0; }
  .yoy-neutral { color: #a16207; background: #fefce8; border: 1px solid #fde047; }
  .yoy-seller  { color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; }
  .yoy-insufficient { color: #94a3b8; font-size: 0.76rem; font-weight: 400; font-style: italic; }
  /* ---- 交易量 Volume YoY badge ---- */
  .volume-signal {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 4px;
    white-space: nowrap;
  }
  .volume-falling { color: #15803d; background: #f0fdf4; border: 1px solid #bbf7d0; }
  .volume-rising  { color: #b91c1c; background: #fef2f2; border: 1px solid #fecaca; }
  .volume-flat    { color: #a16207; background: #fefce8; border: 1px solid #fde047; }
  .volume-count-row {
    font-size: 0.76rem;
    color: #475569;
  }
  .volume-interp {
    font-size: 0.73rem;
    color: #64748b;
    font-style: italic;
    margin-top: 2px;
    padding-left: 2px;
  }
  .yoy-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 5px 0;
    border-top: 1px solid #f1f5f9;
    margin-top: 6px;
    gap: 6px;
  }
  .yoy-row-label {
    font-size: 0.76rem;
    color: #64748b;
    font-weight: 500;
    flex-shrink: 0;
  }

  /* ---- Transaction detail modal / bottom sheet ---- */
  .tx-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .tx-modal-backdrop[hidden] { display: none !important; }

  .tx-modal {
    background: #fff;
    border-radius: 12px;
    max-width: 440px;
    width: 90%;
    max-height: 85vh;
    overflow-y: auto;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    animation: tx-slide-up 0.18s ease;
  }
  @keyframes tx-slide-up {
    from { transform: translateY(14px); opacity: 0.6; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  .tx-modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 20px 12px;
    border-bottom: 1px solid #e2e8f0;
  }
  .tx-modal-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.4;
    flex: 1;
  }
  .tx-modal-close {
    background: none;
    border: none;
    font-size: 1.1rem;
    color: #94a3b8;
    cursor: pointer;
    padding: 0 4px;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .tx-modal-close:hover { color: #334155; }

  .tx-modal-body { padding: 14px 20px 20px; }

  .tx-detail-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 0;
    border-bottom: 1px solid #f1f5f9;
    gap: 8px;
  }
  .tx-detail-row:last-child { border-bottom: none; }
  .tx-detail-label {
    font-size: 0.78rem;
    color: #64748b;
    font-weight: 500;
    flex-shrink: 0;
  }
  .tx-detail-value {
    font-size: 0.85rem;
    color: #1e293b;
    font-weight: 500;
    text-align: right;
  }
  .tx-detail-price {
    font-size: 0.93rem;
    color: #2563eb;
    font-weight: 700;
    text-align: right;
  }

  /* Mobile: full-width bottom sheet */
  @media (max-width: 640px) {
    .tx-modal-backdrop { align-items: flex-end; }
    .tx-modal {
      width: 100%;
      max-width: 100%;
      border-radius: 16px 16px 0 0;
      max-height: 75vh;
      animation: tx-slide-sheet 0.22s ease;
    }
    @keyframes tx-slide-sheet {
      from { transform: translateY(100%); }
      to   { transform: translateY(0); }
    }
  }
</style>

<script>
  import maplibregl from "maplibre-gl";

  const API_BASE = import.meta.env.DEV ? "/api" : "";
  const BASE_URL = import.meta.env.BASE_URL;
  const STATIC_DATA_URL = `${BASE_URL}data/sample-transactions.json`;
  const MRT_STATIONS_URL = `${BASE_URL}data/mrt-stations.json`;

  // ---- MRT station data (loaded once, concurrency-safe via promise cache) ----
  interface MrtStation {
    id: string;
    name: string;
    lat: number;
    lng: number;
    line: string;
    lineZh: string;
  }
  let mrtStations: MrtStation[] = [];
  let _mrtLoadPromise: Promise<void> | null = null;

  async function loadMrtStations(): Promise<void> {
    if (mrtStations.length > 0) return;
    if (_mrtLoadPromise) return _mrtLoadPromise;
    _mrtLoadPromise = (async () => {
      try {
        const res = await fetch(MRT_STATIONS_URL);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        if (!Array.isArray(data) || data.length === 0) throw new Error("Empty or invalid station data");
        mrtStations = data;
      } catch (e) {
        console.warn("[mrt] Failed to load mrt-stations.json:", e);
        // Clear promise so next call can retry
        _mrtLoadPromise = null;
      }
    })();
    return _mrtLoadPromise;
  }

  /** Haversine distance in metres between two lat/lng points. */
  function haversineMetres(lat1: number, lng1: number, lat2: number, lng2: number): number {
    const R = 6371000;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLng = (lng2 - lng1) * Math.PI / 180;
    const a = Math.sin(dLat / 2) ** 2 +
              Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
              Math.sin(dLng / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  /**
   * Returns straight-line distance in metres from [lng, lat] to nearest MRT station.
   * Returns Infinity when station data is unavailable (fails closed — no false matches).
   * Note: straight-line distance; actual walking distances may be longer near rivers/hills.
   * When station data fails to load, the filter is skipped (fail-open: shows all results)
   * rather than showing an empty map. This is a deliberate UX trade-off.
   */
  function distToNearestMrt(lng: number, lat: number): number {
    if (mrtStations.length === 0) return Infinity;
    let minDist = Infinity;
    for (const st of mrtStations) {
      const d = haversineMetres(lat, lng, st.lat, st.lng);
      if (d < minDist) minDist = d;
    }
    return minDist;
  }

  const CITY_DISTRICTS: Record<string, string> = {
    "台北市": `${BASE_URL}data/taipei-districts.geojson`,
    "新北市": `${BASE_URL}data/xinbei-districts.geojson`,
    "桃園市": `${BASE_URL}data/taoyuan-districts.geojson`,
    "台中市": `${BASE_URL}data/taichung-districts.geojson`,
    "台南市": `${BASE_URL}data/tainan-districts.geojson`,
    "高雄市": `${BASE_URL}data/kaohsiung-districts.geojson`,
  };

  const CITY_CENTERS: Record<string, { center: [number, number]; zoom: number }> = {
    "台北市": { center: [121.5654, 25.033], zoom: 12 },
    "新北市": { center: [121.460, 25.012], zoom: 11 },
    "桃園市": { center: [121.250, 24.970], zoom: 11 },
    "台中市": { center: [120.684, 24.138], zoom: 11 },
    "台南市": { center: [120.200, 23.000], zoom: 11 },
    "高雄市": { center: [120.300, 22.630], zoom: 11 },
  };

  // Center on Taipei
  const map = new maplibregl.Map({
    container: "map",
    style: {
      version: 8,
      name: "Real Price Radar",
      sources: {
        osm: {
          type: "raster",
          tiles: ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
          tileSize: 256,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        },
      },
      layers: [
        {
          id: "osm-tiles",
          type: "raster",
          source: "osm",
          minzoom: 0,
          maxzoom: 19,
        },
      ],
    },
    center: [121.5654, 25.033],
    zoom: 12,
    maxBounds: [[119, 21.5], [123, 26.5]],
  });

  map.addControl(new maplibregl.NavigationControl(), "top-right");
  map.addControl(new maplibregl.ScaleControl({ maxWidth: 200 }));

  // ---- Helpers ----
  function formatPrice(price: number): string {
    if (price >= 100_000_000) return `${(price / 100_000_000).toFixed(1)} 億`;
    if (price >= 10_000) return `${(price / 10_000).toFixed(0)} 萬`;
    return price.toLocaleString();
  }

  // ---- Choropleth state ----
  let districtGeoJSON: any = null;
  let currentTxGeojson: any = null;

  // ---- Full unfiltered transaction features (cached once on first static load) ----
  let rawAllFeatures: any[] = [];

  // ---- 議價時機 YoY Trend Signal ----
  /**
   * Computes rolling 12-month YoY median unit-price change for a district.
   * Anchors to the latest date present in rawAllFeatures for that district.
   * Optionally scoped by city to avoid cross-city district-name collisions.
   * Requires ≥3 transactions in both the recent and prior 12-month windows.
   */
  function computeYoYSignal(district: string, city?: string): {
    tier: "buyer" | "neutral" | "seller" | "insufficient";
    pct: number | null;
    label: string;
    arrow: string;
    badge: string;
  } {
    const MIN_SAMPLES = 3;
    const THRESHOLD_PCT = 3;

    const features = rawAllFeatures.filter(
      (f) =>
        f.properties?.district === district &&
        (f.properties?.unitPrice as number) > 0 &&
        (!city || f.properties?.city === city)
    );

    const validTimes = features
      .map((f) => new Date(f.properties.date as string).getTime())
      .filter((t) => !isNaN(t));

    if (validTimes.length < MIN_SAMPLES * 2) {
      return { tier: "insufficient", pct: null, label: "資料不足", arrow: "", badge: "" };
    }

    // Use reduce to avoid RangeError on very large arrays (spread is stack-limited)
    const maxTime = validTimes.reduce((a, b) => (a > b ? a : b), -Infinity);

    // Recent 12mo: (maxDate-12mo, maxDate]
    const cutRecent = new Date(maxTime);
    cutRecent.setFullYear(cutRecent.getFullYear() - 1);

    // Prior 12mo: (maxDate-24mo, maxDate-12mo]
    const cutPrior = new Date(maxTime);
    cutPrior.setFullYear(cutPrior.getFullYear() - 2);

    const toTime = (f: any) => new Date(f.properties.date as string).getTime();

    const recentPrices = features
      .filter((f) => { const t = toTime(f); return t > cutRecent.getTime() && t <= maxTime; })
      .map((f) => f.properties.unitPrice as number);

    const priorPrices = features
      .filter((f) => { const t = toTime(f); return t > cutPrior.getTime() && t <= cutRecent.getTime(); })
      .map((f) => f.properties.unitPrice as number);

    if (recentPrices.length < MIN_SAMPLES || priorPrices.length < MIN_SAMPLES) {
      return { tier: "insufficient", pct: null, label: "資料不足", arrow: "", badge: "" };
    }

    const median = (arr: number[]) => {
      const s = [...arr].sort((a, b) => a - b);
      const mid = Math.floor(s.length / 2);
      // True median: average two middle values for even-length arrays
      return s.length % 2 === 0 ? (s[mid - 1] + s[mid]) / 2 : s[mid];
    };

    const pct = ((median(recentPrices) - median(priorPrices)) / median(priorPrices)) * 100;

    if (pct < -THRESHOLD_PCT) {
      return { tier: "buyer",   pct, label: "買方有利", arrow: "▼", badge: "🟢" };
    } else if (pct > THRESHOLD_PCT) {
      return { tier: "seller",  pct, label: "賣方有利", arrow: "▲", badge: "🔴" };
    } else {
      return { tier: "neutral", pct, label: "持平",     arrow: pct >= 0 ? "▲" : "▼", badge: "🟡" };
    }
  }

  /**
   * Computes rolling 12-month YoY transaction volume (count) change for a district.
   * Scans rawAllFeatures (the full unfiltered dataset) so the signal reflects the
   * true district market regardless of active price/date filters — consistent with
   * the computeYoYSignal price approach.
   * Anchors to the district's latest transaction date (same as computeYoYSignal).
   * Requires ≥10 transactions in both the recent and prior 12-month windows.
   */
  function computeVolumeYoYSignal(district: string, city?: string): {
    tier: "falling" | "rising" | "flat" | "insufficient";
    count12mo: number;
    pct: number | null;
    label: string;
    arrow: string;
  } {
    const MIN_SAMPLES = 10;
    const THRESHOLD_PCT = 5;

    const features = rawAllFeatures.filter(
      (f) =>
        f.properties?.district === district &&
        (!city || f.properties?.city === city)
    );

    const validTimes = features
      .map((f) => new Date((f.properties?.date as string) ?? "").getTime())
      .filter((t) => !isNaN(t));

    if (validTimes.length === 0) {
      return { tier: "insufficient", count12mo: 0, pct: null, label: "資料不足", arrow: "" };
    }

    const maxTime = validTimes.reduce((a, b) => (a > b ? a : b), -Infinity);

    // Use setFullYear (conventional "same day N years ago") — matches computeYoYSignal.
    // Both windows are relative to maxTime (district's latest tx), matching price-YoY anchor.
    const cutRecent = new Date(maxTime);
    cutRecent.setFullYear(cutRecent.getFullYear() - 1);

    const cutPrior = new Date(maxTime);
    cutPrior.setFullYear(cutPrior.getFullYear() - 2);

    const toTime = (f: any) => new Date((f.properties?.date as string) ?? "").getTime();

    const count12mo = features.filter(
      (f) => { const t = toTime(f); return !isNaN(t) && t > cutRecent.getTime() && t <= maxTime; }
    ).length;

    const countPrior12mo = features.filter(
      (f) => { const t = toTime(f); return !isNaN(t) && t > cutPrior.getTime() && t <= cutRecent.getTime(); }
    ).length;

    if (count12mo < MIN_SAMPLES || countPrior12mo < MIN_SAMPLES) {
      return { tier: "insufficient", count12mo, pct: null, label: "資料不足", arrow: "" };
    }

    const pct = ((count12mo - countPrior12mo) / countPrior12mo) * 100;

    if (pct < -THRESHOLD_PCT) {
      return { tier: "falling", count12mo, pct, label: "成交量下降，議價空間擴大", arrow: "↓" };
    } else if (pct > THRESHOLD_PCT) {
      return { tier: "rising",  count12mo, pct, label: "成交量上升，買方競爭增加", arrow: "↑" };
    } else {
      return { tier: "flat",    count12mo, pct, label: "成交量持平",               arrow: "→" };
    }
  }

  /**
   * Renders the volume YoY badge HTML for the stats panel (sidebar only — not used in popups).
   * Called by callers that compose stats-panel HTML; renderYoYHtml stays price-only for popup use.
   */
  function renderVolumeHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const vol = computeVolumeYoYSignal(district, city);
    if (vol.tier === "insufficient") {
      return `<div class="yoy-row"><span class="yoy-row-label">本區交易量 (近12個月)</span><span class="yoy-insufficient">資料不足</span></div>`;
    }
    const pctStr = (vol.pct! >= 0 ? "+" : "") + vol.pct!.toFixed(1);
    return `
      <div class="yoy-row volume-count-row"><span class="yoy-row-label">本區交易量 (近12個月)</span><span>${vol.count12mo} 筆</span></div>
      <div class="yoy-row"><span class="yoy-row-label">較去年同期</span><span class="volume-signal volume-${vol.tier}">${vol.arrow} ${pctStr}%</span></div>
      <div class="volume-interp">${vol.label}</div>`;
  }

  /** Renders the price YoY signal as an HTML row string for use in popups and the stats panel. */
  function renderYoYHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const sig = computeYoYSignal(district, city);
    if (sig.tier === "insufficient") {
      return `<div class="yoy-row"><span class="yoy-row-label">議價時機</span><span class="yoy-insufficient">資料不足</span></div>`;
    }
    const pctStr = Math.abs(sig.pct!).toFixed(1);
    return `<div class="yoy-row"><span class="yoy-row-label">議價時機</span><span class="yoy-signal yoy-${sig.tier}">${sig.badge} ${sig.label} ${sig.arrow}${pctStr}% YoY</span></div>`;
  }

  // ---- Affordability overlay state ----
  let affordabilityActive = false;
  let affordabilityThreshold = 0; // TWD per ping

  // ---- Completion overlay state ----
  let completionActive = false;
  /** District-level rolling-annual completion counts (uses proportional city allocation). */
  let completionByDistrict: Record<string, number> = {};

  const DEFAULT_FILL_COLOR: any = [
    "case",
    ["<", ["coalesce", ["get", "medianPrice"], -1], 0],
    "#d1d5db",
    [
      "interpolate", ["linear"],
      ["get", "medianPrice"],
      300000,  "#22c55e",
      500000,  "#84cc16",
      700000,  "#eab308",
      900000,  "#f97316",
      1100000, "#ef4444",
      1400000, "#7c1010",
    ],
  ];

  function getAffordabilityFillColor(threshold: number): any {
    return [
      "case",
      ["<", ["coalesce", ["get", "medianPrice"], -1], 0], "#d1d5db",
      ["<=", ["get", "medianPrice"], threshold], "#22c55e",
      ["<=", ["get", "medianPrice"], threshold * 1.2], "#eab308",
      "#ef4444",
    ];
  }

  function updateAffordabilityLegend(active: boolean, thresholdWan?: number): void {
    const legend = document.getElementById("choropleth-legend");
    if (!legend) return;
    if (active && thresholdWan !== undefined) {
      const borderlineWan = (thresholdWan * 1.2).toFixed(0);
      legend.innerHTML = `
        <div class="legend-title">可負擔性地圖</div>
        <div class="legend-items">
          <div class="legend-item"><span class="legend-swatch" style="background:#22c55e"></span>可負擔 (≤${thresholdWan.toFixed(0)}萬/坪)</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#eab308"></span>邊緣 (≤${borderlineWan}萬/坪)</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>負擔重 (&gt;${borderlineWan}萬/坪)</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#d1d5db"></span>資料不足</div>
        </div>`;
    } else {
      legend.innerHTML = `
        <div class="legend-title">行政區 中位數單價</div>
        <div class="legend-items">
          <div class="legend-item"><span class="legend-swatch" style="background:#22c55e"></span>&lt; 50萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#84cc16"></span>50–70萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#eab308"></span>70–90萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#f97316"></span>90–110萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>110–140萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#7c1010"></span>&gt; 140萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#d1d5db"></span>資料不足</div>
        </div>`;
    }
  }

  /** Build a MapLibre fill-color expression from completionByDistrict counts. */
  function getCompletionFillColor(): any {
    if (!Object.keys(completionByDistrict).length) return "#d1d5db";
    const counts = Object.values(completionByDistrict);
    const max = Math.max(...counts, 1);
    const p25 = max * 0.25;
    const p50 = max * 0.5;
    const p75 = max * 0.75;
    return [
      "case",
      ["has", "completionCount"],
      [
        "interpolate", ["linear"],
        ["get", "completionCount"],
        0,    "#f0fdf4",
        p25,  "#86efac",
        p50,  "#f97316",
        p75,  "#ef4444",
        max,  "#7f1d1d",
      ],
      "#d1d5db",
    ];
  }

  function updateCompletionLegend(active: boolean, maxUnits?: number): void {
    const legend = document.getElementById("choropleth-legend");
    if (!legend) return;
    if (active && maxUnits) {
      const k = (v: number) => v >= 1000 ? `${(v / 1000).toFixed(1)}K` : String(Math.round(v));
      legend.innerHTML = `
