      <div class="legend-items">
        <div class="legend-item"><span class="legend-swatch" style="background:#22c55e"></span>&lt; 50萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#84cc16"></span>50–70萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#eab308"></span>70–90萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#f97316"></span>90–110萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>110–140萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#7c1010"></span>&gt; 140萬/坪</div>
