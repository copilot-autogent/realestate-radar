  let buyersMarketMarkers: Map<string, maplibregl.Marker> = new Map();

  /**
   * Evaluates whether a district currently shows the 「買方市場」 signal.
   * All three conditions must hold simultaneously:
   *   1. Buyer timing score ≥ 70 (also enforces ≥10 tx data-sufficiency gate)
   *   2. YoY price change < −3% (tier === "buyer")
   *   3. Transaction volume trend = falling (萎縮)
   *
   * Also checks data staleness: if the district's latest transaction is > 90 days
   * old, `isStale` is true and the banner shows a reduced-confidence warning instead.
   *
   * Returns `isDataSufficient: false` only when the ≥10 tx gate fails (score === null).
   */
  function computeBuyersMarketSignal(district: string, city?: string): {
    qualifies: boolean;
    isDataSufficient: boolean;
    isStale: boolean;
  } {
    const STALE_DAYS = 90;

    // Condition 1 + data-sufficiency gate (computeBuyerTimingScore returns null when < 10 tx)
    const score = computeBuyerTimingScore(district, city);
    if (score === null) return { qualifies: false, isDataSufficient: false, isStale: false };

    // Staleness: find the district's latest transaction date
    const features = rawAllFeatures.filter(
      (f) => f.properties?.district === district && (!city || f.properties?.city === city)
    );
    const validTimes = features
      .map((f) => new Date((f.properties?.date as string) ?? "").getTime())
      .filter((t) => !isNaN(t));
    const maxTime = validTimes.length > 0
      ? validTimes.reduce((a, b) => (a > b ? a : b), -Infinity)
      : -Infinity;
    const isStale = maxTime !== -Infinity
      && (Date.now() - maxTime) > STALE_DAYS * 24 * 60 * 60 * 1000;

    if (score < 70) return { qualifies: false, isDataSufficient: true, isStale };

    // Condition 2: YoY price decline > 3%
    const yoy = computeYoYSignal(district, city);
    if (yoy.tier !== "buyer") return { qualifies: false, isDataSufficient: true, isStale };

    // Condition 3: transaction volume falling (萎縮)
    const vol = computeVolumeYoYSignal(district, city);
    if (vol.tier !== "falling") return { qualifies: false, isDataSufficient: true, isStale };

    return { qualifies: true, isDataSufficient: true, isStale };
  }

  /**
   * Renders the 「買方市場訊號」 banner HTML for the click popup and sidebar panel.
   * Returns empty string when the district doesn't qualify.
