  // ---- Pre-sale spread (預售屋 vs 成屋) functions ----

  /**
   * Computes rolling 12-month average unit price for 預售屋 vs 成屋 in a district.
   * Returns the spread percentage: (presale - existing) / existing * 100.
   * Sentinel values: null = insufficient data (< 5 tx either side).
   * Min gate: ≥5 transactions in each category.
   */
  function computePresaleSpread(district: string, city?: string): {
    spread: number | null;
    presaleAvg: number | null;
    existingAvg: number | null;
    presaleCount: number;
    existingCount: number;
  } {
    if (!rawAllFeatures.length) {
      return { spread: null, presaleAvg: null, existingAvg: null, presaleCount: 0, existingCount: 0 };
    }

    // Find anchor date for rolling 12-month window
    const allDates = rawAllFeatures
      .filter((f) => f.properties?.district === district && (!city || f.properties?.city === city))
      .map((f) => new Date((f.properties?.date as string) ?? "").getTime())
      .filter((t) => !isNaN(t));

    if (!allDates.length) {
      return { spread: null, presaleAvg: null, existingAvg: null, presaleCount: 0, existingCount: 0 };
    }

    const maxTime = Math.max(...allDates);
    const cutoff = maxTime - 365 * 24 * 60 * 60 * 1000;

    const recent = rawAllFeatures.filter((f) => {
      if (f.properties?.district !== district) return false;
      if (city && f.properties?.city !== city) return false;
      const t = new Date((f.properties?.date as string) ?? "").getTime();
      if (isNaN(t) || t < cutoff) return false;
      const up = f.properties?.unitPrice as number;
      return typeof up === "number" && up > 0;
    });

    // Separate by transaction type
    // 預售屋 = pre-sale; anything else with a unit price = 成屋 (broadest interpretation)
    const presale: number[] = [];
    const existing: number[] = [];

    for (const f of recent) {
      const txType = f.properties?.transactionType as string | undefined;
      const buildType = f.properties?.buildingType as string | undefined;
      const price = f.properties?.unitPrice as number;

      // Pre-sale: explicit transactionType = "預售屋" OR buildingType contains "預售"
      const isPresale =
        txType === "預售屋" ||
        (buildType ?? "").includes("預售");

      if (isPresale) presale.push(price);
      else existing.push(price);
    }

    const presaleCount = presale.length;
    const existingCount = existing.length;
    const MIN_TX = 5;

    if (presaleCount < MIN_TX || existingCount < MIN_TX) {
      return { spread: null, presaleAvg: null, existingAvg: null, presaleCount, existingCount };
    }

    const presaleAvg = presale.reduce((a, b) => a + b, 0) / presale.length;
    const existingAvg = existing.reduce((a, b) => a + b, 0) / existing.length;
    const spread = ((presaleAvg - existingAvg) / existingAvg) * 100;

    return { spread, presaleAvg, existingAvg, presaleCount, existingCount };
  }

  /** Renders the pre-sale spread badge HTML for district click popup. */
  function renderPresaleSpreadBadgeHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const { spread, presaleAvg, existingAvg, presaleCount, existingCount } = computePresaleSpread(district, city);

    if (spread === null) {
      const detail = presaleCount === 0 && existingCount === 0
        ? "無資料"
        : `預售${presaleCount}筆 / 成屋${existingCount}筆`;
      return `<div class="presale-spread-row">
        <span class="presale-spread-label">🏗 預售 vs 成屋</span>
        <span class="presale-spread-badge presale-insufficient">資料不足 (${detail})</span>
      </div>`;
    }

    const sign  = spread >= 0 ? "+" : "−";
    const absPct = Math.abs(spread).toFixed(1);
    const presaleWan = presaleAvg !== null ? (presaleAvg / 10_000).toFixed(0) : "—";
    const existingWan = existingAvg !== null ? (existingAvg / 10_000).toFixed(0) : "—";

    let badgeClass: string;
    let label: string;
    if (spread < -2) {
      badgeClass = "presale-discount";
      label = `預售折價 ${sign}${absPct}%`;
    } else if (spread < 3) {
      badgeClass = "presale-neutral";
      label = `持平 (${sign}${absPct}%)`;
    } else if (spread < 10) {
      badgeClass = "presale-premium-low";
      label = `預售溢價 +${absPct}%`;
    } else if (spread < 20) {
      badgeClass = "presale-premium-medium";
      label = `預售溢價 +${absPct}%`;
    } else {
      badgeClass = "presale-premium-high";
      label = `預售溢價 +${absPct}%`;
    }

    return `<div class="presale-spread-row">
      <span class="presale-spread-label">🏗 預售溢價</span>
      <span class="presale-spread-badge ${badgeClass}" title="預售 ${presaleWan}萬/坪 (${presaleCount}筆) vs 成屋 ${existingWan}萬/坪 (${existingCount}筆)">${label}</span>
    </div>`;
  }

