  function renderBuyersMarketBannerHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const sig = computeBuyersMarketSignal(district, city);
    if (!sig.qualifies) return "";

    if (sig.isStale) {
