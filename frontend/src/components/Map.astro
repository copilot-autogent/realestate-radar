---
/**
 * MapLibre GL JS map component
 * Renders transaction dots + district choropleth layer
 */
---

<div id="map"></div>

<style is:global>
  /* Choropleth legend overlay */
  .choropleth-legend {
    position: absolute;
    bottom: 40px;
    right: 10px;
    background: rgba(255, 255, 255, 0.93);
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.78rem;
    z-index: 10;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }
  .legend-title {
    font-weight: 700;
    font-size: 0.72rem;
    color: #475569;
    margin-bottom: 7px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .legend-items { display: flex; flex-direction: column; gap: 4px; }
  .legend-item  { display: flex; align-items: center; gap: 6px; color: #334155; }
  .legend-swatch {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    flex-shrink: 0;
    opacity: 0.82;
    border: 1px solid rgba(0,0,0,0.08);
  }

  /* Toggle row in sidebar */
  .toggle-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding: 8px 10px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
  }
  .toggle-row input[type="checkbox"] {
    width: 15px;
    height: 15px;
    cursor: pointer;
    accent-color: #2563eb;
  }
  .toggle-row label {
    font-size: 0.85rem;
    color: #475569;
    cursor: pointer;
    margin-bottom: 0 !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    font-weight: 500;
  }
</style>

<script>
  import maplibregl from "maplibre-gl";

  const API_BASE = import.meta.env.DEV ? "/api" : "";
  const STATIC_DATA_URL = `${import.meta.env.BASE_URL}data/sample-transactions.json`;
  const DISTRICTS_URL = `${import.meta.env.BASE_URL}data/taipei-districts.geojson`;

  // Center on Taipei
  const map = new maplibregl.Map({
    container: "map",
    style: {
      version: 8,
      name: "Real Price Radar",
      sources: {
        osm: {
          type: "raster",
          tiles: ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
          tileSize: 256,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        },
      },
      layers: [
        {
          id: "osm-tiles",
          type: "raster",
          source: "osm",
          minzoom: 0,
          maxzoom: 19,
        },
      ],
    },
    center: [121.5654, 25.033],
    zoom: 12,
    maxBounds: [[119, 21.5], [123, 26.5]],
  });

  map.addControl(new maplibregl.NavigationControl(), "top-right");
  map.addControl(new maplibregl.ScaleControl({ maxWidth: 200 }));

  // ---- Helpers ----
  function formatPrice(price: number): string {
    if (price >= 100_000_000) return `${(price / 100_000_000).toFixed(1)} 億`;
    if (price >= 10_000) return `${(price / 10_000).toFixed(0)} 萬`;
    return price.toLocaleString();
  }

  // ---- Choropleth state ----
  let districtGeoJSON: any = null;
  let currentTxGeojson: any = null;

  /** Compute median unit price per district from transaction features. */
  function computeDistrictMedians(features: any[]): Record<string, number> {
    const byDistrict: Record<string, number[]> = {};
    for (const f of features) {
      const d = f.properties?.district as string | undefined;
      const p = f.properties?.unitPrice as number | undefined;
      if (d && p && p > 0) {
        if (!byDistrict[d]) byDistrict[d] = [];
        byDistrict[d].push(p);
      }
    }
    const medians: Record<string, number> = {};
    for (const [d, prices] of Object.entries(byDistrict)) {
      const sorted = [...prices].sort((a, b) => a - b);
      medians[d] = sorted[Math.floor(sorted.length / 2)];
    }
    return medians;
  }

  /** Re-join district median prices into the district GeoJSON and update source. */
  function updateChoropleth(): void {
    const src = map.getSource("districts") as maplibregl.GeoJSONSource | undefined;
    if (!src || !districtGeoJSON || !currentTxGeojson) return;
    const medians = computeDistrictMedians(currentTxGeojson.features ?? []);
    const updated = {
      ...districtGeoJSON,
      features: districtGeoJSON.features.map((f: any) => ({
        ...f,
        properties: {
          ...f.properties,
          // -1 signals "no data" to the paint expression
          medianPrice: medians[f.properties.district] ?? -1,
        },
      })),
    };
    src.setData(updated);
  }

  // ---- Transaction loading ----
  async function loadTransactions(params: Record<string, string> = {}): Promise<any> {
    let geojson: any;

    try {
      if (API_BASE) {
        const qs = new URLSearchParams(params).toString();
        const url = `${API_BASE}/transactions/geojson${qs ? `?${qs}` : ""}`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        geojson = await res.json();
      } else {
        throw new Error("No API configured");
      }
    } catch {
      // Fall back to static sample data
      const res = await fetch(STATIC_DATA_URL);
      geojson = await res.json();

      // Client-side filtering
      if (params.city)         geojson.features = geojson.features.filter((f: any) => f.properties.city === params.city);
      if (params.district)    geojson.features = geojson.features.filter((f: any) => f.properties.district === params.district);
      if (params.minPrice)    geojson.features = geojson.features.filter((f: any) => f.properties.unitPrice >= Number(params.minPrice));
      if (params.maxPrice)    geojson.features = geojson.features.filter((f: any) => f.properties.unitPrice <= Number(params.maxPrice));
      if (params.buildingType) geojson.features = geojson.features.filter((f: any) => f.properties.buildingType === params.buildingType);
    }

    currentTxGeojson = geojson;

    try {
      const source = map.getSource("transactions") as maplibregl.GeoJSONSource | undefined;
      if (source) {
        source.setData(geojson);
      } else {
        map.addSource("transactions", { type: "geojson", data: geojson });
        map.addLayer({
          id: "transactions-circles",
          type: "circle",
          source: "transactions",
          paint: {
            "circle-radius": [
              "interpolate", ["linear"], ["zoom"],
              10, 2, 14, 6, 18, 12,
            ],
            "circle-color": [
              "interpolate", ["linear"],
              ["get", "unitPrice"],
              200000, "#22c55e",
              400000, "#84cc16",
              600000, "#eab308",
              800000, "#f97316",
              1000000, "#ef4444",
              1500000, "#dc2626",
            ],
            "circle-opacity": 0.85,
            "circle-stroke-width": 1,
            "circle-stroke-color": "#ffffff",
            "circle-stroke-opacity": 0.5,
          },
        });
      }

      // Update stats panel
      const statsEl = document.getElementById("stats-content");
      if (statsEl && geojson.features) {
        const prices = geojson.features
          .map((f: any) => f.properties.unitPrice)
          .filter((p: any) => p != null && p > 0);
        if (prices.length > 0) {
          prices.sort((a: number, b: number) => a - b);
          const median = prices[Math.floor(prices.length / 2)];
          const avg = Math.round(prices.reduce((s: number, p: number) => s + p, 0) / prices.length);
          statsEl.innerHTML = `
            <div class="popup-row">
              <span class="popup-label">筆數</span>
              <span class="popup-value">${geojson.features.length.toLocaleString()}</span>
            </div>
            <div class="popup-row">
              <span class="popup-label">中位數 (元/坪)</span>
              <span class="popup-price">${formatPrice(median)}</span>
            </div>
            <div class="popup-row">
              <span class="popup-label">平均 (元/坪)</span>
              <span class="popup-price">${formatPrice(avg)}</span>
            </div>
          `;
        }
      }
    } catch (err) {
      console.error("Failed to update map layer:", err);
    }

    // Recompute choropleth colors with current data
    updateChoropleth();
    return geojson;
  }

  // ---- Map load ----
  map.on("load", async () => {
    // 1. District fill + border layers FIRST (render below transaction dots)
    map.addSource("districts", {
      type: "geojson",
      data: { type: "FeatureCollection", features: [] },
    });

    map.addLayer({
      id: "districts-fill",
      type: "fill",
      source: "districts",
      paint: {
        "fill-color": [
          "case",
          // medianPrice < 0 means no data → grey
          ["<", ["coalesce", ["get", "medianPrice"], -1], 0],
          "#d1d5db",
          [
            "interpolate", ["linear"],
            ["get", "medianPrice"],
            300000,  "#22c55e",
            500000,  "#84cc16",
            700000,  "#eab308",
            900000,  "#f97316",
            1100000, "#ef4444",
            1400000, "#7c1010",
          ],
        ],
        "fill-opacity": 0.44,
      },
    });

    map.addLayer({
      id: "districts-line",
      type: "line",
      source: "districts",
      paint: {
        "line-color": "#475569",
        "line-width": 1.5,
        "line-opacity": 0.65,
      },
    });

    // 2. Load transactions — circles layer added ON TOP of district fill
    await loadTransactions();

    // 3. Fetch district boundaries (async, doesn't block tx rendering)
    try {
      const res = await fetch(DISTRICTS_URL);
      districtGeoJSON = await res.json();
      updateChoropleth();
    } catch (e) {
      console.warn("[choropleth] district boundaries unavailable:", e);
    }

    // 4. Inject legend into map container
    const legend = document.createElement("div");
    legend.id = "choropleth-legend";
    legend.className = "choropleth-legend";
    legend.innerHTML = `
      <div class="legend-title">行政區 中位數單價</div>
      <div class="legend-items">
        <div class="legend-item"><span class="legend-swatch" style="background:#22c55e"></span>&lt; 50萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#84cc16"></span>50–70萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#eab308"></span>70–90萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#f97316"></span>90–110萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>110–140萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#7c1010"></span>&gt; 140萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#d1d5db"></span>資料不足</div>
      </div>`;
    document.getElementById("map")!.appendChild(legend);
  });

  // ---- Popup on transaction click ----
  map.on("click", "transactions-circles", (e) => {
    if (!e.features || e.features.length === 0) return;
    const props = e.features[0].properties;
    const coords = (e.features[0].geometry as GeoJSON.Point).coordinates.slice() as [number, number];
    new maplibregl.Popup({ offset: 10 })
      .setLngLat(coords)
      .setHTML(`
        <div class="popup-title">${props.address || "地址未登錄"}</div>
        <div class="popup-row">
          <span class="popup-label">單價</span>
          <span class="popup-price">${formatPrice(props.unitPrice)}/坪</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">總價</span>
          <span class="popup-value">${formatPrice(props.totalPrice)}</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">坪數</span>
          <span class="popup-value">${props.areaPing ? Number(props.areaPing).toFixed(1) + " 坪" : "—"}</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">型態</span>
          <span class="popup-value">${props.buildingType || "—"}</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">日期</span>
          <span class="popup-value">${props.date}</span>
        </div>
      `)
      .addTo(map);
  });

  // Cursor on transaction dots
  map.on("mouseenter", "transactions-circles", () => {
    map.getCanvas().style.cursor = "pointer";
  });
  map.on("mouseleave", "transactions-circles", () => {
    map.getCanvas().style.cursor = "";
  });

  // ---- District click → dispatch trend event ----
  map.on("click", "districts-fill", (e) => {
    if (!e.features || e.features.length === 0) return;
    const district = e.features[0].properties.district as string;

    const txFeatures = currentTxGeojson?.features ?? [];
    const quarterly: Record<string, number[]> = {};
    for (const f of txFeatures) {
      if (f.properties.district !== district) continue;
      const p = f.properties.unitPrice as number | undefined;
      const d = f.properties.date as string | undefined;
      if (!p || !d) continue;
      const dt = new Date(d);
      const q = Math.floor(dt.getMonth() / 3) + 1;
      const key = `${dt.getFullYear()}-Q${q}`;
      if (!quarterly[key]) quarterly[key] = [];
      quarterly[key].push(p);
    }

    const quarters = Object.keys(quarterly).sort();
    const medians = quarters.map((q) => {
      const arr = quarterly[q].sort((a, b) => a - b);
      return arr[Math.floor(arr.length / 2)];
    });

    document.dispatchEvent(
      new CustomEvent("district-trend", { detail: { district, quarters, medians } })
    );
  });

  // Cursor on district polygons
  map.on("mouseenter", "districts-fill", () => {
    map.getCanvas().style.cursor = "pointer";
  });
  map.on("mouseleave", "districts-fill", () => {
    map.getCanvas().style.cursor = "";
  });

  // ---- District hover popup ----
  let districtHover: maplibregl.Popup | null = null;

  map.on("mousemove", "districts-fill", (e) => {
    if (!e.features || e.features.length === 0) return;
    const props = e.features[0].properties as Record<string, any>;
    if (!districtHover) {
      districtHover = new maplibregl.Popup({
        closeButton: false,
        closeOnClick: false,
        offset: 4,
      });
    }
    const priceHtml =
      props.medianPrice > 0
        ? `<div class="popup-row"><span class="popup-label">中位數單價</span><span class="popup-price">${formatPrice(props.medianPrice)}/坪</span></div>`
        : `<div class="popup-row"><span class="popup-label">資料不足</span></div>`;
    districtHover
      .setLngLat(e.lngLat)
      .setHTML(`<div class="popup-title">${props.district}</div>${priceHtml}`)
      .addTo(map);
  });

  map.on("mouseleave", "districts-fill", () => {
    districtHover?.remove();
    districtHover = null;
  });

  // ---- Search button ----
  document.getElementById("search-btn")?.addEventListener("click", () => {
    const params: Record<string, string> = {};
    const city         = (document.getElementById("city-select")    as HTMLSelectElement)?.value;
    const district     = (document.getElementById("district-select") as HTMLSelectElement)?.value;
    const minPrice     = (document.getElementById("price-min")       as HTMLInputElement)?.value;
    const maxPrice     = (document.getElementById("price-max")       as HTMLInputElement)?.value;
    const buildingType = (document.getElementById("building-type")   as HTMLSelectElement)?.value;
    if (city)         params.city = city;
    if (district)     params.district = district;
    if (minPrice)     params.minPrice = String(Number(minPrice) * 10000);
    if (maxPrice)     params.maxPrice = String(Number(maxPrice) * 10000);
    if (buildingType) params.buildingType = buildingType;
    loadTransactions(params);
  });

  // ---- Choropleth toggle ----
  document.getElementById("choropleth-toggle")?.addEventListener("change", (e) => {
    const on = (e.target as HTMLInputElement).checked;
    const vis = on ? "visible" : "none";
    for (const id of ["districts-fill", "districts-line"]) {
      if (map.getLayer(id)) map.setLayoutProperty(id, "visibility", vis);
    }
    const legend = document.getElementById("choropleth-legend");
    if (legend) legend.style.opacity = on ? "1" : "0";
  });

  // Initial load
  map.on("load", () => { /* handled by the async load handler above */ });
</script>
