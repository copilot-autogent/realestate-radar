<script>
  import maplibregl from "maplibre-gl";

  const API_BASE = import.meta.env.DEV ? "/api" : "";
  const BASE_URL = import.meta.env.BASE_URL;
  const STATIC_DATA_URL = `${BASE_URL}data/sample-transactions.json`;
  const MRT_STATIONS_URL = `${BASE_URL}data/mrt-stations.json`;

  // ---- MRT station data (loaded once, concurrency-safe via promise cache) ----
  interface MrtStation {
    id: string;
    name: string;
    lat: number;
    lng: number;
    line: string;
    lineZh: string;
  }
  let mrtStations: MrtStation[] = [];
  let _mrtLoadPromise: Promise<void> | null = null;

  async function loadMrtStations(): Promise<void> {
    if (mrtStations.length > 0) return;
    if (_mrtLoadPromise) return _mrtLoadPromise;
    _mrtLoadPromise = (async () => {
      try {
        const res = await fetch(MRT_STATIONS_URL);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        const data = await res.json();
        if (!Array.isArray(data) || data.length === 0) throw new Error("Empty or invalid station data");
        mrtStations = data;
      } catch (e) {
        console.warn("[mrt] Failed to load mrt-stations.json:", e);
        // Clear promise so next call can retry
        _mrtLoadPromise = null;
      }
    })();
    return _mrtLoadPromise;
  }

  /** Haversine distance in metres between two lat/lng points. */
  function haversineMetres(lat1: number, lng1: number, lat2: number, lng2: number): number {
    const R = 6371000;
    const dLat = (lat2 - lat1) * Math.PI / 180;
    const dLng = (lng2 - lng1) * Math.PI / 180;
    const a = Math.sin(dLat / 2) ** 2 +
              Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
              Math.sin(dLng / 2) ** 2;
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  /**
   * Returns straight-line distance in metres from [lng, lat] to nearest MRT station.
   * Returns Infinity when station data is unavailable (fails closed — no false matches).
   * Note: straight-line distance; actual walking distances may be longer near rivers/hills.
   * When station data fails to load, the filter is skipped (fail-open: shows all results)
   * rather than showing an empty map. This is a deliberate UX trade-off.
   */
  function distToNearestMrt(lng: number, lat: number): number {
    if (mrtStations.length === 0) return Infinity;
    let minDist = Infinity;
    for (const st of mrtStations) {
      const d = haversineMetres(lat, lng, st.lat, st.lng);
      if (d < minDist) minDist = d;
    }
    return minDist;
  }

  const CITY_DISTRICTS: Record<string, string> = {
    "台北市": `${BASE_URL}data/taipei-districts.geojson`,
    "新北市": `${BASE_URL}data/xinbei-districts.geojson`,
    "桃園市": `${BASE_URL}data/taoyuan-districts.geojson`,
    "台中市": `${BASE_URL}data/taichung-districts.geojson`,
    "台南市": `${BASE_URL}data/tainan-districts.geojson`,
    "高雄市": `${BASE_URL}data/kaohsiung-districts.geojson`,
  };

  const CITY_CENTERS: Record<string, { center: [number, number]; zoom: number }> = {
    "台北市": { center: [121.5654, 25.033], zoom: 12 },
    "新北市": { center: [121.460, 25.012], zoom: 11 },
    "桃園市": { center: [121.250, 24.970], zoom: 11 },
    "台中市": { center: [120.684, 24.138], zoom: 11 },
    "台南市": { center: [120.200, 23.000], zoom: 11 },
    "高雄市": { center: [120.300, 22.630], zoom: 11 },
  };

  // Center on Taipei
  const map = new maplibregl.Map({
    container: "map",
    style: {
      version: 8,
      name: "Real Price Radar",
      sources: {
        osm: {
          type: "raster",
          tiles: ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
          tileSize: 256,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        },
      },
      layers: [
        {
          id: "osm-tiles",
          type: "raster",
          source: "osm",
          minzoom: 0,
          maxzoom: 19,
        },
      ],
    },
    center: [121.5654, 25.033],
    zoom: 12,
    maxBounds: [[119, 21.5], [123, 26.5]],
  });

  map.addControl(new maplibregl.NavigationControl(), "top-right");
  map.addControl(new maplibregl.ScaleControl({ maxWidth: 200 }));

  // ---- Helpers ----
  function formatPrice(price: number): string {
    if (price >= 100_000_000) return `${(price / 100_000_000).toFixed(1)} 億`;
    if (price >= 10_000) return `${(price / 10_000).toFixed(0)} 萬`;
    return price.toLocaleString();
  }

  // ---- Choropleth state ----
  let districtGeoJSON: any = null;
  let currentTxGeojson: any = null;

  // ---- Full unfiltered transaction features (cached once on first static load) ----
  let rawAllFeatures: any[] = [];

  // ---- Cross-district comparison panel state ----
  const MAX_PINS = 3;
  interface PinnedDistrict { district: string; city: string }
  let pinnedDistricts: PinnedDistrict[] = [];

  /**
   * Compute key metrics for one district from rawAllFeatures.
   * Uses the full unfiltered dataset for consistency (same as YoY functions).
   */
  function computeDistrictMetrics(district: string, city?: string): {
    medianPriceWan: string;
    yoyPct: string;
    yoyClass: string;
    txCount6mo: number;
    medianBuildingAge: string;
    velocityTrend: string;
    velocityClass: string;
  } {
    const features = rawAllFeatures.filter(
      (f) => f.properties?.district === district && (!city || f.properties?.city === city)
    );

    // Median unit price (all time)
    const prices = features
      .map((f) => f.properties?.unitPrice as number)
      .filter((p) => typeof p === "number" && p > 0)
      .sort((a, b) => a - b);
    const medianPriceWan = prices.length
      ? ((prices[Math.floor(prices.length / 2)] || 0) / 10_000).toFixed(1)
      : "—";

    // YoY price change
    const sig = computeYoYSignal(district, city);
    let yoyPct = "—";
    let yoyClass = "val-na";
    if (sig.tier !== "insufficient" && sig.pct !== null) {
      const sign = sig.pct >= 0 ? "+" : "";
      yoyPct = `${sign}${sig.pct.toFixed(1)}%`;
      yoyClass = sig.tier === "buyer" ? "val-down" : sig.tier === "seller" ? "val-up" : "val-neutral";
    }

    // Transactions past 6 months
    const cutoff6mo = new Date();
    cutoff6mo.setMonth(cutoff6mo.getMonth() - 6);
    const txCount6mo = features.filter((f) => {
      const d = f.properties?.date as string | undefined;
      return d && new Date(d) >= cutoff6mo;
    }).length;

    // Median building age: compute from buildYear in each feature
    const currentYear = new Date().getFullYear();
    const ages = features
      .map((f) => {
        const rawBY = f.properties?.buildYear ? Number(f.properties.buildYear) : null;
        if (!rawBY || rawBY <= 0) return null;
        const by = rawBY < 200 ? rawBY + 1911 : rawBY;
        const age = currentYear - by;
        return age >= 0 && age < 200 ? age : null;
      })
      .filter((a): a is number => a !== null)
      .sort((a, b) => a - b);
    const medianBuildingAge = ages.length
      ? `${ages[Math.floor(ages.length / 2)]} 年`
      : "—";

    // Monthly velocity trend
    const vel = computeMonthlyVelocity(district, city);
    const velocityTrend = vel.trendLabel;
    const velocityClass = vel.trendClass;

    return { medianPriceWan, yoyPct, yoyClass, txCount6mo, medianBuildingAge, velocityTrend, velocityClass };
  }

  /** Render (or refresh) the comparison panel table from current pinnedDistricts state. */
  function renderComparisonPanel(): void {
    const panel = document.getElementById("comparison-panel") as HTMLElement | null;
    const table = document.getElementById("comparison-table") as HTMLTableElement | null;
    const hint  = document.getElementById("comparison-hint") as HTMLElement | null;
    if (!panel || !table) return;

    if (pinnedDistricts.length === 0) {
      panel.style.display = "none";
      return;
    }

    panel.style.display = "block";
    panel.classList.remove("collapsed");  // clear stale collapsed state when re-opening
    if (hint) hint.style.display = pinnedDistricts.length < MAX_PINS ? "block" : "none";

    const metrics = pinnedDistricts.map((p) => computeDistrictMetrics(p.district, p.city));

    // Build header row (metric label col + one col per pinned district)
    const thead = table.querySelector("thead tr") as HTMLTableRowElement;
    thead.innerHTML = `<th class="comparison-metric-col">指標</th>`;
    pinnedDistricts.forEach((p) => {
      const th = document.createElement("th");
      th.className = "district-header-cell";
      th.innerHTML = `${escHtml(p.city ? p.city + " " : "")}${escHtml(p.district)}<button class="unpin-btn" data-district="${escHtml(p.district)}" data-city="${escHtml(p.city)}" aria-label="移除 ${escHtml(p.district)}">✕</button>`;
      thead.appendChild(th);
    });

    // Build data rows
    const ROWS: [string, (m: ReturnType<typeof computeDistrictMetrics>) => string][] = [
      ["中位單價 (萬/坪)",   (m) => `<span class="val-price">${m.medianPriceWan}</span>`],
      ["年增率 YoY",         (m) => `<span class="${m.yoyClass}">${m.yoyPct}</span>`],
      ["近半年成交 (筆)",     (m) => `${m.txCount6mo || "0"}`],
      ["中位屋齡",           (m) => m.medianBuildingAge],
      ["成交量趨勢",         (m) => m.velocityClass === "velocity-na"
        ? `<span class="val-na">${escHtml(m.velocityTrend)}</span>`
        : `<span class="velocity-trend-badge ${m.velocityClass}">${escHtml(m.velocityTrend)}</span>`],
    ];

    const tbody = table.querySelector("tbody") as HTMLTableSectionElement;
    tbody.innerHTML = ROWS.map(([label, render]) => {
      const cells = metrics.map((m) => `<td>${render(m)}</td>`).join("");
      return `<tr><td class="comparison-metric-col">${escHtml(label)}</td>${cells}</tr>`;
    }).join("");

    // Wire up unpin buttons
    thead.querySelectorAll(".unpin-btn").forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const district = (btn as HTMLElement).dataset.district ?? "";
        const city     = (btn as HTMLElement).dataset.city     ?? "";
        pinnedDistricts = pinnedDistricts.filter(
          (p) => !(p.district === district && p.city === city)
        );
        renderComparisonPanel();
        // Refresh the currently open popup's pin button state (cap may have freed up)
        syncOpenPopupPinButton();
      });
    });
  }

  /**
   * Toggle a district pin on/off. Returns new pinned state.
   * Enforces MAX_PINS cap (returns false if cap would be exceeded).
   */
  function togglePin(district: string, city: string): boolean {
    const idx = pinnedDistricts.findIndex((p) => p.district === district && p.city === city);
    if (idx !== -1) {
      pinnedDistricts.splice(idx, 1);
      renderComparisonPanel();
      return false; // unpinned
    }
    if (pinnedDistricts.length >= MAX_PINS) return false; // cap reached
    pinnedDistricts.push({ district, city });
    renderComparisonPanel();
    return true; // pinned
  }

  /**
   * Refresh pin button state in the currently open district click popup.
   * Finds the button by reading its own data-district/data-city attributes —
   * avoids CSS.escape/escHtml mismatch for attribute selectors.
   * Called after any state change (pin, unpin, clear all) to prevent staleness.
   */
  function syncOpenPopupPinButton(): void {
    if (!districtClickPopup) return;
    const btn = districtClickPopup.getElement()?.querySelector<HTMLButtonElement>(".popup-pin-btn");
    if (!btn) return;
    const d = btn.dataset.district ?? "";
    const c = btn.dataset.city     ?? "";
    const isPinned = pinnedDistricts.some((p) => p.district === d && p.city === c);
    const atCap    = !isPinned && pinnedDistricts.length >= MAX_PINS;
    btn.textContent = isPinned ? "✕ 移除比較" : atCap ? `📌 已達上限 (最多${MAX_PINS}個)` : "📌 加入比較";
    btn.classList.toggle("pinned", isPinned);
    btn.disabled    = atCap;
  }

  /**
   * Computes rolling 12-month YoY median unit-price change for a district.
   * Anchors to the latest date present in rawAllFeatures for that district.
   * Optionally scoped by city to avoid cross-city district-name collisions.
   * Requires ≥3 transactions in both the recent and prior 12-month windows.
   */
  function computeYoYSignal(district: string, city?: string): {
    tier: "buyer" | "neutral" | "seller" | "insufficient";
    pct: number | null;
    label: string;
    arrow: string;
    badge: string;
  } {
    const MIN_SAMPLES = 3;
    const THRESHOLD_PCT = 3;

    const features = rawAllFeatures.filter(
      (f) =>
        f.properties?.district === district &&
        (f.properties?.unitPrice as number) > 0 &&
        (!city || f.properties?.city === city)
    );

    const validTimes = features
      .map((f) => new Date(f.properties.date as string).getTime())
      .filter((t) => !isNaN(t));

    if (validTimes.length < MIN_SAMPLES * 2) {
      return { tier: "insufficient", pct: null, label: "資料不足", arrow: "", badge: "" };
    }

    // Use reduce to avoid RangeError on very large arrays (spread is stack-limited)
    const maxTime = validTimes.reduce((a, b) => (a > b ? a : b), -Infinity);

    // Recent 12mo: (maxDate-12mo, maxDate]
    const cutRecent = new Date(maxTime);
    cutRecent.setFullYear(cutRecent.getFullYear() - 1);

    // Prior 12mo: (maxDate-24mo, maxDate-12mo]
    const cutPrior = new Date(maxTime);
    cutPrior.setFullYear(cutPrior.getFullYear() - 2);

    const toTime = (f: any) => new Date(f.properties.date as string).getTime();

    const recentPrices = features
      .filter((f) => { const t = toTime(f); return t > cutRecent.getTime() && t <= maxTime; })
      .map((f) => f.properties.unitPrice as number);

    const priorPrices = features
      .filter((f) => { const t = toTime(f); return t > cutPrior.getTime() && t <= cutRecent.getTime(); })
      .map((f) => f.properties.unitPrice as number);

    if (recentPrices.length < MIN_SAMPLES || priorPrices.length < MIN_SAMPLES) {
      return { tier: "insufficient", pct: null, label: "資料不足", arrow: "", badge: "" };
    }

    const median = (arr: number[]) => {
      const s = [...arr].sort((a, b) => a - b);
      const mid = Math.floor(s.length / 2);
      // True median: average two middle values for even-length arrays
      return s.length % 2 === 0 ? (s[mid - 1] + s[mid]) / 2 : s[mid];
    };

    const pct = ((median(recentPrices) - median(priorPrices)) / median(priorPrices)) * 100;

    if (pct < -THRESHOLD_PCT) {
      return { tier: "buyer",   pct, label: "買方有利", arrow: "▼", badge: "🟢" };
    } else if (pct > THRESHOLD_PCT) {
      return { tier: "seller",  pct, label: "賣方有利", arrow: "▲", badge: "🔴" };
    } else {
      return { tier: "neutral", pct, label: "持平",     arrow: pct >= 0 ? "▲" : "▼", badge: "🟡" };
    }
  }

  /**
   * Computes rolling 12-month YoY transaction volume (count) change for a district.
   * Scans rawAllFeatures (the full unfiltered dataset) so the signal reflects the
   * true district market regardless of active price/date filters — consistent with
   * the computeYoYSignal price approach.
   * Anchors to the district's latest transaction date (same as computeYoYSignal).
   * Requires ≥10 transactions in both the recent and prior 12-month windows.
   */
  function computeVolumeYoYSignal(district: string, city?: string): {
    tier: "falling" | "rising" | "flat" | "insufficient";
    count12mo: number;
    pct: number | null;
    label: string;
    arrow: string;
  } {
    const MIN_SAMPLES = 10;
    const THRESHOLD_PCT = 5;

    const features = rawAllFeatures.filter(
      (f) =>
        f.properties?.district === district &&
        (!city || f.properties?.city === city)
    );

    const validTimes = features
      .map((f) => new Date((f.properties?.date as string) ?? "").getTime())
      .filter((t) => !isNaN(t));

    if (validTimes.length === 0) {
      return { tier: "insufficient", count12mo: 0, pct: null, label: "資料不足", arrow: "" };
    }

    const maxTime = validTimes.reduce((a, b) => (a > b ? a : b), -Infinity);

    // Use setFullYear (conventional "same day N years ago") — matches computeYoYSignal.
    // Both windows are relative to maxTime (district's latest tx), matching price-YoY anchor.
    const cutRecent = new Date(maxTime);
    cutRecent.setFullYear(cutRecent.getFullYear() - 1);

    const cutPrior = new Date(maxTime);
    cutPrior.setFullYear(cutPrior.getFullYear() - 2);

    const toTime = (f: any) => new Date((f.properties?.date as string) ?? "").getTime();

    const count12mo = features.filter(
      (f) => { const t = toTime(f); return !isNaN(t) && t > cutRecent.getTime() && t <= maxTime; }
    ).length;

    const countPrior12mo = features.filter(
      (f) => { const t = toTime(f); return !isNaN(t) && t > cutPrior.getTime() && t <= cutRecent.getTime(); }
    ).length;

    if (count12mo < MIN_SAMPLES || countPrior12mo < MIN_SAMPLES) {
      return { tier: "insufficient", count12mo, pct: null, label: "資料不足", arrow: "" };
    }

    const pct = ((count12mo - countPrior12mo) / countPrior12mo) * 100;

    if (pct < -THRESHOLD_PCT) {
      return { tier: "falling", count12mo, pct, label: "成交量下降，議價空間擴大", arrow: "↓" };
    } else if (pct > THRESHOLD_PCT) {
      return { tier: "rising",  count12mo, pct, label: "成交量上升，買方競爭增加", arrow: "↑" };
    } else {
      return { tier: "flat",    count12mo, pct, label: "成交量持平",               arrow: "→" };
    }
  }

  /**
   * Renders the volume YoY badge HTML for the stats panel (sidebar only — not used in popups).
   * Called by callers that compose stats-panel HTML; renderYoYHtml stays price-only for popup use.
   */
  function renderVolumeHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const vol = computeVolumeYoYSignal(district, city);
    if (vol.tier === "insufficient") {
      return `<div class="yoy-row"><span class="yoy-row-label">本區交易量 (近12個月)</span><span class="yoy-insufficient">資料不足</span></div>`;
    }
    const pctStr = (vol.pct! >= 0 ? "+" : "") + vol.pct!.toFixed(1);
    return `
      <div class="yoy-row volume-count-row"><span class="yoy-row-label">本區交易量 (近12個月)</span><span>${vol.count12mo} 筆</span></div>
      <div class="yoy-row"><span class="yoy-row-label">較去年同期</span><span class="volume-signal volume-${vol.tier}">${vol.arrow} ${pctStr}%</span></div>
      <div class="volume-interp">${vol.label}</div>`;
  }

  /**
   * Computes a 12-month rolling monthly transaction count sparkline for a district.
   * Anchors to the latest month present in rawAllFeatures for the district.
   * Gate: requires ≥3 months with data in the 12-month window.
   * Trend: computed from sum of last 3 months vs prior 3 months (months 4–6 from end).
   */
  function computeMonthlyVelocity(district: string, city?: string): {
    hasData: boolean;
    months: string[];      // YYYY-MM labels for 12-month window
    counts: (number | null)[]; // transaction count per month, null if no data
    trendLabel: string;    // ▲ 成交量增加 / ▼ 成交量萎縮 / → 持平 / 資料不足
    trendClass: string;    // CSS class: velocity-rising / velocity-falling / velocity-flat / velocity-na
  } {
    const MIN_DATA_POINTS = 3;
    const TREND_THRESHOLD = 0.05; // 5% change to register as rising/falling

    const features = rawAllFeatures.filter(
      (f) =>
        f.properties?.district === district &&
        (!city || f.properties?.city === city)
    );

    // Group transaction counts by YYYY-MM.
    // Use string slice on YYYY-MM-DD to avoid UTC-vs-local timezone shift when
    // constructing a Date from a bare date string (parsed as UTC by spec).
    // Guard against non-string values (upstream GeoJSON properties are untyped).
    const monthMap: Record<string, number> = {};
    for (const f of features) {
      const d = f.properties?.date;
      if (typeof d !== "string" || d.length < 7) continue;
      const key = d.slice(0, 7); // "YYYY-MM" extracted directly — no Date parsing needed
      if (!/^\d{4}-\d{2}$/.test(key)) continue; // guard against non-YYYY-MM-DD date formats
      monthMap[key] = (monthMap[key] ?? 0) + 1;
    }

    const allMonthKeys = Object.keys(monthMap).sort();
    if (allMonthKeys.length === 0) {
      return { hasData: false, months: [], counts: [], trendLabel: "資料不足", trendClass: "velocity-na" };
    }

    // Anchor 12-month window at the latest month present
    const lastKey = allMonthKeys[allMonthKeys.length - 1];
    const [lastYr, lastMo] = lastKey.split("-").map(Number);
    const anchorDate = new Date(lastYr, lastMo - 1, 1);

    const months: string[] = [];
    for (let i = 11; i >= 0; i--) {
      const d = new Date(anchorDate);
      d.setMonth(d.getMonth() - i);
      months.push(`${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}`);
    }

    // Months without any observed transactions are null (no record vs zero).
    // Every key in monthMap is ≥1 since we only increment on observed rows.
    const counts: (number | null)[] = months.map((m) =>
      monthMap[m] != null ? monthMap[m] : null
    );

    const dataPointCount = counts.filter((c) => c !== null).length;
    if (dataPointCount < MIN_DATA_POINTS) {
      return { hasData: false, months, counts, trendLabel: "資料不足", trendClass: "velocity-na" };
    }

    // Trend: last 3 months vs prior 3 months (index 9-11 vs 6-8).
    // Null months contribute 0 to the sum (same as no transactions recorded).
    const last3: number = counts.slice(9).reduce<number>((s, v) => s + (v ?? 0), 0);
    const prior3: number = counts.slice(6, 9).reduce<number>((s, v) => s + (v ?? 0), 0);

    let trendLabel: string;
    let trendClass: string;
    if (last3 === 0 && prior3 === 0) {
      // All data is in the first half of the window — trend windows lack data
      trendLabel = "資料不足";
      trendClass = "velocity-na";
    } else if (prior3 === 0) {
      // New or recovering market: data only in the recent window.
      // Require ≥MIN_DATA_POINTS transactions to avoid noise from isolated records.
      if (last3 >= MIN_DATA_POINTS) {
        trendLabel = "▲ 成交量增加";
        trendClass = "velocity-rising";
      } else {
        // Too few recent transactions and no prior baseline — insufficient for trend
        trendLabel = "資料不足";
        trendClass = "velocity-na";
      }
    } else {
      const ratio = (last3 - prior3) / prior3;
      if (ratio > TREND_THRESHOLD) {
        trendLabel = "▲ 成交量增加";
        trendClass = "velocity-rising";
      } else if (ratio < -TREND_THRESHOLD) {
        trendLabel = "▼ 成交量萎縮";
        trendClass = "velocity-falling";
      } else {
        trendLabel = "→ 持平";
        trendClass = "velocity-flat";
      }
    }

    return { hasData: true, months, counts, trendLabel, trendClass };
  }

  /**
   * Renders an inline SVG sparkline for monthly transaction counts.
   * Similar to buildSparkline but for integer count data.
   */
  function buildVolumeSparkline(counts: (number | null)[], width = 204, height = 40): string {
    const W = width, H = height;
    const PX = 3, PY = 4;
    const plotW = W - PX * 2;
    const plotH = H - PY * 2;
    const n = counts.length;

    const nonNull = counts.filter((v): v is number => v !== null);
    if (nonNull.length === 0) {
      return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}"><text x="${W / 2}" y="${H / 2 + 3}" text-anchor="middle" font-size="9" fill="#94a3b8">暫無資料</text></svg>`;
    }

    const yMin = 0; // Count bars start at 0
    const yMax = Math.max(...nonNull);
    const yRange = yMax - yMin || 1;

    const pts: ([number, number] | null)[] = counts.map((v, i) => {
      if (v === null) return null;
      const x = PX + (n <= 1 ? plotW / 2 : (i / (n - 1)) * plotW);
      const y = PY + plotH - ((v - yMin) / yRange) * plotH;
      return [+x.toFixed(1), +y.toFixed(1)];
    });

    const lines: string[] = [];
    let seg: [number, number][] = [];
    const flushSeg = () => {
      if (seg.length >= 2) {
        lines.push(`<polyline points="${seg.map((p) => p.join(",")).join(" ")}" fill="none" stroke="#10b981" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"/>`);
      } else if (seg.length === 1) {
        lines.push(`<circle cx="${seg[0][0]}" cy="${seg[0][1]}" r="2" fill="#10b981"/>`);
      }
      seg = [];
    };
    for (const pt of pts) {
      if (pt === null) { flushSeg(); } else { seg.push(pt); }
    }
    flushSeg();

    const dots = pts
      .filter((p): p is [number, number] => p !== null)
      .map(([x, y]) => `<circle cx="${x}" cy="${y}" r="2.2" fill="#059669" stroke="white" stroke-width="1.2"/>`)
      .join("");

    return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" style="display:block;overflow:visible">${lines.join("")}${dots}</svg>`;
  }

  /** Renders the price YoY signal as an HTML row string for use in popups and the stats panel. */
  function renderYoYHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const sig = computeYoYSignal(district, city);
    if (sig.tier === "insufficient") {
      return `<div class="yoy-row"><span class="yoy-row-label">議價時機</span><span class="yoy-insufficient">資料不足</span></div>`;
    }
    const pctStr = Math.abs(sig.pct!).toFixed(1);
    return `<div class="yoy-row"><span class="yoy-row-label">議價時機</span><span class="yoy-signal yoy-${sig.tier}">${sig.badge} ${sig.label} ${sig.arrow}${pctStr}% YoY</span></div>`;
  }

  /**
   * Computes the Buyer Timing Score (買方時機分) for a district.
   * Formula (all from rawAllFeatures):
   *   40% YoY median price change (declining → higher score)
   *   30% YoY transaction volume change (declining → higher score)
   *   20% Current price vs 3-yr district average (below avg → higher score)
   *   10% Months since local price peak (longer → higher score)
   *
   * Minimum data threshold: ≥10 transactions in past 12 months.
   * Returns null when data is insufficient.
   */
  function computeBuyerTimingScore(district: string, city?: string): number | null {
    const MIN_TX_12MO = 10;

    const features = rawAllFeatures.filter(
      (f) =>
        f.properties?.district === district &&
        (f.properties?.unitPrice as number) > 0 &&
        (!city || f.properties?.city === city)
    );

    const validTimes = features
      .map((f) => new Date((f.properties?.date as string) ?? "").getTime())
      .filter((t) => !isNaN(t));

    if (validTimes.length === 0) return null;

    const maxTime = validTimes.reduce((a, b) => (a > b ? a : b), -Infinity);

    // Window anchors
    const cut12mo = new Date(maxTime);
    cut12mo.setFullYear(cut12mo.getFullYear() - 1);
    const cut24mo = new Date(maxTime);
    cut24mo.setFullYear(cut24mo.getFullYear() - 2);
    const cut36mo = new Date(maxTime);
    cut36mo.setFullYear(cut36mo.getFullYear() - 3);

    const toTime = (f: any) => new Date((f.properties?.date as string) ?? "").getTime();

    // Gate on minimum transaction count in recent 12 months
    const recent12 = features.filter((f) => { const t = toTime(f); return !isNaN(t) && t > cut12mo.getTime() && t <= maxTime; });
    if (recent12.length < MIN_TX_12MO) return null;

    const prior12 = features.filter((f) => { const t = toTime(f); return !isNaN(t) && t > cut24mo.getTime() && t <= cut12mo.getTime(); });

    const median = (arr: number[]) => {
      const s = [...arr].sort((a, b) => a - b);
      const mid = Math.floor(s.length / 2);
      return s.length % 2 === 0 ? (s[mid - 1] + s[mid]) / 2 : s[mid];
    };

    // Helper: map a percentage change to 0–100 sub-score (declining = high score)
    // Range: pct ≤ -20% → 100, pct ≥ +20% → 0
    const clamp = (v: number) => Math.max(0, Math.min(100, v));
    const pctToScore = (pct: number) => clamp((-pct + 20) / 40 * 100);

    // ── Signal 1: YoY median price change (40%) ──
    let s1 = 50; // neutral fallback
    if (prior12.length >= 3 && recent12.length >= 3) {
      const priorPrices  = prior12.map((f) => f.properties.unitPrice as number);
      const recentPrices = recent12.map((f) => f.properties.unitPrice as number);
      const pct = ((median(recentPrices) - median(priorPrices)) / median(priorPrices)) * 100;
      s1 = pctToScore(pct);
    }

    // ── Signal 2: YoY transaction volume change (30%) ──
    let s2 = 50; // neutral fallback
    if (prior12.length >= 3) {
      const pct = ((recent12.length - prior12.length) / prior12.length) * 100;
      s2 = pctToScore(pct);
    }

    // ── Signal 3: Current price vs 3-yr district average (20%) ──
    let s3 = 50; // neutral fallback
    const all3yr = features.filter((f) => { const t = toTime(f); return !isNaN(t) && t > cut36mo.getTime() && t <= maxTime; });
    if (all3yr.length >= 10) {
      const recentPrices = recent12.map((f) => f.properties.unitPrice as number);
      const avg3yr       = all3yr.map((f) => f.properties.unitPrice as number).reduce((a, b) => a + b, 0) / all3yr.length;
      const recentMedian = median(recentPrices);
      const deviation    = ((recentMedian - avg3yr) / avg3yr) * 100;
      s3 = pctToScore(deviation);
    }

    // ── Signal 4: Months since local price peak (10%) ──
    let s4 = 50; // neutral fallback
    if (all3yr.length >= 5) {
      // Bucket by quarter and find the quarter with the highest median
      const qBuckets: Record<string, number[]> = {};
      for (const f of all3yr) {
        const t = toTime(f);
        if (isNaN(t)) continue;
        const dt = new Date(t);
        const q = Math.floor(dt.getMonth() / 3) + 1;
        const key = `${dt.getFullYear()}-Q${q}`;
        (qBuckets[key] ??= []).push(f.properties.unitPrice as number);
      }
      const sortedQKeys = Object.keys(qBuckets).sort();
      // Need at least 2 quarters to identify a peak
      if (sortedQKeys.length >= 2) {
        let peakMedian = -Infinity;
        let peakQKey = sortedQKeys[0];
        for (const k of sortedQKeys) {
          const m = median(qBuckets[k]);
          if (m > peakMedian) { peakMedian = m; peakQKey = k; }
        }
        // Compute months from peak quarter midpoint to maxTime
        const [yr, qStr] = peakQKey.split("-Q");
        const peakDate = new Date(Number(yr), (Number(qStr) - 1) * 3 + 1, 15); // mid-quarter
        const monthsSincePeak = (maxTime - peakDate.getTime()) / (1000 * 60 * 60 * 24 * 30.44);
        s4 = clamp(monthsSincePeak / 36 * 100);
      }
    }

    const score = 0.4 * s1 + 0.3 * s2 + 0.2 * s3 + 0.1 * s4;
    return Math.round(score);
  }

  /** Returns score bucket info: label, CSS class, emoji. */
  function buyerScoreBucket(score: number): { label: string; cls: string; emoji: string } {
    if (score >= 70) return { label: "買方優勢", cls: "buyer-score-green",  emoji: "🟢" };
    if (score >= 40) return { label: "均衡市場", cls: "buyer-score-yellow", emoji: "🟡" };
    return               { label: "賣方市場", cls: "buyer-score-red",    emoji: "🔴" };
  }

  /** Renders buyer score badge HTML for use in popups. */
  function renderBuyerScoreBadgeHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const score = computeBuyerTimingScore(district, city);
    if (score === null) {
      return `<div class="buyer-score-row"><span class="buyer-score-row-label">買方時機分</span><span class="buyer-score-insufficient">資料不足</span></div>`;
    }
    const { label, cls, emoji } = buyerScoreBucket(score);
    return `<div class="buyer-score-row"><span class="buyer-score-row-label">買方時機分 <button class="buyer-score-help-btn" title="查看計算方法" aria-label="買方時機分計算方法">?</button></span><span class="buyer-score-badge ${cls}">${emoji} ${label} ${score}/100</span></div>`;
  }

  // ---- Price Volatility (CV) ----

  /**
   * Computes the price Coefficient of Variation (CV) for a district over the last 12 months.
   * CV = (stddev / mean) × 100  — using unitPrice (元/坪).
   * Minimum data gate: ≥10 transactions in the 12-month window.
   * Returns null when data is insufficient.
   */
  function computeVolatilityCV(district: string, city?: string): number | null {
    const MIN_TX = 10;

    const features = rawAllFeatures.filter(
      (f) =>
        f.properties?.district === district &&
        (f.properties?.unitPrice as number) > 0 &&
        (!city || f.properties?.city === city)
    );

    const validTimes = features
      .map((f) => new Date((f.properties?.date as string) ?? "").getTime())
      .filter((t) => !isNaN(t));

    if (validTimes.length === 0) return null;

    const maxTime = validTimes.reduce((a, b) => (a > b ? a : b), -Infinity);
    const cut12mo = new Date(maxTime);
    cut12mo.setFullYear(cut12mo.getFullYear() - 1);

    const recent12 = features.filter((f) => {
      const t = new Date((f.properties?.date as string) ?? "").getTime();
      return !isNaN(t) && t >= cut12mo.getTime() && t <= maxTime;
    });

    if (recent12.length < MIN_TX) return null;

    const prices = recent12.map((f) => Number(f.properties.unitPrice));
    const mean = prices.reduce((a, b) => a + b, 0) / prices.length;
    if (mean === 0) return null;

    const variance = prices.reduce((sum, p) => sum + (p - mean) ** 2, 0) / prices.length;
    const stddev = Math.sqrt(variance);
    return (stddev / mean) * 100;
  }

  /** Returns volatility tier info: label, CSS class, emoji. */
  function volatilityTier(cv: number): { label: string; cls: string; emoji: string } {
    if (cv < 10)  return { label: "穩定",  cls: "volatility-stable",  emoji: "🟢" };
    if (cv < 20)  return { label: "中波動", cls: "volatility-medium",  emoji: "🟡" };
    return               { label: "高波動", cls: "volatility-high",    emoji: "🔴" };
  }

  /** Renders the volatility badge row HTML for use in popups. */
  function renderVolatilityBadgeHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const cv = computeVolatilityCV(district, city);
    if (cv === null) {
      return `<div class="volatility-row"><span class="volatility-row-label">價格波動度</span><span class="volatility-insufficient">資料不足</span></div>`;
    }
    const { label, cls, emoji } = volatilityTier(cv);
    return `<div class="volatility-row"><span class="volatility-row-label">價格波動度 (CV ${cv.toFixed(1)}%)</span><span class="volatility-badge ${cls}">${emoji} ${label}</span></div>`;
  }

  /**
   * Renders combined signal callouts for a district:
   *  - 最佳進場訊號 when timing score ≥70 AND CV<10%
   *  - Caveat card when timing score ≥70 AND CV>20%
   */
  function renderVolatilityCombinedSignalHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    const score = computeBuyerTimingScore(district, city);
    const cv = computeVolatilityCV(district, city);
    if (score === null || cv === null) return "";

    if (score >= 70 && cv < 10) {
      return `<div class="best-entry-callout">🏆 最佳進場訊號：買方優勢 + 價格穩定</div>`;
    }
    if (score >= 70 && cv >= 20) {
      return `<div class="volatility-caveat-card">⚠️ 買方時機佳，但價格波動大——進場時機影響更顯著，請留意低點。</div>`;
    }
    return "";
  }

  // ---- MRT Proximity Price Premium ----

  /**
   * Computes the MRT proximity price premium for a district.
   * Splits transactions into ≤500m and >500m buckets; returns % premium when both
   * buckets have ≥5 transactions.
   *
   * Return values encoded as numbers for GeoJSON property:
   *   -9999 = no MRT coverage (no station within 2 km of any transaction in district)
   *   -9998 = insufficient data (fewer than 5 tx in one or both buckets, but MRT exists;
   *           also returned when station data has not yet loaded)
   *   real  = actual premium %; can be negative (near-MRT is cheaper — rare discount case)
   */
  function computeMrtPremium(district: string, city?: string): number {
    const MIN_BUCKET = 5;
    const NEAR_M = 500;
    const COVERAGE_M = 2000;

    // Stations not loaded yet — insufficient data, not "no coverage"
    if (mrtStations.length === 0) return -9998;

    const features = rawAllFeatures.filter(
      (f) =>
        f.properties?.district === district &&
        (f.properties?.unitPrice as number) > 0 &&
        (!city || f.properties?.city === city) &&
        f.geometry?.coordinates?.length >= 2
    );

    if (features.length === 0) return -9998;

    const nearPrices: number[] = [];
    const farPrices: number[] = [];

    for (const f of features) {
      const [lng, lat] = f.geometry.coordinates as [number, number];
      const dist = distToNearestMrt(lng, lat);
      const price = Number(f.properties.unitPrice);
      if (dist <= NEAR_M) nearPrices.push(price);
      else farPrices.push(price);
    }

    // Check MRT coverage: any station within COVERAGE_M of any transaction
    if (nearPrices.length < MIN_BUCKET) {
      const hasCoverage = features.some((f) => {
        const [lng, lat] = f.geometry.coordinates as [number, number];
        return distToNearestMrt(lng, lat) <= COVERAGE_M;
      });
      if (!hasCoverage) return -9999; // no MRT in district
      return -9998; // MRT exists but too few near-MRT transactions
    }

    if (farPrices.length < MIN_BUCKET) return -9998;

    // Proper median: average two middle elements for even-length arrays
    const median = (arr: number[]) => {
      const s = [...arr].sort((a, b) => a - b);
      const mid = Math.floor(s.length / 2);
      return s.length % 2 === 0 ? (s[mid - 1] + s[mid]) / 2 : s[mid];
    };

    const nearMed = median(nearPrices);
    const farMed  = median(farPrices);
    if (farMed === 0) return -9998;

    return ((nearMed - farMed) / farMed) * 100;
  }

  /** Renders the MRT premium badge HTML for district click popups. */
  function renderMrtPremiumBadgeHtml(district: string, city?: string): string {
    if (!rawAllFeatures.length) return "";
    // Show 資料不足 badge even when stations haven't loaded yet (mrtStations may be empty)
    const premium = computeMrtPremium(district, city);
    if (premium === -9999) {
      return `<div class="mrt-premium-row"><span class="mrt-premium-label">捷運500m溢價</span><span class="mrt-premium-badge mrt-no-coverage">無近捷運交易</span></div>`;
    }
    if (premium === -9998) {
      return `<div class="mrt-premium-row"><span class="mrt-premium-label">捷運500m溢價</span><span class="mrt-premium-badge mrt-insufficient">資料不足</span></div>`;
    }
    const pct = premium.toFixed(1);
    // Negatives and small positives (<5%) are treated as no-effect, matching choropleth neutral bucket
    if (premium < 5) {
      return `<div class="mrt-premium-row"><span class="mrt-premium-label">捷運500m溢價</span><span class="mrt-premium-badge mrt-neutral">無捷運效應 (${pct}%)</span></div>`;
    }
    const sign  = "+";
    const cls   = premium >= 20 ? "mrt-high" : premium >= 10 ? "mrt-medium" : "mrt-low";
