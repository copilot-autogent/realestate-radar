    </div>`;
  }

  /**
   * Computes the approximate centroid of a GeoJSON polygon ring (outer ring).
   * Slices off the closing duplicate point (GeoJSON rings repeat the first coord at end)
   * before averaging to avoid biasing the centroid toward that vertex.
   * Returns [lng, lat] or null when coordinates are empty.
   */
  function computePolygonCentroid(rings: number[][][]): [number, number] | null {
    const ring = rings[0];
    if (!ring || ring.length < 2) return null;
    // GeoJSON ring closes by repeating the first point — drop the last vertex before averaging
    const pts = ring.length > 1 ? ring.slice(0, -1) : ring;
    const sum = pts.reduce(
      (acc: [number, number], c: number[]) => [acc[0] + c[0], acc[1] + c[1]],
      [0, 0]
    );
    return [sum[0] / pts.length, sum[1] / pts.length];
  }

  /**
   * Returns the centroid of the largest sub-polygon (by vertex count) in a MultiPolygon.
   * Falls back to the first polygon when all have equal size.
   */
  function computeMultiPolygonCentroid(polygons: number[][][][]): [number, number] | null {
    if (!polygons || polygons.length === 0) return null;
    // Pick the polygon with the most outer-ring vertices as a proxy for "largest"
    const largest = polygons.reduce(
      (best, poly) => (poly[0]?.length ?? 0) > (best[0]?.length ?? 0) ? poly : best,
      polygons[0]
    );
    return computePolygonCentroid(largest);
  }

  /**
   * Adds/removes pulsing ring markers on the map for districts that qualify
   * as buyer's market opportunities.  Accepts pre-computed qualifying keys
   * from `updateChoropleth` to avoid re-scanning rawAllFeatures per district.
   * Diffs against the current marker set to avoid restarting CSS pulse animations
   * (which would cause visible flicker on every choropleth update).
   * Clears all markers first only when districtGeoJSON is absent/empty.
   */
  function updateBuyersMarketMarkers(qualifyingKeys: Set<string>): void {
    if (!districtGeoJSON || !rawAllFeatures.length || qualifyingKeys.size === 0) {
      for (const m of buyersMarketMarkers.values()) m.remove();
      buyersMarketMarkers.clear();
      return;
    }

    // Build a lookup from key to district feature for position resolution
    const featureByKey = new Map<string, any>();
    for (const f of districtGeoJSON.features) {
      const district = f.properties?.district as string | undefined;
      const city = f.properties?.city as string | undefined;
      if (district) featureByKey.set(`${city ?? ""}:${district}`, f);
    }

    // Remove markers for districts that no longer qualify
    for (const [key, marker] of buyersMarketMarkers.entries()) {
      if (!qualifyingKeys.has(key)) {
        marker.remove();
        buyersMarketMarkers.delete(key);
      }
    }

    // Add markers for newly qualifying districts (don't recreate existing ones)
    for (const key of qualifyingKeys) {
      if (buyersMarketMarkers.has(key)) continue; // already present; preserve animation

      const f = featureByKey.get(key);
      if (!f) continue;

      let center: [number, number] | null = null;
      const geom = f.geometry;
      if (geom?.type === "Polygon") {
        center = computePolygonCentroid(geom.coordinates);
      } else if (geom?.type === "MultiPolygon") {
        center = computeMultiPolygonCentroid(geom.coordinates);
      }
      if (!center) continue;

      const el = document.createElement("div");
      el.className = "bm-pulse-marker";
      const marker = new maplibregl.Marker({ element: el, anchor: "center" })
        .setLngLat(center)
        .addTo(map);
      buyersMarketMarkers.set(key, marker);
    }
  }


