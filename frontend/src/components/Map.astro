---
/**
 * MapLibre GL JS map component
 * Renders transaction dots + district choropleth layer
 */
---

<div id="map"></div>

<style is:global>
  /* Choropleth legend overlay */
  .choropleth-legend {
    position: absolute;
    bottom: 40px;
    right: 10px;
    background: rgba(255, 255, 255, 0.93);
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.78rem;
    z-index: 10;
    pointer-events: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }
  .legend-title {
    font-weight: 700;
    font-size: 0.72rem;
    color: #475569;
    margin-bottom: 7px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .legend-items { display: flex; flex-direction: column; gap: 4px; }
  .legend-item  { display: flex; align-items: center; gap: 6px; color: #334155; }
  .legend-swatch {
    width: 14px;
    height: 14px;
    border-radius: 2px;
    flex-shrink: 0;
    opacity: 0.82;
    border: 1px solid rgba(0,0,0,0.08);
  }

  /* Match count badge */
  .match-count {
    font-size: 0.78rem;
    color: #64748b;
    margin-top: 4px;
    padding: 4px 0;
  }
  .match-count strong {
    color: #2563eb;
    font-weight: 700;
  }

  /* Toggle row in sidebar */
  .toggle-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    padding: 8px 10px;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 6px;
  }
  .toggle-row input[type="checkbox"] {
    width: 15px;
    height: 15px;
    cursor: pointer;
    accent-color: #2563eb;
  }
  .toggle-row label {
    font-size: 0.85rem;
    color: #475569;
    cursor: pointer;
    margin-bottom: 0 !important;
    text-transform: none !important;
    letter-spacing: normal !important;
    font-weight: 500;
  }

  /* ---- District sparkline popup ---- */
  .district-sparkline-popup .maplibregl-popup-content {
    padding: 10px 13px 10px;
    min-width: 210px;
    max-width: 275px;
    font-size: 0.82rem;
  }
  .spark-wrap {
    margin: 7px 0 4px;
    padding: 6px 0 4px;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
  }
  .spark-label {
    font-size: 0.7rem;
    color: #64748b;
    font-weight: 600;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .spark-axis-labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.64rem;
    color: #94a3b8;
    margin-top: 3px;
  }
  @media (max-width: 400px) {
    .district-sparkline-popup .maplibregl-popup-content {
      min-width: 170px;
      max-width: 240px;
      font-size: 0.78rem;
    }
  }
</style>

<script>
  import maplibregl from "maplibre-gl";

  const API_BASE = import.meta.env.DEV ? "/api" : "";
  const BASE_URL = import.meta.env.BASE_URL;
  const STATIC_DATA_URL = `${BASE_URL}data/sample-transactions.json`;

  const CITY_DISTRICTS: Record<string, string> = {
    "台北市": `${BASE_URL}data/taipei-districts.geojson`,
    "新北市": `${BASE_URL}data/xinbei-districts.geojson`,
    "桃園市": `${BASE_URL}data/taoyuan-districts.geojson`,
    "台中市": `${BASE_URL}data/taichung-districts.geojson`,
    "台南市": `${BASE_URL}data/tainan-districts.geojson`,
    "高雄市": `${BASE_URL}data/kaohsiung-districts.geojson`,
  };

  const CITY_CENTERS: Record<string, { center: [number, number]; zoom: number }> = {
    "台北市": { center: [121.5654, 25.033], zoom: 12 },
    "新北市": { center: [121.460, 25.012], zoom: 11 },
    "桃園市": { center: [121.250, 24.970], zoom: 11 },
    "台中市": { center: [120.684, 24.138], zoom: 11 },
    "台南市": { center: [120.200, 23.000], zoom: 11 },
    "高雄市": { center: [120.300, 22.630], zoom: 11 },
  };

  // Center on Taipei
  const map = new maplibregl.Map({
    container: "map",
    style: {
      version: 8,
      name: "Real Price Radar",
      sources: {
        osm: {
          type: "raster",
          tiles: ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
          tileSize: 256,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        },
      },
      layers: [
        {
          id: "osm-tiles",
          type: "raster",
          source: "osm",
          minzoom: 0,
          maxzoom: 19,
        },
      ],
    },
    center: [121.5654, 25.033],
    zoom: 12,
    maxBounds: [[119, 21.5], [123, 26.5]],
  });

  map.addControl(new maplibregl.NavigationControl(), "top-right");
  map.addControl(new maplibregl.ScaleControl({ maxWidth: 200 }));

  // ---- Helpers ----
  function formatPrice(price: number): string {
    if (price >= 100_000_000) return `${(price / 100_000_000).toFixed(1)} 億`;
    if (price >= 10_000) return `${(price / 10_000).toFixed(0)} 萬`;
    return price.toLocaleString();
  }

  // ---- Choropleth state ----
  let districtGeoJSON: any = null;
  let currentTxGeojson: any = null;

  // ---- Affordability overlay state ----
  let affordabilityActive = false;
  let affordabilityThreshold = 0; // TWD per ping

  const DEFAULT_FILL_COLOR: any = [
    "case",
    ["<", ["coalesce", ["get", "medianPrice"], -1], 0],
    "#d1d5db",
    [
      "interpolate", ["linear"],
      ["get", "medianPrice"],
      300000,  "#22c55e",
      500000,  "#84cc16",
      700000,  "#eab308",
      900000,  "#f97316",
      1100000, "#ef4444",
      1400000, "#7c1010",
    ],
  ];

  function getAffordabilityFillColor(threshold: number): any {
    return [
      "case",
      ["<", ["coalesce", ["get", "medianPrice"], -1], 0], "#d1d5db",
      ["<=", ["get", "medianPrice"], threshold], "#22c55e",
      ["<=", ["get", "medianPrice"], threshold * 1.2], "#eab308",
      "#ef4444",
    ];
  }

  function updateAffordabilityLegend(active: boolean, thresholdWan?: number): void {
    const legend = document.getElementById("choropleth-legend");
    if (!legend) return;
    if (active && thresholdWan !== undefined) {
      const borderlineWan = (thresholdWan * 1.2).toFixed(0);
      legend.innerHTML = `
        <div class="legend-title">可負擔性地圖</div>
        <div class="legend-items">
          <div class="legend-item"><span class="legend-swatch" style="background:#22c55e"></span>可負擔 (≤${thresholdWan.toFixed(0)}萬/坪)</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#eab308"></span>邊緣 (≤${borderlineWan}萬/坪)</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>負擔重 (&gt;${borderlineWan}萬/坪)</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#d1d5db"></span>資料不足</div>
        </div>`;
    } else {
      legend.innerHTML = `
        <div class="legend-title">行政區 中位數單價</div>
        <div class="legend-items">
          <div class="legend-item"><span class="legend-swatch" style="background:#22c55e"></span>&lt; 50萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#84cc16"></span>50–70萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#eab308"></span>70–90萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#f97316"></span>90–110萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>110–140萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#7c1010"></span>&gt; 140萬/坪</div>
          <div class="legend-item"><span class="legend-swatch" style="background:#d1d5db"></span>資料不足</div>
        </div>`;
    }
  }

  /** Compute median unit price per district from transaction features. */
  function computeDistrictMedians(features: any[]): Record<string, number> {
    const byDistrict: Record<string, number[]> = {};
    for (const f of features) {
      const d = f.properties?.district as string | undefined;
      const p = f.properties?.unitPrice as number | undefined;
      if (d && p && p > 0) {
        if (!byDistrict[d]) byDistrict[d] = [];
        byDistrict[d].push(p);
      }
    }
    const medians: Record<string, number> = {};
    for (const [d, prices] of Object.entries(byDistrict)) {
      const sorted = [...prices].sort((a, b) => a - b);
      medians[d] = sorted[Math.floor(sorted.length / 2)];
    }
    return medians;
  }

  /** Re-join district median prices into the district GeoJSON and update source. */
  function updateChoropleth(): void {
    const src = map.getSource("districts") as maplibregl.GeoJSONSource | undefined;
    if (!src || !districtGeoJSON || !currentTxGeojson) return;
    const medians = computeDistrictMedians(currentTxGeojson.features ?? []);
    const updated = {
      ...districtGeoJSON,
      features: districtGeoJSON.features.map((f: any) => ({
        ...f,
        properties: {
          ...f.properties,
          medianPrice: medians[f.properties.district] ?? -1,
        },
      })),
    };
    src.setData(updated);
  }

  /** Load district boundary GeoJSON for the given city. */
  async function loadDistrictBoundaries(city: string): Promise<void> {
    const url = CITY_DISTRICTS[city] ?? CITY_DISTRICTS["台北市"];
    try {
      const res = await fetch(url);
      districtGeoJSON = await res.json();
    } catch (e) {
      console.warn("[choropleth] district boundaries unavailable:", e);
      districtGeoJSON = null;
    }
    updateChoropleth();
  }

  // ---- Transaction loading ----
  async function loadTransactions(params: Record<string, string> = {}): Promise<any> {
    let geojson: any;

    try {
      if (API_BASE) {
        const qs = new URLSearchParams(params).toString();
        const url = `${API_BASE}/transactions/geojson${qs ? `?${qs}` : ""}`;
        const res = await fetch(url);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        geojson = await res.json();
      } else {
        throw new Error("No API configured");
      }
    } catch {
      // Fall back to static sample data
      const res = await fetch(STATIC_DATA_URL);
      geojson = await res.json();

      // Client-side filtering
      if (params.city)         geojson.features = geojson.features.filter((f: any) => f.properties.city === params.city);
      if (params.district)    geojson.features = geojson.features.filter((f: any) => f.properties.district === params.district);
      if (params.minPrice)    geojson.features = geojson.features.filter((f: any) => f.properties.unitPrice >= Number(params.minPrice));
      if (params.maxPrice)    geojson.features = geojson.features.filter((f: any) => f.properties.unitPrice <= Number(params.maxPrice));
      if (params.buildingType) geojson.features = geojson.features.filter((f: any) => f.properties.buildingType === params.buildingType);
      if (params.dateFrom)  geojson.features = geojson.features.filter((f: any) => f.properties.date >= params.dateFrom);
      if (params.dateTo)    geojson.features = geojson.features.filter((f: any) => f.properties.date <= params.dateTo);
      if (params.totalPriceMin) geojson.features = geojson.features.filter((f: any) => f.properties.totalPrice >= Number(params.totalPriceMin) * 10000);
      if (params.totalPriceMax) geojson.features = geojson.features.filter((f: any) => f.properties.totalPrice <= Number(params.totalPriceMax) * 10000);
      if (params.areaMin) geojson.features = geojson.features.filter((f: any) => f.properties.areaPing >= Number(params.areaMin));
      if (params.areaMax) geojson.features = geojson.features.filter((f: any) => f.properties.areaPing <= Number(params.areaMax));
      if (params.address) {
        const keyword = params.address.toLowerCase();
        geojson.features = geojson.features.filter((f: any) => {
          const addr = (f.properties.address || "").toLowerCase();
          return addr.includes(keyword);
        });
      }
    }

    currentTxGeojson = geojson;

    try {
      const source = map.getSource("transactions") as maplibregl.GeoJSONSource | undefined;
      if (source) {
        source.setData(geojson);
      } else {
        map.addSource("transactions", { type: "geojson", data: geojson });
        map.addLayer({
          id: "transactions-circles",
          type: "circle",
          source: "transactions",
          paint: {
            "circle-radius": [
              "interpolate", ["linear"], ["zoom"],
              10, 2, 14, 6, 18, 12,
            ],
            "circle-color": [
              "interpolate", ["linear"],
              ["get", "unitPrice"],
              200000, "#22c55e",
              400000, "#84cc16",
              600000, "#eab308",
              800000, "#f97316",
              1000000, "#ef4444",
              1500000, "#dc2626",
            ],
            "circle-opacity": 0.85,
            "circle-stroke-width": 1,
            "circle-stroke-color": "#ffffff",
            "circle-stroke-opacity": 0.5,
          },
        });
      }

      // Update stats panel
      const statsEl = document.getElementById("stats-content");
      if (statsEl && geojson.features) {
        const prices = geojson.features
          .map((f: any) => f.properties.unitPrice)
          .filter((p: any) => p != null && p > 0);
        if (prices.length > 0) {
          prices.sort((a: number, b: number) => a - b);
          const median = prices[Math.floor(prices.length / 2)];
          const avg = Math.round(prices.reduce((s: number, p: number) => s + p, 0) / prices.length);
          statsEl.innerHTML = `
            <div class="match-count">符合筆數：<strong>${geojson.features.length.toLocaleString()}</strong></div>
            <div class="popup-row">
              <span class="popup-label">中位數單價 (萬/坪)</span>
              <span class="popup-price">${formatPrice(median)}</span>
            </div>
            <div class="popup-row">
              <span class="popup-label">平均單價 (萬/坪)</span>
              <span class="popup-price">${formatPrice(avg)}</span>
            </div>
          `;
        } else {
          statsEl.innerHTML = `
          <div class="stats-empty-state">
            <div class="empty-state-icon">📊</div>
            <p class="empty-state-msg">目前篩選條件下無符合交易記錄。</p>
            <p class="empty-state-hint">試試調整篩選條件以查看統計資訊。</p>
          </div>`;
        }
      }

      // Dispatch histogram event
      const allPrices: number[] = (geojson.features ?? [])
        .map((f: any) => f.properties.unitPrice as number)
        .filter((p: any) => p != null && p > 0);

      if (allPrices.length >= 3) {
        const minP = Math.min(...allPrices);
        const maxP = Math.max(...allPrices);
        const binWidth = (maxP - minP) / 10;
        const bins: string[] = [];
        const counts: number[] = new Array(10).fill(0);
        for (let i = 0; i < 10; i++) {
          const lo = minP + i * binWidth;
          const hi = minP + (i + 1) * binWidth;
          bins.push(`${Math.round(lo / 10000)}-${Math.round(hi / 10000)}萬`);
          for (const p of allPrices) {
            if (i < 9 ? (p >= lo && p < hi) : (p >= lo && p <= hi)) counts[i]++;
          }
        }
        const sorted = [...allPrices].sort((a, b) => a - b);
        const medianWan = sorted[Math.floor(sorted.length / 2)] / 10000;
        const avgWan = allPrices.reduce((s, p) => s + p, 0) / allPrices.length / 10000;
        document.dispatchEvent(new CustomEvent("stats-histogram", {
          detail: { bins, counts, median: medianWan, avg: avgWan },
        }));
      } else {
        document.dispatchEvent(new CustomEvent("stats-histogram", {
          detail: { bins: [], counts: [], median: 0, avg: 0 },
        }));
      }
    } catch (err) {
      console.error("Failed to update map layer:", err);
    }

    // Recompute choropleth colors with current data

    // Render transaction list
    const sortBy = (document.getElementById('sort-by') as HTMLSelectElement)?.value || 'date-desc';
    renderTransactionList(geojson.features || [], sortBy);
    updateChoropleth();
    return geojson;
  }

  // ---- Map load ----
  map.on("load", async () => {
    // 1. District fill + border layers FIRST (render below transaction dots)
    map.addSource("districts", {
      type: "geojson",
      data: { type: "FeatureCollection", features: [] },
    });

    map.addLayer({
      id: "districts-fill",
      type: "fill",
      source: "districts",
      paint: {
        "fill-color": [
          "case",
          ["<", ["coalesce", ["get", "medianPrice"], -1], 0],
          "#d1d5db",
          [
            "interpolate", ["linear"],
            ["get", "medianPrice"],
            300000,  "#22c55e",
            500000,  "#84cc16",
            700000,  "#eab308",
            900000,  "#f97316",
            1100000, "#ef4444",
            1400000, "#7c1010",
          ],
        ],
        "fill-opacity": 0.44,
      },
    });

    map.addLayer({
      id: "districts-line",
      type: "line",
      source: "districts",
      paint: {
        "line-color": "#475569",
        "line-width": 1.5,
        "line-opacity": 0.65,
      },
    });

    // 2. Load transactions — circles layer added ON TOP of district fill
    await loadTransactions();

    // 3. Fetch Taipei district boundaries initially
    await loadDistrictBoundaries("台北市");

    // 4. Inject legend into map container
    const legend = document.createElement("div");
    legend.id = "choropleth-legend";
    legend.className = "choropleth-legend";
    legend.innerHTML = `
      <div class="legend-title">行政區 中位數單價</div>
      <div class="legend-items">
        <div class="legend-item"><span class="legend-swatch" style="background:#22c55e"></span>&lt; 50萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#84cc16"></span>50–70萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#eab308"></span>70–90萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#f97316"></span>90–110萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#ef4444"></span>110–140萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#7c1010"></span>&gt; 140萬/坪</div>
        <div class="legend-item"><span class="legend-swatch" style="background:#d1d5db"></span>資料不足</div>
      </div>`;
    document.getElementById("map")!.appendChild(legend);
  });

  // ---- Popup on transaction click ----
  map.on("click", "transactions-circles", (e) => {
    if (!e.features || e.features.length === 0) return;
    const props = e.features[0].properties;
    const coords = (e.features[0].geometry as GeoJSON.Point).coordinates.slice() as [number, number];
    new maplibregl.Popup({ offset: 10 })
      .setLngLat(coords)
      .setHTML(`
        <div class="popup-title">${props.address || "地址未登錄"}</div>
        <div class="popup-row">
          <span class="popup-label">單價</span>
          <span class="popup-price">${formatPrice(props.unitPrice)}/</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">總價</span>
          <span class="popup-value">${formatPrice(props.totalPrice)}</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">坪數</span>
          <span class="popup-value">${props.areaPing ? Number(props.areaPing).toFixed(1) + " 坪" : "—"}</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">型態</span>
          <span class="popup-value">${props.buildingType || "—"}</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">樓層</span>
          <span class="popup-value">${props.floor && props.floorsTotal ? `${props.floor}F / ${props.floorsTotal}F` : "—"}</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">格局</span>
          <span class="popup-value">${props.rooms ? `${props.rooms}房` : "—"}</span>
        </div>
        <div class="popup-row">
          <span class="popup-label">交易日期</span>
          <span class="popup-value">${props.date}</span>
        </div>
      `)
      .addTo(map);

    // Dispatch price-history trend for same district × building type
    const txDistrict = props.district as string | undefined;
    const txType     = props.buildingType as string | undefined;
    if (txDistrict) {
      const txFeatures = currentTxGeojson?.features ?? [];
      const quarterly: Record<string, number[]> = {};
      for (const f of txFeatures) {
        if (f.properties.district !== txDistrict) continue;
        if (txType && f.properties.buildingType !== txType) continue;
        const p = f.properties.unitPrice as number | undefined;
        const d = f.properties.date as string | undefined;
        const dt = new Date(d);
        const q = Math.floor(dt.getMonth() / 3) + 1;
        const key = `${dt.getFullYear()}-Q${q}`;
        quarterly[key].push(p);
      }
      const quarters = Object.keys(quarterly).sort();
      const medians = quarters.map((q) => {
        const arr = quarterly[q].sort((a, b) => a - b);
        return arr[Math.floor(arr.length / 2)];
      });
      document.dispatchEvent(
        new CustomEvent('district-trend', {
          detail: { district: txDistrict, quarters, medians, buildingType: txType ?? '', source: 'dot' },
        })
      );
    }
  });

  // Cursor on transaction dots
  map.on("mouseenter", "transactions-circles", () => {
    map.getCanvas().style.cursor = "pointer";
  });
  map.on("mouseleave", "transactions-circles", () => {
    map.getCanvas().style.cursor = "";
  });

  // ---- SVG sparkline helper ----
  /**
   * Renders an inline SVG sparkline for up to N quarterly price points.
   * Null entries create a visual gap — no line is drawn through those quarters.
   */
  function buildSparkline(values: (number | null)[], width = 204, height = 44): string {
    const W = width, H = height;
    const PX = 3, PY = 5; // padding
    const plotW = W - PX * 2;
    const plotH = H - PY * 2;
    const n = values.length;

    const nonNull = values.filter((v): v is number => v !== null && v > 0);
    if (nonNull.length === 0) {
      return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}"><text x="${W / 2}" y="${H / 2 + 3}" text-anchor="middle" font-size="9" fill="#94a3b8">暫無走勢資料</text></svg>`;
    }

    const yMin = Math.min(...nonNull);
    const yMax = Math.max(...nonNull);
    const yRange = yMax - yMin || 1;

    // Map each value to SVG coordinates; null → null
    const pts: ([number, number] | null)[] = values.map((v, i) => {
      if (v === null) return null;
      const x = PX + (n <= 1 ? plotW / 2 : (i / (n - 1)) * plotW);
      const y = PY + plotH - ((v - yMin) / yRange) * plotH;
      return [+x.toFixed(1), +y.toFixed(1)];
    });

    // Build contiguous polyline segments, breaking at null gaps
    const lines: string[] = [];
    let seg: [number, number][] = [];
    const flushSeg = () => {
      if (seg.length >= 2) {
        lines.push(`<polyline points="${seg.map((p) => p.join(",")).join(" ")}" fill="none" stroke="#3b82f6" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"/>`);
      } else if (seg.length === 1) {
        lines.push(`<circle cx="${seg[0][0]}" cy="${seg[0][1]}" r="2" fill="#3b82f6"/>`);
      }
      seg = [];
    };
    for (const pt of pts) {
      if (pt === null) { flushSeg(); } else { seg.push(pt); }
    }
    flushSeg();

    // Data-point dots overlaid on the lines
    const dots = pts
      .filter((p): p is [number, number] => p !== null)
      .map(([x, y]) => `<circle cx="${x}" cy="${y}" r="2.2" fill="#2563eb" stroke="white" stroke-width="1.2"/>`)
      .join("");

    return `<svg width="${W}" height="${H}" viewBox="0 0 ${W} ${H}" style="display:block;overflow:visible">${lines.join("")}${dots}</svg>`;
  }

  // ---- District click → sparkline popup + dispatch trend event ----
  let districtClickPopup: maplibregl.Popup | null = null;

  map.on("click", "districts-fill", (e) => {
    if (!e.features || e.features.length === 0) return;
    // Don't open district popup when clicking a transaction dot on top of the fill
    if (map.queryRenderedFeatures(e.point, { layers: ["transactions-circles"] }).length > 0) return;

    const district = e.features[0].properties.district as string;
    const txFeatures = currentTxGeojson?.features ?? [];

    // Group unit prices by quarter for this district
    const quarterly: Record<string, number[]> = {};
    for (const f of txFeatures) {
      if (f.properties.district !== district) continue;
      const p = f.properties.unitPrice as number | undefined;
      const d = f.properties.date as string | undefined;
      if (!p || p <= 0 || !d) continue;
      const dt = new Date(d);
      if (isNaN(dt.getTime())) continue;
      const q = Math.floor(dt.getMonth() / 3) + 1;
      const key = `${dt.getFullYear()}-Q${q}`;
      (quarterly[key] ??= []).push(p);
    }

    // Overall median for the filtered district (all quarters combined)
    const allPrices = Object.values(quarterly).flat().sort((a, b) => a - b);
    const medianPrice = allPrices.length ? allPrices[Math.floor(allPrices.length / 2)] : null;

    // Transactions in the last 6 months (近半年)
    const cutoff = new Date();
    cutoff.setMonth(cutoff.getMonth() - 6);
    const sixMonthCount = txFeatures.filter((f: any) => {
      if (f.properties.district !== district) return false;
      const d = f.properties.date as string | undefined;
      return d && new Date(d) >= cutoff;
    }).length;

    // Determine the 8-quarter window anchored at the latest quarter present in data
    const allSortedKeys = Object.keys(quarterly).sort();
    let anchorDate: Date;
    if (allSortedKeys.length > 0) {
      const [yr, qStr] = allSortedKeys[allSortedKeys.length - 1].split("-Q");
      anchorDate = new Date(Number(yr), (Number(qStr) - 1) * 3, 1);
    } else {
      anchorDate = new Date();
    }

    const last8: string[] = [];
    for (let i = 7; i >= 0; i--) {
      const d = new Date(anchorDate);
      d.setMonth(d.getMonth() - i * 3);
      const q = Math.floor(d.getMonth() / 3) + 1;
      last8.push(`${d.getFullYear()}-Q${q}`);
    }

    // Sparkline values: median per quarter, null if no transactions that quarter
    const sparkValues: (number | null)[] = last8.map((qk) => {
      const arr = quarterly[qk];
      if (!arr || arr.length === 0) return null;
      const sorted = [...arr].sort((a, b) => a - b);
      return sorted[Math.floor(sorted.length / 2)];
    });

    // Dispatch sidebar trend event (all quarters with data, sorted)
    const trendMedians = allSortedKeys.map((qk) => {
      const arr = [...quarterly[qk]].sort((a, b) => a - b);
      return arr[Math.floor(arr.length / 2)];
    });
    document.dispatchEvent(
      new CustomEvent("district-trend", { detail: { district, quarters: allSortedKeys, medians: trendMedians } })
    );

    // Build popup HTML
    const medianWan = medianPrice ? (medianPrice / 10_000).toFixed(1) : "—";
    const hasSparkData = sparkValues.some((v) => v !== null);
    const sparkSection = hasSparkData
      ? `<div class="spark-wrap">
           <div class="spark-label">📈 季均價走勢 (萬/坪)</div>
           ${buildSparkline(sparkValues)}
           <div class="spark-axis-labels">
             <span>${last8[0]}</span><span>${last8[7]}</span>
           </div>
         </div>`
      : `<div class="popup-row" style="color:#94a3b8;font-size:0.76rem;margin-top:4px">走勢資料不足</div>`;

    districtClickPopup?.remove();
    districtClickPopup = new maplibregl.Popup({
      closeButton: true,
      closeOnClick: false,
      offset: [0, -6],
      className: "district-sparkline-popup",
      maxWidth: "280px",
    })
      .setLngLat(e.lngLat)
      .setHTML(
        `<div class="popup-title">${district}</div>
         <div class="popup-row">
           <span class="popup-label">中位單價</span>
           <span class="popup-price">${medianWan} 萬/坪</span>
         </div>
         ${sparkSection}
         <div class="popup-row" style="margin-top:6px">
           <span class="popup-label">近半年成交</span>
           <span class="popup-value">${sixMonthCount} 筆</span>
         </div>`
      )
      .addTo(map);
  });

  // Cursor on district polygons
  map.on("mouseenter", "districts-fill", () => {
    map.getCanvas().style.cursor = "pointer";
  });
  map.on("mouseleave", "districts-fill", () => {
    map.getCanvas().style.cursor = "";
  });

  // ---- District hover popup ----
  let districtHover: maplibregl.Popup | null = null;

  map.on("mousemove", "districts-fill", (e) => {
    if (!e.features || e.features.length === 0) return;
    const props = e.features[0].properties as Record<string, any>;
    if (!districtHover) {
      districtHover = new maplibregl.Popup({
        closeButton: false,
        closeOnClick: false,
        offset: 4,
      });
    }
    const priceHtml =
      props.medianPrice > 0
        ? (() => {
            const baseHtml = `<div class="popup-row"><span class="popup-label">中位數單價</span><span class="popup-price">${formatPrice(props.medianPrice)}/坪</span></div>`;
            if (affordabilityActive && affordabilityThreshold > 0) {
              let status: string;
              if (props.medianPrice <= affordabilityThreshold) {
                status = `<div class="popup-row" style="color:#16a34a;font-weight:600">✅ 可負擔</div>`;
              } else if (props.medianPrice <= affordabilityThreshold * 1.2) {
                status = `<div class="popup-row" style="color:#ca8a04;font-weight:600">⚠️ 邊緣</div>`;
              } else {
                status = `<div class="popup-row" style="color:#dc2626;font-weight:600">❌ 負擔重</div>`;
              }
              return baseHtml + status;
            }
            return baseHtml;
          })()
        : `<div class="popup-row"><span class="popup-label">資料不足</span></div>`;
    districtHover
      .setLngLat(e.lngLat)
      .setHTML(`<div class="popup-title">${props.district}</div>${priceHtml}`)
      .addTo(map);
  });

  map.on("mouseleave", "districts-fill", () => {
    districtHover?.remove();
    districtHover = null;
  });

  // Close district sparkline popup when clicking outside a district polygon
  map.on("click", (e) => {
    if (!districtClickPopup) return;
    if (map.queryRenderedFeatures(e.point, { layers: ["districts-fill"] }).length === 0) {
      districtClickPopup.remove();
      districtClickPopup = null;
    }
  });

  // Escape key closes the district sparkline popup
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape" && districtClickPopup) {
      districtClickPopup.remove();
      districtClickPopup = null;
    }
  });

  // ---- Search button ----
  document.getElementById("search-btn")?.addEventListener("click", () => {
    const params: Record<string, string> = {};
    const city         = (document.getElementById("city-select")    as HTMLSelectElement)?.value;
    const district     = (document.getElementById("district-select") as HTMLSelectElement)?.value;
    const minPrice     = (document.getElementById("price-min")       as HTMLInputElement)?.value;
    const maxPrice     = (document.getElementById("price-max")       as HTMLInputElement)?.value;
    const buildingType = (document.getElementById("building-type")   as HTMLSelectElement)?.value;
    const address      = (document.getElementById("address-search")  as HTMLInputElement)?.value;
    if (city)         params.city = city;
    if (district)     params.district = district;
    if (minPrice)     params.minPrice = String(Number(minPrice) * 10000);
    if (maxPrice)     params.maxPrice = String(Number(maxPrice) * 10000);
    const totalPriceMin = (document.getElementById("total-price-min") as HTMLInputElement)?.value;
    const totalPriceMax = (document.getElementById("total-price-max") as HTMLInputElement)?.value;
    if (totalPriceMin) params.totalPriceMin = totalPriceMin;
    if (totalPriceMax) params.totalPriceMax = totalPriceMax;
    const areaMin = (document.getElementById("area-min") as HTMLInputElement)?.value;
    const areaMax = (document.getElementById("area-max") as HTMLInputElement)?.value;
    if (areaMin) params.areaMin = areaMin;
    if (areaMax) params.areaMax = areaMax;
    if (buildingType) params.buildingType = buildingType;
    if (address)      params.address = address;
    const dateFrom = (document.getElementById("date-from") as HTMLInputElement)?.value;
    const dateTo   = (document.getElementById("date-to")   as HTMLInputElement)?.value;
    if (dateFrom) params.dateFrom = dateFrom;
    if (dateTo)   params.dateTo   = dateTo;

    // Fly to selected city center and load matching district boundaries
    const targetCity = city || "台北市";
    if (city && CITY_CENTERS[city]) {
      map.flyTo({ center: CITY_CENTERS[city].center, zoom: CITY_CENTERS[city].zoom, duration: 800 });
    }
    loadTransactions(params);
    loadDistrictBoundaries(targetCity);
  });

  // ---- Affordability overlay ----
  document.addEventListener("affordability-mode-change", (e: Event) => {
    const detail = (e as CustomEvent).detail as {
      enabled: boolean;
      maxUnitPricePerPing?: number;
    };

    if (!map.getLayer("districts-fill")) return;

    if (detail.enabled && detail.maxUnitPricePerPing && detail.maxUnitPricePerPing > 0) {
      affordabilityActive = true;
      affordabilityThreshold = detail.maxUnitPricePerPing;
      map.setPaintProperty("districts-fill", "fill-color", getAffordabilityFillColor(affordabilityThreshold));
      // Ensure district layers are visible when affordability overlay is turned on
      for (const id of ["districts-fill", "districts-line"]) {
        if (map.getLayer(id)) map.setLayoutProperty(id, "visibility", "visible");
      }
      const choroplethToggle = document.getElementById("choropleth-toggle") as HTMLInputElement | null;
      if (choroplethToggle) choroplethToggle.checked = true;
      updateAffordabilityLegend(true, affordabilityThreshold / 10000);
      const legend = document.getElementById("choropleth-legend");
      if (legend) legend.style.opacity = "1";
    } else {
      affordabilityActive = false;
      affordabilityThreshold = 0;
      map.setPaintProperty("districts-fill", "fill-color", DEFAULT_FILL_COLOR);
      updateAffordabilityLegend(false);
    }
  });

  // ---- Choropleth toggle ----
  document.getElementById("choropleth-toggle")?.addEventListener("change", (e) => {
    const on = (e.target as HTMLInputElement).checked;
    const vis = on ? "visible" : "none";
    for (const id of ["districts-fill", "districts-line"]) {
      if (map.getLayer(id)) map.setLayoutProperty(id, "visibility", vis);
    }
    const legend = document.getElementById("choropleth-legend");

  // ---- Transaction List Rendering ----
  function renderTransactionList(features: any[], sortBy: string = 'date-desc'): void {
    const panel = document.getElementById("transaction-list-panel") as HTMLDivElement | null;
    const content = document.getElementById("transaction-list-content") as HTMLDivElement | null;
    if (!panel || !content) return;

    if (!features || features.length === 0) {
      panel.style.display = "block";
      content.innerHTML = `
        <div class="transaction-list-empty">
          <div class="empty-state-icon">🔍</div>
          <p class="empty-state-msg">目前篩選條件下無符合交易記錄。<br>試試調整價格範圍或日期區間。</p>
        </div>`;
      return;
    }

    panel.style.display = "block";

    // Sort transactions
    const sorted = [...features];
    const [field, order] = sortBy.split('-');
    sorted.sort((a, b) => {
      let aVal: any, bVal: any;
      if (field === 'date') {
        aVal = new Date(a.properties.date || '').getTime();
        bVal = new Date(b.properties.date || '').getTime();
      } else if (field === 'unitPrice' || field === 'totalPrice') {
        aVal = a.properties[field] || 0;
        bVal = b.properties[field] || 0;
      } else {
        return 0;
      }
      return order === 'desc' ? bVal - aVal : aVal - bVal;
    });

    // Limit to first 50 transactions (performance)
    const limited = sorted.slice(0, 50);

    if (limited.length === 0) {
      content.innerHTML = '<div class="transaction-list-empty">查無符合條件的資料</div>';
      return;
    }

    content.innerHTML = limited.map((f: any) => {
      const p = f.properties;
      const unitPriceWan = p.unitPrice ? (p.unitPrice / 10000).toFixed(1) : '—';
      const totalPriceWan = p.totalPrice ? (p.totalPrice / 10000).toFixed(0) : '—';
      const areaPing = p.areaPing ? Number(p.areaPing).toFixed(1) : '—';
      const buildingType = p.buildingType || '—';
      const date = p.date || '—';

      return `
        <div class="transaction-item" data-coords="${f.geometry.coordinates[0]},${f.geometry.coordinates[1]}">
          <div class="transaction-item-address">${p.address || '地址未登錄'}</div>
          <div class="transaction-item-details">
            <span class="price-highlight">單價 ${unitPriceWan} 萬/坪</span>
            <span>總價 ${totalPriceWan} 萬</span>
            <span>${areaPing} 坪</span>
            <span>${buildingType}</span>
            <span>${date}</span>
          </div>
        </div>
      `;
    }).join('');

    // Add click handlers to fly to transaction on map
    content.querySelectorAll('.transaction-item').forEach((item) => {
      item.addEventListener('click', () => {
        const coords = (item as HTMLElement).dataset.coords?.split(',').map(Number);
        if (coords && coords.length === 2) {
          map.flyTo({ center: coords as [number, number], zoom: 16, duration: 600 });
        }
      });
    });
  }

  // Hook sort dropdown
  document.getElementById("sort-by")?.addEventListener("change", (e) => {
    const sortBy = (e.target as HTMLSelectElement).value;
    if (currentTxGeojson) {
      renderTransactionList(currentTxGeojson.features || [], sortBy);
    }
  });

    if (legend) legend.style.opacity = on ? "1" : "0";
  });

  // Initial load
  map.on("load", () => { /* handled by the async load handler above */ });
</script>
