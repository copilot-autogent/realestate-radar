        ? `<span class="bm-opportunity-indicator" style="background:#fefce8;border-color:#fde047;color:#713f12">⚠️ 買方機會區（資料逾90天）</span>`
        : `<span class="bm-opportunity-indicator">🟢 買方機會區</span>`
      : "";
    districtHover
      .setLngLat(e.lngLat)
      .setHTML(`<div class="popup-title">${props.district}</div>${bmOpportunityHtml}${priceHtml}${completionHtml}${buyerScoreHtml}${volatilityHoverHtml}${ageHtml}`)
