        map.setPaintProperty("districts-fill", "fill-color", getPresaleSpreadFillColor());
        updatePresaleSpreadLegend(true);
      }
      const legend = document.getElementById("choropleth-legend");
      if (legend) legend.style.opacity = "1";
    } else {
      updateChoropleth();
      if (completionActive) {
        map.setPaintProperty("districts-fill", "fill-color", getCompletionFillColor());
      } else if (volatilityActive) {
        map.setPaintProperty("districts-fill", "fill-color", getVolatilityFillColor());
        updateVolatilityLegend(true);
      } else if (buyerScoreActive) {
        map.setPaintProperty("districts-fill", "fill-color", getBuyerScoreFillColor());
        updateBuyerScoreLegend(true);
      } else if (mrtPremiumActive) {
        map.setPaintProperty("districts-fill", "fill-color", getMrtPremiumFillColor());
        updateMrtPremiumLegend(true);
      } else if (affordabilityActive && affordabilityThreshold > 0) {
        map.setPaintProperty("districts-fill", "fill-color", getAffordabilityFillColor(affordabilityThreshold));
        updateAffordabilityLegend(true, affordabilityThreshold / 10000);
      } else {
        map.setPaintProperty("districts-fill", "fill-color", DEFAULT_FILL_COLOR);
        updateAffordabilityLegend(false);
      }
      updatePresaleSpreadLegend(false);
    }
  });

  // ---- Comparison panel controls (registered once at top level, not inside any callback) ----
  document.getElementById("comparison-clear-btn")?.addEventListener("click", (e) => {
    e.stopPropagation();
    pinnedDistricts = [];
    renderComparisonPanel();
    // Refresh the open popup's pin button (may have been showing "移除比較" or disabled)
    syncOpenPopupPinButton();
  });

  document.getElementById("comparison-toggle-btn")?.addEventListener("click", (e) => {
    e.stopPropagation();
    document.getElementById("comparison-panel")?.classList.toggle("collapsed");
  });

  // Clicking the header (but not its children) also toggles collapse
  document.querySelector(".comparison-panel-header")?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).closest("button")) return;
    document.getElementById("comparison-panel")?.classList.toggle("collapsed");
  });

  // Initial load
  map.on("load", () => { /* handled by the async load handler above */ });
</script>
